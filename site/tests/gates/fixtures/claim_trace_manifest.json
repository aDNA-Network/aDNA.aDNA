    {
      "id": "canonical-repo",
      "class": "source_fidelity",
      "claim": "the clone-and-run image lives at the canonical repo",
      "rendered_on": ["/", "/network", "/get-started"],
      "source_ref": "src/data/canonical.ts",
      "owner": "website",
      "check": { "kind": "exists" },
      "expected": null
    },
    {
      "id": "subnetworks-count",
      "class": "structural",
      "claim": "four public-good subnetworks are featured",
      "rendered_on": ["/commons"],
      "source_ref": "src/data/subnetworks.json",
      "owner": "website",
      "check": { "kind": "exists" },
      "expected": null
