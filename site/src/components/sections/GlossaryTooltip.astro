---
interface Props {
  term: string;
  slug?: string;
  definition: string;
  display?: string;
}

const { term, slug, definition, display } = Astro.props;

const kebab = (s: string) =>
  s.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

const termSlug = slug ?? kebab(term);
const href = `/glossary/glossary-${termSlug}`;
const tooltipId = `gloss-tip-${termSlug}`;
---

<span class="glossary-tip">
  <a href={href} class="glossary-tip__term" aria-describedby={tooltipId}>
    {display ?? term}<span class="glossary-tip__icon" aria-hidden="true">ⓘ</span>
  </a>
  <span role="tooltip" id={tooltipId} class="glossary-tip__body">
    <strong class="glossary-tip__head">{term}</strong>
    {definition}
  </span>
</span>

<style>
  .glossary-tip {
    position: relative;
    display: inline-block;
  }

  .glossary-tip__term {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dashed var(--color-primary);
    cursor: help;
  }

  .glossary-tip__term:hover,
  .glossary-tip__term:focus-visible {
    color: var(--color-primary);
    border-bottom-style: solid;
  }

  .glossary-tip__icon {
    font-size: 0.7em;
    margin-left: 0.2em;
    color: var(--color-primary);
    vertical-align: super;
  }

  .glossary-tip__body {
    position: absolute;
    bottom: calc(100% + 0.45rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 14rem;
    max-width: 22rem;
    padding: var(--space-3);
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
    font-size: var(--text-sm);
    line-height: 1.45;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 120ms ease, visibility 120ms ease;
    z-index: 50;
    white-space: normal;
  }

  .glossary-tip__head {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .glossary-tip:hover .glossary-tip__body,
  .glossary-tip:focus-within .glossary-tip__body {
    opacity: 1;
    visibility: visible;
  }

  @media (max-width: 640px) {
    .glossary-tip__body {
      left: 0;
      transform: none;
      max-width: min(20rem, 88vw);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glossary-tip__body {
      transition: none;
    }
  }
</style>
