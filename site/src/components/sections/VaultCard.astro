---
interface Props { vault: any; }
const { vault } = Astro.props;

// Refit M2 / DP1 (2026-07-21, ratification_record_refit_g1): `tagline` is the canonical
// per-vault purpose field (`headline_mission` retired — 0/73 populated, never authored);
// fall back to `note` (the populated one-liner) so the purpose renders NOW from existing
// data and auto-upgrades as Home backfills taglines. No strings authored here.
const purpose = vault.tagline || vault.note || null;
// Suppress the "—" persona placeholder (data-currency artifact routed to Hestia) so the
// card never shows a lone em-dash above the new purpose line.
const persona = vault.persona && vault.persona !== '—' ? vault.persona : null;
// Flat search haystack for the client-side registry filter (M3.1.3); no-JS ignores it.
const searchBlob = [vault.display_name, persona, vault.class, purpose]
  .filter(Boolean).join(' ').toLowerCase();
---

<article
  class={`vault-card class-${vault.class}`}
  data-vault-card
  data-class={vault.class}
  data-search={searchBlob}
>
  <h3>
    <a href={`/vaults/${vault.vault_slug}/`}>{vault.display_name}</a>
  </h3>
  {persona && <p class="vault-card-persona">{persona}</p>}
  {purpose && <p class="vault-card-purpose">{purpose}</p>}
  <p class="vault-card-meta">
    <span class={`vault-status status-${vault.status}`}>{vault.status}</span>
    {vault.current_phase && <span class="vault-phase">{vault.current_phase}</span>}
  </p>
</article>

<style>
  /* Token-driven (audit P1 / campaign_adna_network_audit DS5): replaces hardcoded light-mode greys +
     off-palette blue hover + pale-pastel status fills that inherited dark page text at 1.15:1 (78-node
     WCAG-AA failure on the Tokyo-Night register). Status pills mirror RegistryCard's AA-safe color-mix
     (text darkened toward --color-text so the label meets AA on its own pale tint, both modes). */
  /* Storyweave P5 M5.2 / B11: harmonized with RegistryCard — tokenized padding
     (1rem = --space-4) + the --color-primary hover the sibling card tiers share
     (was the off-tier --color-link blue). Density stays denser than RegistryCard
     by design (this is the /vaults listing card). */
  .vault-card { padding: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-lg); transition: border-color var(--transition-fast); }
  .vault-card:hover { border-color: var(--color-primary); }
  .vault-card h3 a { text-decoration: none; color: var(--color-text-heading); }
  .vault-card-persona { color: var(--color-text-muted); font-size: 0.9em; margin: 0.25rem 0; }
  .vault-card-tagline { font-style: italic; color: var(--color-text-muted); margin: 0.5rem 0; }
  /* Storyweave P3 / M3.1: the purpose line — one line, tail-truncated with a real ellipsis.
     The full text stays in the DOM (screen readers read it in full); only the visual is clipped
     at the card edge, so no word is ever hard-cut in the content. Token colour (gate-14). */
  .vault-card-purpose {
    color: var(--color-text);
    font-size: 0.9em;
    margin: 0.4rem 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .vault-card-meta { font-size: 0.8em; margin-top: 0.5rem; }
  .vault-status { padding: 0.1rem 0.4rem; border-radius: var(--radius-full); }
  .status-active { background: color-mix(in srgb, var(--color-success) 15%, transparent); color: color-mix(in srgb, var(--color-success) 55%, var(--color-text)); }
  .status-genesis,
  .status-pending { background: color-mix(in srgb, var(--color-accent) 18%, transparent); color: color-mix(in srgb, var(--color-accent) 45%, var(--color-text)); }
  .status-superseded { background: color-mix(in srgb, var(--color-text-muted) 15%, transparent); color: var(--color-text-muted); }
</style>
