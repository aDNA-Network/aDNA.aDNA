---
import iconLearn from '../../assets/icons/icon_learn.svg?raw';
import iconHow from '../../assets/icons/icon_how.svg?raw';
import iconPatterns from '../../assets/icons/icon_patterns.svg?raw';
import iconReference from '../../assets/icons/icon_reference.svg?raw';
import iconCommunity from '../../assets/icons/icon_community.svg?raw';
import iconUseCases from '../../assets/icons/icon_use_cases.svg?raw';

interface Props {
  pageTitle: string;
}

const { pageTitle } = Astro.props;

type Route = {
  prefix: string;
  leg: 'WHAT' | 'HOW' | 'WHO';
  sectionLabel: string;
  sectionHref: string;
  icon: string;
};

const routes: Route[] = [
  { prefix: '/learn/concepts/', leg: 'WHAT', sectionLabel: 'Concepts', sectionHref: '/learn/concepts/', icon: iconLearn },
  { prefix: '/learn/tutorials/', leg: 'WHAT', sectionLabel: 'Tutorials', sectionHref: '/learn/tutorials/', icon: iconLearn },
  { prefix: '/learn/comparisons/', leg: 'WHAT', sectionLabel: 'Comparisons', sectionHref: '/learn/comparisons/', icon: iconLearn },
  { prefix: '/patterns/', leg: 'WHAT', sectionLabel: 'Patterns', sectionHref: '/patterns/', icon: iconPatterns },
  { prefix: '/glossary/', leg: 'WHAT', sectionLabel: 'Glossary', sectionHref: '/glossary/', icon: iconReference },
  { prefix: '/use-cases/', leg: 'WHAT', sectionLabel: 'Use Cases', sectionHref: '/use-cases/', icon: iconUseCases },
  { prefix: '/reference/', leg: 'WHAT', sectionLabel: 'Reference', sectionHref: '/reference/', icon: iconReference },
  { prefix: '/adopters/', leg: 'WHO', sectionLabel: 'Adopters', sectionHref: '/adopters/', icon: iconUseCases },
  { prefix: '/community/', leg: 'WHO', sectionLabel: 'Community', sectionHref: '/community/', icon: iconCommunity },
  { prefix: '/how/publishing/', leg: 'HOW', sectionLabel: 'Publishing', sectionHref: '/how/publishing/', icon: iconHow },
  { prefix: '/how/workshops/', leg: 'HOW', sectionLabel: 'Workshops', sectionHref: '/how/workshops/', icon: iconHow },
  { prefix: '/how/lattice-examples/', leg: 'HOW', sectionLabel: 'Lattice Examples', sectionHref: '/how/lattice-examples/', icon: iconHow },
];

const path = Astro.url.pathname;

const match = routes.find((r) => {
  const trimmed = r.prefix.replace(/\/$/, '');
  return (path === r.prefix || path.startsWith(r.prefix)) && path !== trimmed && path !== r.prefix;
});
---

{match && (
  <>
    <a href={match.sectionHref} class="back-to-index">
      <span aria-hidden="true">←</span> Back to {match.sectionLabel.toLowerCase()}
    </a>
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <ol>
        <li class="leg">{match.leg}</li>
        <li class="sep" aria-hidden="true">›</li>
        <li class="section-cell">
          <span class="section-icon" aria-hidden="true" set:html={match.icon} />
          <a href={match.sectionHref}>{match.sectionLabel}</a>
        </li>
        <li class="sep" aria-hidden="true">›</li>
        <li aria-current="page" class="current">{pageTitle}</li>
      </ol>
    </nav>
  </>
)}

<style>
  .back-to-index {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-2);
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .back-to-index:hover {
    color: var(--color-text);
    border-bottom-color: currentColor;
  }

  .back-to-index:focus-visible {
    outline: 2px solid var(--brand-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .breadcrumb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .breadcrumb ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .breadcrumb .leg {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .breadcrumb .section-cell {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .breadcrumb .section-icon {
    display: inline-flex;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    color: var(--color-text-muted);
  }

  .breadcrumb .section-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
    border-bottom-color: currentColor;
  }

  .breadcrumb a:focus-visible {
    outline: 2px solid var(--brand-primary);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .breadcrumb .sep {
    color: var(--color-text-muted);
    user-select: none;
  }

  .breadcrumb .current {
    color: var(--color-text);
    font-weight: 500;
  }
</style>
