---
import { navigation, isSubgroup } from '../../utils/navigation';
import type { NavGroup, NavSubgroup, NavItem } from '../../utils/navigation';
import iconLearn from '../../assets/icons/icon_learn.svg?raw';
import iconHow from '../../assets/icons/icon_how.svg?raw';
import iconPatterns from '../../assets/icons/icon_patterns.svg?raw';
import iconReference from '../../assets/icons/icon_reference.svg?raw';
import iconCommunity from '../../assets/icons/icon_community.svg?raw';
import iconUseCases from '../../assets/icons/icon_use_cases.svg?raw';

const currentPath = Astro.url.pathname.replace(/\/$/, '');

const groupIcons: Record<string, string> = {
  'Learn': iconLearn,
  'Use Cases': iconUseCases,
  'Patterns': iconPatterns,
  'Glossary': iconReference,
  'Community': iconCommunity,
  'Guides': iconHow,
  'Reference': iconReference,
  'For you': iconCommunity,
};

// Network-audit H4 + SP-2: every doc page rendered all 7 groups (~100 links). Scope the open tree to
// the section the reader is in; keep every section one click away via a compact switcher at the top.
const under = (href: string) => {
  const h = href.replace(/\/$/, '');
  return currentPath === h || currentPath.startsWith(h + '/');
};
function inGroup(group: NavGroup): boolean {
  return group.items.some((item) =>
    isSubgroup(item)
      ? (item as NavSubgroup).items.some((si: NavItem) => under(si.href))
      : under((item as NavItem).href)
  );
}
function entryHref(group: NavGroup): string {
  const first = group.items[0];
  return isSubgroup(first) ? (first as NavSubgroup).items[0].href : (first as NavItem).href;
}

const activeGroup = navigation.find(inGroup) ?? null;
// SP-2: when the page isn't in any nav section, show NO expanded group rather than dumping the full
// ~100-link tree (the reading-order / nav-serialization defect). The switcher above still puts every
// section one click away.
const shownGroups: NavGroup[] = activeGroup ? [activeGroup] : [];
---

<nav class="sidebar-nav" aria-label="Documentation sections">
  <ul class="section-switcher" aria-label="All sections">
    {navigation.map((group: NavGroup) => (
      <li>
        <a
          href={entryHref(group)}
          class:list={['switcher-link', { active: activeGroup?.label === group.label }]}
          aria-current={activeGroup?.label === group.label ? 'true' : undefined}
        >
          {groupIcons[group.label] && (
            <span class="group-icon" aria-hidden="true" set:html={groupIcons[group.label]} />
          )}
          <span>{group.label}</span>
        </a>
      </li>
    ))}
  </ul>

  {shownGroups.map((group: NavGroup) => (
    <div class="nav-group">
      <p class="group-label">
        {groupIcons[group.label] && (
          <span class="group-icon" aria-hidden="true" set:html={groupIcons[group.label]} />
        )}
        <span>{group.label}</span>
      </p>
      <ul class="group-list">
        {group.items.map((item) => {
          if (isSubgroup(item)) {
            const subgroup = item as NavSubgroup;
            const isOpen = subgroup.items.some(
              (si: NavItem) => currentPath === si.href.replace(/\/$/, '')
            );
            return (
              <li class="subgroup">
                <details open={isOpen}>
                  <summary class="subgroup-label">{subgroup.label}</summary>
                  <ul class="subgroup-list">
                    {subgroup.items.map((si: NavItem) => (
                      <li>
                        <a
                          href={si.href}
                          class:list={['nav-item', { active: currentPath === si.href.replace(/\/$/, '') }]}
                          aria-current={currentPath === si.href.replace(/\/$/, '') ? 'page' : undefined}
                        >
                          {si.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            );
          }
          const navItem = item as NavItem;
          return (
            <li>
              <a
                href={navItem.href}
                class:list={['nav-item', { active: currentPath === navItem.href.replace(/\/$/, '') }]}
                aria-current={currentPath === navItem.href.replace(/\/$/, '') ? 'page' : undefined}
              >
                {navItem.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</nav>

<style>
  .sidebar-nav {
    font-size: var(--text-sm);
  }

  /* Section switcher — all top-level sections, one click away; the active one is expanded below. */
  .section-switcher {
    list-style: none;
    margin: 0 0 var(--space-6);
    padding: 0 0 var(--space-4);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .switcher-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .switcher-link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .switcher-link.active {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .nav-group {
    margin-bottom: var(--space-6);
  }

  .group-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    margin-bottom: var(--space-1);
  }

  .group-icon {
    display: inline-flex;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: var(--color-text-muted);
  }

  .group-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .group-list,
  .subgroup-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .subgroup-list {
    padding-left: var(--space-3);
  }

  .subgroup-label {
    font-weight: 500;
    color: var(--color-text);
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
    list-style: none;
    font-size: var(--text-sm);
  }

  .subgroup-label::-webkit-details-marker {
    display: none;
  }

  .subgroup-label::before {
    content: '▸ ';
    display: inline-block;
    transition: transform var(--transition-fast);
    font-size: 0.7em;
    margin-right: var(--space-1);
  }

  details[open] > .subgroup-label::before {
    transform: rotate(90deg);
  }

  .nav-item {
    display: block;
    padding: var(--space-1) var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-item:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .nav-item.active {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    font-weight: 500;
  }
</style>
