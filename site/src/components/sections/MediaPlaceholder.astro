---
interface Props {
  type: 'gif' | 'diagram' | 'illustration';
  alt: string;
  aspect?: '16/9' | '4/3' | '1/1';
  caption?: string;
}

const { type, alt, aspect = '16/9', caption } = Astro.props;

const icons: Record<string, string> = {
  gif: '▶',
  diagram: '◇',
  illustration: '🖼',
};

const labels: Record<string, string> = {
  gif: 'Animation coming soon',
  diagram: 'Diagram coming soon',
  illustration: 'Illustration coming soon',
};
---

<figure class="media-placeholder-figure">
  <div class="media-placeholder" style={`aspect-ratio: ${aspect}`} data-media={type}>
    <div class="media-placeholder-inner">
      <span class="media-placeholder-icon" aria-hidden="true">{icons[type]}</span>
      <span class="media-placeholder-alt">{alt}</span>
      <span class="media-placeholder-label">{labels[type]}</span>
    </div>
  </div>
  {caption && <figcaption class="media-placeholder-caption">{caption}</figcaption>}
</figure>

<style>
  .media-placeholder-figure {
    margin: var(--space-6) 0;
  }

  .media-placeholder {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 3%, transparent),
      color-mix(in srgb, var(--color-accent) 3%, transparent)
    );
  }

  .media-placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    padding: var(--space-4);
    text-align: center;
  }

  .media-placeholder-icon {
    font-size: var(--text-2xl);
    opacity: 0.4;
  }

  .media-placeholder-alt {
    font-size: var(--text-sm);
    font-weight: 500;
    max-width: 30ch;
  }

  .media-placeholder-label {
    font-size: var(--text-xs);
    font-style: italic;
    opacity: 0.6;
  }

  .media-placeholder-caption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-2);
    font-style: italic;
  }
</style>
