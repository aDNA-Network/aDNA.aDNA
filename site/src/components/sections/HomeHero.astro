---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { STANDARD_LICENSE } from '../../data/standard';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  heroImage: ImageMetadata;
  heroAlt?: string;
  title?: string;
  lead?: string;
  /**
   * Optional second manifesto beat — the "you already do X" reframe (Storyweave J1 / S2).
   * Rendered as a distinct line under the lead; the lead keeps the gate-23 hero phrases
   * verbatim, so the reframe sits AROUND them, never replaces them. Home-only today;
   * omitted by /commons + /network (zero-diff — additive-optional-prop pattern).
   */
  reframe?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  getStartedHref?: string;
  getStartedLabel?: string;
  showGetStarted?: boolean;
  githubHref?: string;
  stats?: Stat[];
  /**
   * Optional proof-of-life beat (Storyweave J3): a calm borrowed-trust line naming the
   * real public-good subnetworks, placed hero-adjacent under the stat strip. `proofNames`
   * come from subnetworks.json (single-source — never hardcoded). `proofHref` +
   * `proofLinkLabel` add one subtle "who's behind this" link to the credibility surface.
   */
  proofLead?: string;
  proofNames?: string[];
  proofHref?: string;
  proofLinkLabel?: string;
  /**
   * Optional pre-rendered "living network" hero graph — the compact connected-component radial
   * emitted by scripts/build_graph_svg.mjs → src/assets/hero_graph.svg, passed as a raw SVG string
   * (Storyweave direction A). HOME-ONLY, additive-optional (the zero-diff pattern, same as `reframe`
   * + the `proof*` beats):
   *   • When SET  → the hero renders the 2-column GRAPH-LED variant: copy LEFT, the graph in a panel
   *     RIGHT, with the pixel-art <Picture> demoted to a dimmed full-bleed ground behind the whole
   *     hero. The above-the-fold then reads as "a real, running network."
   *   • When ABSENT (/network, /commons) → the EXISTING image-led layout renders completely unchanged
   *     (pixel-identical — those surfaces never pass this prop).
   * The static SVG is the no-JS baseline (gate-22 discipline — no `data-chart`); a tiny optional
   * enhancement gently drifts the nodes only when JS is on and reduced-motion is not requested.
   */
  heroGraph?: string;
  /** Small caption under the hero-graph panel (graph-led variant only). */
  heroGraphCaption?: string;
  /**
   * Optional onboarding beats (Storyweave P5 / M5.1a — R2 hero-install + R3 license eyebrow).
   * HOME-ONLY, additive-optional (the zero-diff pattern, same as `reframe` + `heroGraph`):
   *   • installOneLiner → a copy-pill under the CTAs surfacing the clone-and-run command. Pass the
   *     SINGLE SOURCE (install_truth.json `one_liner`) — never a literal; gate-12 covers `/`.
   *   • showLicenseEyebrow → an "Open standard · <license>" eyebrow ABOVE the title, drawn from
   *     standard.ts STANDARD_LICENSE (drift-proof). The `.hero-trust-links` badge is single-sourced
   *     from the same const on every surface, so its render is unchanged.
   * ABSENT (/network, /commons) → the hero renders exactly as before (pixel-identical).
   */
  installOneLiner?: string;
  showLicenseEyebrow?: boolean;
}

const {
  heroImage,
  heroAlt = "A bird's-eye pixel-art map of cozy vault-buildings linked by glowing cyan and purple conduits — the aDNA network sharing context, AI, and DNA",
  title = 'The aDNA Network',
  lead = 'Language and DNA were co-created by everyone before us. The context that powers AI should be too — built, shared, and governed in the open, for the good of all. aDNA is an open standard for organizing project knowledge so both humans and AI agents can navigate it — and the open network where that shared context lives, built on the Lattice Protocol (the open coordination protocol underneath).',
  reframe,
  primaryHref = '/vaults',
  primaryLabel = 'Explore the network',
  secondaryHref = '/reference/specification',
  secondaryLabel = 'Read the standard',
  getStartedHref = '/get-started',
  getStartedLabel = 'Get Started',
  showGetStarted = false,
  githubHref = 'https://github.com/aDNA-Network/aDNA',
  stats = [],
  proofLead,
  proofNames = [],
  proofHref,
  proofLinkLabel,
  heroGraph,
  heroGraphCaption = '15 connected vaults · 14 relationships',
  installOneLiner,
  showLicenseEyebrow = false,
} = Astro.props;

// Home-only graph-led variant is active iff a hero graph was passed (additive-optional prop).
const graphLed = Boolean(heroGraph);

// Storyweave P3 / M3.1 — accessible deep-link twin for the hero graph (mirrors /vaults/graph's
// node-list <nav>): parse the connected vaults' slug + name straight from the SSR SVG string
// (single source of truth) so keyboard/AT/no-JS users can open any hero vault. The SVG (role="img")
// and the decorative canvas (aria-hidden) stay non-interactive to AT; this <nav> is their twin.
const heroNodes = graphLed
  ? [...(heroGraph as string).matchAll(/<g class="node" data-slug="([^"]+)">.*?<text[^>]*>([^<]*)<\/text>/g)]
      .map((m) => ({ slug: m[1], name: m[2].replace(/\.aDNA$/, '') }))
  : [];
---

<section class:list={['hero', 'dark', { 'hero--graph-led': graphLed }]}>
  {graphLed ? (
    <Fragment>
      {/* GRAPH-LED variant (Storyweave direction A, home only): the rebuilt connected graph becomes
          the hero — copy LEFT, graph RIGHT, so the fold reads as "a real, running network." The
          pixel-art asset is demoted to a dimmed full-bleed GROUND behind the whole hero (kept VISIBLE
          + 16:9 + <picture> AVIF/WebP so gate-11 still passes; it grounds the warm register without
          competing with the copy). A scrim over it guarantees AA text contrast (gate-4). */}
      <div class="hero-ground" aria-hidden="true">
        <Picture
          src={heroImage}
          alt={heroAlt}
          widths={[768, 1024, 1408]}
          formats={["avif", "webp"]}
          sizes="100vw"
          class="hero-stage-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-ground-scrim"></div>
      </div>

      <div class="hero-grid">
        <div class="hero-copy">
          {/* R3 license-forward trust (Storyweave M5.1a): a small eyebrow ABOVE the title. Sits
              around `.hero-lead`, never touches it → the gate-23 hero phrases stay verbatim.
              "MIT" is single-sourced from standard.ts STANDARD_LICENSE (drift-proof). */}
          {showLicenseEyebrow && (
            <p class="hero-eyebrow">Open standard · {STANDARD_LICENSE}</p>
          )}
          <h1 class="hero-title hero-title--split">
            {/* Accent "Network" — the second word — while keeping the full accessible title. */}
            <span class="hero-title-lead">The aDNA</span>{' '}
            <span class="hero-title-accent">Network</span>
          </h1>

          <p class="hero-lead">{lead}</p>

          {reframe && <p class="hero-reframe">{reframe}</p>}

          <div class="hero-actions">
            {showGetStarted && (
              <a href={getStartedHref} class="btn btn-primary" data-astro-prefetch>{getStartedLabel}</a>
            )}
            <a href={primaryHref} class:list={['btn', showGetStarted ? 'btn-secondary' : 'btn-primary']} data-astro-prefetch>{primaryLabel}</a>
            <a href={secondaryHref} class="btn btn-secondary" data-astro-prefetch>{secondaryLabel}</a>
          </div>

          {/* R2 hero-level install (Storyweave M5.1a): the clone-and-run one-liner as a copy-pill,
              a tertiary "or start now" affordance under the CTAs (Get Started stays the fuller CTA).
              Command is the SINGLE SOURCE (install_truth.json one_liner) passed from index.astro —
              never hardcoded; gate-12 verifies it verbatim on `/`. Static → CLS-safe. */}
          {installOneLiner && (
            <div class="hero-install">
              <span class="hero-install-prompt" aria-hidden="true">$</span>
              <code class="hero-install-cmd">{installOneLiner}</code>
              <button class="hero-install-copy" type="button" aria-label="Copy install command">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
              </button>
            </div>
          )}

          <div class="hero-trust-links">
            <a href={githubHref} target="_blank" rel="noopener" class="trust-link">Open source on GitHub</a>
            <span class="trust-sep" aria-hidden="true">·</span>
            <span class="trust-link trust-static">{STANDARD_LICENSE}-licensed</span>
            <span class="trust-sep" aria-hidden="true">·</span>
            <a href="/reference/specification" class="trust-link" data-astro-prefetch>built on the Lattice Protocol — the coordination layer, opening progressively</a>
          </div>

          {stats.length > 0 && (
            <div class="trust-strip">
              {stats.map((stat) => (
                <div class="trust-stat">
                  <span class="trust-value">{stat.value}</span>
                  <span class="trust-label">{stat.label}</span>
                </div>
              ))}
            </div>
          )}

          {proofNames.length > 0 && (
            <div class="hero-proof">
              <p class="hero-proof-names">
                {proofLead}{proofLead ? ' ' : ''}<span class="hero-proof-list">{proofNames.join(' · ')}</span>
              </p>
              {proofHref && proofLinkLabel && (
                <a href={proofHref} class="hero-proof-link" data-astro-prefetch>{proofLinkLabel}</a>
              )}
            </div>
          )}
        </div>

        {/* The rebuilt connected graph — the "living network" proof, inlined (no-JS baseline).
            The SSR SVG is the accessible + no-JS floor (role="img" + <title>/<desc>); a decorative
            Canvas "constellation" (aria-hidden) cross-fades in over it when JS is present — the
            Storyweave P1.6 / T2 progressive enhancement. `set:html` needs its own wrapper so it does
            not wipe the sibling <canvas>. */}
        <figure class="hero-graph" data-hero-graph>
          <div class="hero-graph-frame">
            <div class="hero-graph-svg-wrap" set:html={heroGraph} />
            <canvas class="hero-graph-canvas" aria-hidden="true"></canvas>
          </div>
          <figcaption class="hero-graph-caption">{heroGraphCaption}</figcaption>
        </figure>
        {/* Storyweave P3 / M3.1 — the hero graph's keyboard/AT/no-JS deep-link twin. Visually hidden;
            revealed on keyboard focus. Each connected vault opens its own /vaults/[slug] page. */}
        {heroNodes.length > 0 && (
          <nav class="hero-graph-nodelist" aria-label="Open a vault from the network graph">
            <ul>
              {heroNodes.map((n) => (
                <li><a href={`/vaults/${n.slug}/`}>{n.name}</a></li>
              ))}
            </ul>
          </nav>
        )}
      </div>
    </Fragment>
  ) : (
    <Fragment>
      {/* Image-led hero (E1 c146 / SS Ghibli-pixel pivot, ADR-032): the title-image leads
         the fold; the live "The aDNA Network" title is composited as real text over the
         darkened upper band of the image (Space Grotesk Bold + shadow — the cmux treatment),
         NOT baked into the gen. Reverses the c2 `banner_vs_words: DEMOTE`. The image carries
         the new warm register; surrounding chrome keeps v2 tokens until visual-identity-v3
         ratifies. UNCHANGED from before the graph-led variant — /network + /commons render this. */}
      <div class="hero-stage">
        <Picture
          src={heroImage}
          alt={heroAlt}
          widths={[768, 1024, 1408]}
          formats={["avif", "webp"]}
          sizes="(max-width: 980px) calc(100vw - 2rem), 60rem"
          class="hero-stage-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-title-band">
          <h1 class="hero-title">{title}</h1>
        </div>
      </div>

      <p class="hero-lead">{lead}</p>

      {/* Storyweave J1 (S2): the "you already do X" reframe — the manifesto's second beat.
          A separate element so the lead keeps the gate-23 verbatim phrases intact. */}
      {reframe && <p class="hero-reframe">{reframe}</p>}

      {/* Storyweave: the hero carries exactly 1 primary + 1 secondary (tightened from 1+2). Home
         now passes explicit CTAs (primary "Explore the network" → the proof; secondary "Get Started"
         → the build path, also persistent in the header, honoring the network-audit D4 concern), so
         it no longer sets showGetStarted. The showGetStarted 3-button mode is retained for any
         consumer that wants Get-Started-leads; /commons + /network pass their own primary/secondary. */}
      <div class="hero-actions">
        {showGetStarted && (
          <a href={getStartedHref} class="btn btn-primary" data-astro-prefetch>{getStartedLabel}</a>
        )}
        <a href={primaryHref} class:list={['btn', showGetStarted ? 'btn-secondary' : 'btn-primary']} data-astro-prefetch>{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-secondary" data-astro-prefetch>{secondaryLabel}</a>
      </div>

      <div class="hero-trust-links">
        <a href={githubHref} target="_blank" rel="noopener" class="trust-link">Open source on GitHub</a>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-link trust-static">MIT-licensed</span>
        <span class="trust-sep" aria-hidden="true">·</span>
        {/* EV1 (Storyweave): the Lattice Protocol implementation repo is private (404) — never link it,
            and gate-14 forbids the legacy LatticeProtocol-org GitHub literal. Honest fix: link the PUBLIC
            spec/reference and frame the substrate as opening progressively (ties to progressive
            decentralization), rather than a dead-end static tagline. */}
        <a href="/reference/specification" class="trust-link" data-astro-prefetch>built on the Lattice Protocol — the coordination layer, opening progressively</a>
      </div>

      {stats.length > 0 && (
        <div class="trust-strip">
          {stats.map((stat) => (
            <div class="trust-stat">
              <span class="trust-value">{stat.value}</span>
              <span class="trust-label">{stat.label}</span>
            </div>
          ))}
        </div>
      )}

      {/* Storyweave J3 — proof-of-life, hero-adjacent: name the real public-good work as
          borrowed trust (subnetwork names from subnetworks.json, single-source), then offer
          one calm link to the credibility surface. Home-only; zero-diff for other consumers. */}
      {proofNames.length > 0 && (
        <div class="hero-proof">
          <p class="hero-proof-names">
            {proofLead}{proofLead ? ' ' : ''}<span class="hero-proof-list">{proofNames.join(' · ')}</span>
          </p>
          {proofHref && proofLinkLabel && (
            <a href={proofHref} class="hero-proof-link" data-astro-prefetch>{proofLinkLabel}</a>
          )}
        </div>
      )}
    </Fragment>
  )}
</section>

{/* Progressive enhancement (graph-led, home only) — the Storyweave P1.6 / T2 "living network":
    a Canvas constellation drawn OVER the SSR SVG (which stays the no-JS + a11y baseline; the <canvas>
    is aria-hidden decorative). Honors reduced-motion (renders one static frame), only animates while
    on-screen, adapts to the live theme, and adds NO data-chart hook (gate-22). Astro bundles this as a
    deferred module script — non-render-blocking (gate-10), and it inits off the LCP path (idle). */}
{graphLed && (
  <script>
    (() => {
      const fig = document.querySelector('[data-hero-graph]');
      if (!fig) return;
      const frame = fig.querySelector('.hero-graph-frame') as HTMLElement | null;
      const cv = fig.querySelector('canvas.hero-graph-canvas') as HTMLCanvasElement | null;
      const ctx = cv?.getContext('2d');
      if (!frame || !cv || !ctx) return;

      const reduceMQ = window.matchMedia('(prefers-reduced-motion: reduce)');

      // Real connected graph — 15 vaults / 14 relationships (the operator-approved T2 layout).
      // 6th field = the vault_slug for the node's /vaults/[slug] deep-link (Storyweave P3 / M3.1).
      // Slugs are the canonical route ids from vaults.json (some lower-case: sciencestanley/zenzachary/…).
      const N: any[] = [
        ['aDNA.aDNA', 0.00, 0.06, 6, 'core', 'aDNA.aDNA'], ['III.aDNA', -0.40, -0.30, 5, 'hub', 'III.aDNA'], ['Astro.aDNA', 0.42, -0.24, 5, 'hub', 'Astro.aDNA'],
        ['WilhelmAI', 0.04, -0.60, 5, 'org', 'WilhelmAI.aDNA'], ['RareArchive', -0.22, -0.92, 3, 'org', 'RareArchive.aDNA'], ['RareHarness', 0.60, -0.58, 4, 'plat', 'Harness.aDNA'],
        ['Molecules', 0.84, -0.04, 4, 'forge', 'Molecules.aDNA'], ['TappProtocol', 0.96, 0.40, 4, 'plat', 'TappProtocol.aDNA'], ['VAAS', 0.78, 0.80, 3, 'fw', 'VAAS.aDNA'],
        ['Science Stanley', -0.56, 0.40, 5, 'org', 'sciencestanley'], ['Oration', -0.90, 0.18, 3, 'forge', 'Oration.aDNA'], ['VisualDNA', -0.30, 0.66, 4, 'fw', 'visualdna'],
        ['Zen Zachary', -0.74, 0.82, 4, 'org', 'zenzachary'], ['RemoteControl', 0.30, 0.88, 3, 'plat', 'RemoteControl.aDNA'], ['Terminal', 0.56, 1.04, 3, 'plat', 'terminal'],
      ].map(([name, x, y, deg, role, slug]: any, i: number) => ({
        name, x, y, deg, role, slug, i,
        r: role === 'core' ? 15 : deg >= 5 ? 10.5 : deg >= 4 ? 8.5 : 7,
        tw: 0.6 + (i % 5) * 0.13, ph: (i * 1.7) % 6.283, _x: 0, _y: 0,
      }));
      const idx: any = Object.fromEntries(N.map((n: any) => [n.name, n.i]));
      const E: any[] = [
        ['aDNA.aDNA', 'III.aDNA'], ['WilhelmAI', 'Astro.aDNA'], ['WilhelmAI', 'III.aDNA'], ['WilhelmAI', 'RareArchive'],
        ['RareHarness', 'Astro.aDNA'], ['RareHarness', 'III.aDNA'], ['Molecules', 'Astro.aDNA'], ['TappProtocol', 'Molecules'],
        ['TappProtocol', 'VAAS'], ['Science Stanley', 'Oration'], ['Science Stanley', 'VisualDNA'], ['Zen Zachary', 'Science Stanley'],
        ['Zen Zachary', 'VisualDNA'], ['RemoteControl', 'Terminal'],
      ].map(([a, b]: any) => ({ a: idx[a], b: idx[b] }));
      let seed = 1234; const rnd = () => (seed = (seed * 16807) % 2147483647) / 2147483647;
      const SEEDS = Array.from({ length: 24 }, () => { const a = rnd() * 6.283, rr = 1.3 + rnd() * 0.5;
        return { x: Math.cos(a) * rr, y: Math.sin(a) * rr * 0.86, ph: rnd() * 6.283, sp: 0.3 + rnd() * 0.5, r: 1 + rnd() * 1.7 }; });
      const STARS = Array.from({ length: 70 }, () => ({ x: rnd(), y: rnd(), a: 0.05 + rnd() * 0.35, r: rnd() * 1.2 }));

      const PAL: any = {
        dark: { g0: '#1b2740', g1: '#141a2b', g2: '#0b0b12', aura0: 'rgba(125,207,255,0.16)', aura1: 'rgba(157,124,216,0.06)',
          star: '200,215,255', ring: 'rgba(125,207,255,0.06)', seed: '169,200,255',
          e0: 'rgba(125,207,255,0.42)', e1: 'rgba(157,124,216,0.40)', eShadow: 'rgba(125,207,255,0.5)',
          part: 'rgba(210,235,255,0.95)', lab: '#e6f0ff', labSh: 'rgba(10,12,20,0.55)' },
        light: { g0: '#dfe8fb', g1: '#eef2fd', g2: '#f6f8fe', aura0: 'rgba(31,131,201,0.12)', aura1: 'rgba(122,91,192,0.06)',
          star: '90,110,160', ring: 'rgba(31,131,201,0.10)', seed: '90,120,190',
          e0: 'rgba(31,131,201,0.5)', e1: 'rgba(122,91,192,0.48)', eShadow: 'rgba(31,131,201,0.35)',
          part: 'rgba(31,131,201,0.95)', lab: '#1a1b26', labSh: 'rgba(255,255,255,0.6)' },
      };
      // The home hero is dark-first — its <section> always carries `.dark`, so its panel + tokens stay
      // dark regardless of the site's light/dark page theme. The constellation must match the dark panel
      // it sits in, so it always uses the dark palette (reading the page/body theme would mismatch on a
      // light page → a white constellation inside the dark hero). Future light-hero variant → PAL.light.
      const P = (fig as Element).closest('.dark') ? PAL.dark : PAL.light;

      let W = 0, H = 0, dpr = 1, S = 1, CX = 0, CY = 0, hover = -1, staticShown = false;
      const fontFamily = getComputedStyle(fig as Element).fontFamily || 'system-ui, sans-serif';
      const c2 = ctx as CanvasRenderingContext2D;
      const canvas = cv as HTMLCanvasElement;
      const frameEl = frame as HTMLElement;

      function resize() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        const b = frameEl.getBoundingClientRect();
        W = b.width; H = b.height;
        canvas.width = Math.max(1, Math.round(W * dpr));
        canvas.height = Math.max(1, Math.round(H * dpr));
        c2.setTransform(dpr, 0, 0, dpr, 0, 0);
        S = Math.min(W, H) / 2.85; CX = W * 0.5; CY = H * 0.47;
      }
      const px = (n: any) => CX + n.x * S, py = (n: any) => CY + n.y * S;

      canvas.addEventListener('pointermove', (ev) => {
        const b = canvas.getBoundingClientRect();
        const mx = ev.clientX - b.left, my = ev.clientY - b.top;
        let best = -1, bd = 1e9;
        for (const n of N) { const d = Math.hypot(mx - n._x, my - n._y); if (d < bd && d < 26) { bd = d; best = n.i; } }
        hover = best; canvas.style.cursor = best >= 0 ? 'pointer' : 'default';
      });
      canvas.addEventListener('pointerleave', () => { hover = -1; canvas.style.cursor = 'default'; });
      // Storyweave P3 / M3.1 — deep-link the hovered constellation node to its own vault page
      // (was: every node → the generic /vaults). Falls back to /vaults if a slug is ever missing.
      canvas.addEventListener('click', () => {
        if (hover < 0) return;
        const slug = N[hover] && N[hover].slug;
        window.location.href = slug ? `/vaults/${slug}/` : '/vaults';
      });

      function draw(t: number, moving: boolean) {
        const m = moving ? 0.55 : 0;
        c2.clearRect(0, 0, W, H);
        let g = c2.createRadialGradient(CX, CY, 0, CX, CY, S * 2.2);
        g.addColorStop(0, P.g0); g.addColorStop(.35, P.g1); g.addColorStop(1, P.g2);
        c2.fillStyle = g; c2.fillRect(0, 0, W, H);
        g = c2.createRadialGradient(CX, CY, 0, CX, CY, S * 1.35);
        g.addColorStop(0, P.aura0); g.addColorStop(.5, P.aura1); g.addColorStop(1, 'transparent');
        c2.fillStyle = g; c2.fillRect(0, 0, W, H);
        for (const s of STARS) { const a = s.a * (m ? (0.6 + 0.4 * Math.sin(t * 0.001 + s.x * 20)) : 1);
          c2.fillStyle = `rgba(${P.star},${a})`; c2.fillRect(s.x * W, s.y * H, s.r, s.r); }
        c2.strokeStyle = P.ring; c2.lineWidth = 1; c2.setLineDash([2, 7]);
        for (const rr of [0.62, 1.02]) { c2.beginPath(); c2.ellipse(CX, CY, S * rr, S * rr * 0.9, 0, 0, 6.283); c2.stroke(); }
        c2.setLineDash([]);
        for (const s of SEEDS) { const pulse = 0.26 + 0.32 * (0.5 + 0.5 * Math.sin(t * 0.0006 * s.sp + s.ph));
          c2.fillStyle = `rgba(${P.seed},${m ? pulse : 0.3})`;
          c2.beginPath(); c2.arc(CX + s.x * S, CY + s.y * S, s.r, 0, 6.283); c2.fill(); }
        for (const e of E) { const A = N[e.a], B = N[e.b], ax = px(A), ay = py(A), bx = px(B), by = py(B);
          const mx = (ax + bx) / 2, my = (ay + by) / 2, dx = bx - ax, dy = by - ay, d = Math.hypot(dx, dy) || 1;
          const cx = mx - dy / d * d * 0.14, cy = my + dx / d * d * 0.14;
          const lit = hover >= 0 && (e.a === hover || e.b === hover); const dim = hover >= 0 && !lit;
          const grd = c2.createLinearGradient(ax, ay, bx, by);
          grd.addColorStop(0, P.e0); grd.addColorStop(1, P.e1);
