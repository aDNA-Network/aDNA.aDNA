---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  bannerImage: ImageMetadata;
  bannerAlt?: string;
  headline?: string;
  lead?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  githubHref?: string;
  specHref?: string;
  stats?: Stat[];
}

const {
  bannerImage,
  bannerAlt = 'aDNA — retro pixel-art wordmark on a metal plate, set against glowing DNA helices rising from a workspace of laboratory instruments',
  headline = 'Context is our shared inheritance.',
  lead = 'Language and DNA were co-created by everyone before us. The context that powers AI should be too — built, shared, and governed in the open, for the good of all. aDNA is the network where that happens, on the Lattice Protocol.',
  primaryHref = '/vaults',
  primaryLabel = 'Explore the network',
  secondaryHref = '/reference/specification',
  secondaryLabel = 'Read the standard',
  githubHref = 'https://github.com/LatticeProtocol/Agentic-DNA',
  stats = [],
} = Astro.props;
---

<section class="hero dark">
  <h1 class="hero-headline">{headline}</h1>
  <p class="hero-lead">{lead}</p>
  <div class="hero-actions">
    <a href={primaryHref} class="btn btn-primary" data-astro-prefetch>{primaryLabel}</a>
    <a href={secondaryHref} class="btn btn-secondary" data-astro-prefetch>{secondaryLabel}</a>
  </div>
  <div class="hero-trust-links">
    <a href={githubHref} target="_blank" rel="noopener" class="trust-link">Open source on GitHub</a>
    <span class="trust-sep" aria-hidden="true">·</span>
    <span class="trust-link trust-static">MIT · built on the Lattice Protocol</span>
  </div>
  <div class="hero-banner">
    <Picture
      src={bannerImage}
      alt={bannerAlt}
      widths={[480, 768, 964]}
      formats={["avif", "webp"]}
      sizes="(max-width: 768px) calc(100vw - 3rem), 44rem"
      class="hero-banner-img"
      loading="lazy"
    />
  </div>
  {stats.length > 0 && (
    <div class="trust-strip">
      {stats.map((stat) => (
        <div class="trust-stat">
          <span class="trust-value">{stat.value}</span>
          <span class="trust-label">{stat.label}</span>
        </div>
      ))}
    </div>
  )}
</section>

<style>
  /* E1 c3 (brand-system v3 delta): dark-mode-first hero band. The `dark` class on
     the <section> scopes the AA-verified dark tokens (tokens.css / branding.css) to
     this subtree, so the above-fold hero is always dark for the conviction register
     (Hermes/Linear), regardless of page theme — while the body below keeps light/theme
     parity. Documented in reference/visual-identity-v2.mdx §brand-system v3. */
  .hero {
    position: relative;
    isolation: isolate;
    padding: var(--space-16) var(--space-6) var(--space-16);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* One quiet teal signal-glow for depth — surface treatment, not imagery; stays
     within the ≤2-color palette (teal carries signal). */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      62% 55% at 50% 0%,
      color-mix(in srgb, var(--brand-primary) 20%, transparent) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Banner demoted below the manifesto words (E1 c2): words lead the fold;
     the DNA-helix mark supports the 'shared inheritance' theme as a quieter band. */
  .hero-banner {
    max-width: 44rem;
    width: 100%;
    margin: var(--space-10) auto 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 40px color-mix(in srgb, var(--brand-primary) 14%, transparent);
    opacity: 0.9;
  }

  .hero-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    color: var(--color-text-heading);
    max-width: 18ch;
    margin: 0 auto var(--space-4);
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 44rem;
    margin: 0 auto var(--space-6);
    line-height: 1.6;
  }

  .trust-static {
    cursor: default;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-trust-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .trust-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .trust-link:hover {
    color: var(--color-primary);
  }

  .trust-sep {
    color: var(--color-border);
  }

  .trust-strip {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    width: 100%;
    max-width: 36rem;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .trust-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .trust-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-16) var(--space-4) var(--space-12);
    }

    .hero-banner {
      max-width: 100%;
    }

    .trust-strip {
      gap: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-8) var(--space-4) var(--space-8);
    }

    .hero-lead {
      font-size: var(--text-xl);
    }

    .trust-strip {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }
</style>
