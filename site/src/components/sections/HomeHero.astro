---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  heroImage: ImageMetadata;
  heroAlt?: string;
  title?: string;
  lead?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  githubHref?: string;
  stats?: Stat[];
}

const {
  heroImage,
  heroAlt = "A bird's-eye pixel-art map of cozy vault-buildings linked by glowing cyan and purple conduits — the aDNA network sharing context, AI, and DNA",
  title = 'The aDNA Network',
  lead = 'Language and DNA were co-created by everyone before us. The context that powers AI should be too — built, shared, and governed in the open, for the good of all. The open standard and network where that happens, on the Lattice Protocol.',
  primaryHref = '/vaults',
  primaryLabel = 'Explore the network',
  secondaryHref = '/reference/specification',
  secondaryLabel = 'Read the standard',
  githubHref = 'https://github.com/LatticeProtocol/aDNA',
  stats = [],
} = Astro.props;
---

<section class="hero dark">
  {/* Image-led hero (E1 c146 / SS Ghibli-pixel pivot, ADR-032): the title-image leads
     the fold; the live "The aDNA Network" title is composited as real text over the
     darkened upper band of the image (Space Grotesk Bold + shadow — the cmux treatment),
     NOT baked into the gen. Reverses the c2 `banner_vs_words: DEMOTE`. The image carries
     the new warm register; surrounding chrome keeps v2 tokens until visual-identity-v3
     ratifies. */}
  <div class="hero-stage">
    <Picture
      src={heroImage}
      alt={heroAlt}
      widths={[768, 1024, 1408]}
      formats={["avif", "webp"]}
      sizes="(max-width: 980px) calc(100vw - 2rem), 60rem"
      class="hero-stage-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-title-band">
      <h1 class="hero-title">{title}</h1>
    </div>
  </div>

  <p class="hero-lead">{lead}</p>

  <div class="hero-actions">
    <a href={primaryHref} class="btn btn-primary" data-astro-prefetch>{primaryLabel}</a>
    <a href={secondaryHref} class="btn btn-secondary" data-astro-prefetch>{secondaryLabel}</a>
  </div>

  <div class="hero-trust-links">
    <a href={githubHref} target="_blank" rel="noopener" class="trust-link">Open source on GitHub</a>
    <span class="trust-sep" aria-hidden="true">·</span>
    <span class="trust-link trust-static">MIT · built on the Lattice Protocol</span>
  </div>

  {stats.length > 0 && (
    <div class="trust-strip">
      {stats.map((stat) => (
        <div class="trust-stat">
          <span class="trust-value">{stat.value}</span>
          <span class="trust-label">{stat.label}</span>
        </div>
      ))}
    </div>
  )}
</section>

<style>
  /* E1 c3 dark-mode-first hero band (scoped `.dark`) retained; c146 makes it image-led. */
  .hero {
    position: relative;
    isolation: isolate;
    padding: var(--space-12) var(--space-6) var(--space-16);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* Quiet teal signal-glow for depth behind the stage — surface treatment, not imagery. */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      62% 55% at 50% 0%,
      color-mix(in srgb, var(--brand-primary) 18%, transparent) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Title-image stage — leads the fold. The image is the hero; the title is overlaid
     on its darkened upper band. */
  .hero-stage {
    position: relative;
    width: 100%;
    max-width: 60rem;
    margin: 0 auto var(--space-8);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 12px 48px color-mix(in srgb, var(--brand-primary) 16%, transparent);
  }

  .hero-stage-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Title band sits over the (deliberately darkened) upper portion of the image.
     A top-down scrim guarantees AA contrast independent of the asset. */
  .hero-title-band {
    position: absolute;
    inset: 0 0 auto 0;
    display: flex;
    justify-content: center;
    padding: clamp(var(--space-4), 4vw, var(--space-10)) var(--space-4) var(--space-12);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, #1a1b26 78%, transparent) 0%,
      color-mix(in srgb, #1a1b26 40%, transparent) 55%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 7vw, 4.75rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #f7f7fb;
    margin: 0;
    text-wrap: balance;
    /* cmux "shadow finish" — layered drop + soft cyan glow for the pixel-block feel */
    text-shadow:
      0 2px 0 rgba(0, 0, 0, 0.55),
      0 6px 22px rgba(0, 0, 0, 0.5),
      0 0 30px color-mix(in srgb, #7dcfff 38%, transparent);
  }

  .hero-lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 44rem;
    margin: 0 auto var(--space-6);
    line-height: 1.6;
  }

  .trust-static {
    cursor: default;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-trust-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .trust-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .trust-link:hover {
    color: var(--color-primary);
  }

  .trust-sep {
    color: var(--color-border);
  }

  .trust-strip {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    width: 100%;
    max-width: 36rem;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .trust-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .trust-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-10) var(--space-4) var(--space-12);
    }

    .hero-stage {
      max-width: 100%;
    }

    .trust-strip {
      gap: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-8) var(--space-4) var(--space-8);
    }

    .hero-lead {
      font-size: var(--text-base);
    }

    .trust-strip {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }
</style>
