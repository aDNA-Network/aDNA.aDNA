)}

<script>
  // R2 hero-install copy (Storyweave M5.1a) — mirrors TryInClaudeCode's copy pattern. No-op on
  // surfaces without the pill (/network, /commons never render `.hero-install`). Astro-bundled
  // deferred module script → not render-blocking (gate-10). Copies the exact one-liner from the
  // `<code>` textContent (the decorative `$` prompt lives in a separate span, never copied).
  document.querySelectorAll<HTMLButtonElement>('.hero-install-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cmd = btn.closest('.hero-install')?.querySelector('.hero-install-cmd')?.textContent ?? '';
      try {
        await navigator.clipboard.writeText(cmd);
        btn.setAttribute('aria-label', 'Copied!');
        setTimeout(() => btn.setAttribute('aria-label', 'Copy install command'), 2000);
      } catch {
        /* clipboard unavailable (insecure context) — the command stays visible + selectable */
      }
    });
  });
</script>

