---
interface Props {
  chart: string;
  caption?: string;
}

const { chart, caption } = Astro.props;
const diagramId = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="mermaid-figure">
  <div
    class="mermaid-container"
    id={diagramId}
    data-chart={chart}
    role="img"
    aria-label={caption || "Mermaid diagram"}
  >
    <noscript>
      <pre><code>{chart}</code></pre>
    </noscript>
  </div>
  {caption && <figcaption class="mermaid-caption">{caption}</figcaption>}
</figure>

<script>
  // Tokyo-Night (ADR-032) diagram theme — single-sourced from styles/palette.ts so the
  // hex can't drift across components (Storyweave P5 M5.2 / B11). Dark = dark-surface node
  // fills + light text + purple borders + cyan edges; light = brand purple/amber.
  import { mermaidThemeVariables } from '../../styles/palette';

  async function renderMermaid() {
    const containers = document.querySelectorAll('.mermaid-container[data-chart]');
    if (containers.length === 0) return;

    const { default: mermaid } = await import('mermaid');

    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      themeVariables: isDark ? mermaidThemeVariables.dark : mermaidThemeVariables.light,
      fontFamily: "'Space Grotesk', system-ui, sans-serif",
    });

    for (const container of containers) {
      const chart = container.getAttribute('data-chart');
      if (!chart) continue;
      try {
        // Render IN PLACE via run() rather than render()+innerHTML. render() measures labels in a
        // detached element where getBBox() returns 0 in this bundled context → dagre collapses to an
        // empty svg (no viewBox, no nodes). run() lays out inside the attached, visible container.
        container.textContent = chart;
        container.classList.add('mermaid');
        container.removeAttribute('data-chart');
        await mermaid.run({ nodes: [container as HTMLElement] });
        // Mark rendered SVG as presentational — container has the accessible name
        const svgEl = container.querySelector('svg');
        if (svgEl) svgEl.setAttribute('aria-hidden', 'true');
      } catch (e) {
        container.classList.remove('mermaid');
        container.innerHTML = `<pre><code>${chart}</code></pre>`;
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  } else {
    renderMermaid();
  }

  // Re-render on Astro page transitions
  document.addEventListener('astro:page-load', renderMermaid);
</script>

<style>
  .mermaid-figure {
    margin: var(--space-6) 0;
  }

  .mermaid-container {
    display: flex;
    justify-content: center;
    padding: var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow-x: auto;
  }

  .mermaid-container :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-caption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-2);
    font-style: italic;
  }
</style>
