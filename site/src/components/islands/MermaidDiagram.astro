---
interface Props {
  chart: string;
  caption?: string;
}

const { chart, caption } = Astro.props;
const diagramId = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="mermaid-figure">
  <div class="mermaid-container" id={diagramId} data-chart={chart}>
    <noscript>
      <pre><code>{chart}</code></pre>
    </noscript>
  </div>
  {caption && <figcaption class="mermaid-caption">{caption}</figcaption>}
</figure>

<script>
  async function renderMermaid() {
    const containers = document.querySelectorAll('.mermaid-container[data-chart]');
    if (containers.length === 0) return;

    const { default: mermaid } = await import('mermaid');

    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      themeVariables: isDark
        ? {
            primaryColor: '#14919B',
            primaryTextColor: '#f0f0f0',
            primaryBorderColor: '#14919B',
            lineColor: '#5FC4C8',
            secondaryColor: '#F0D060',
            tertiaryColor: '#1a1a1a',
          }
        : {
            primaryColor: '#0D7377',
            primaryTextColor: '#ffffff',
            primaryBorderColor: '#0A4F52',
            lineColor: '#0A4F52',
            secondaryColor: '#D4A017',
            tertiaryColor: '#f5f5f5',
          },
      fontFamily: "'Space Grotesk', system-ui, sans-serif",
    });

    for (const container of containers) {
      const chart = container.getAttribute('data-chart');
      if (!chart) continue;
      try {
        const { svg } = await mermaid.render(`${container.id}-svg`, chart);
        container.innerHTML = svg;
        container.removeAttribute('data-chart');
      } catch (e) {
        container.innerHTML = `<pre><code>${chart}</code></pre>`;
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  } else {
    renderMermaid();
  }

  // Re-render on Astro page transitions
  document.addEventListener('astro:page-load', renderMermaid);
</script>

<style>
  .mermaid-figure {
    margin: var(--space-6) 0;
  }

  .mermaid-container {
    display: flex;
    justify-content: center;
    padding: var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow-x: auto;
  }

  .mermaid-container :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-caption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-2);
    font-style: italic;
  }
</style>
