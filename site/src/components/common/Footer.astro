---
import { PUBLISHER, REPO_HTTPS } from '../../data/canonical';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">aDNA</span>
      <p class="footer-tagline">Give your project a knowledge architecture that both humans and AI agents can navigate.</p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/network">Network</a>
      <a href="/vaults">Vaults</a>
      <a href="/commons">Commons</a>
      <a href="/community">Community</a>
      <a href="/security">Security</a>
      <a href="/reference/specification">Specification</a>
      <a href="/glossary">Glossary</a>
      <a href="/how">Guides</a>
      <a href="/get-started">Get Started</a>
      <a href="/changelog">Changelog</a>
      <a href="/rss.xml">RSS</a>
      <a href={REPO_HTTPS} target="_blank" rel="noopener">GitHub</a>
    </nav>
    <p class="footer-copyright">&copy; {year} {PUBLISHER}. Released under the MIT License.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-text-heading);
  }

  .footer-tagline {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 40ch;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .footer-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-copyright {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }
</style>
