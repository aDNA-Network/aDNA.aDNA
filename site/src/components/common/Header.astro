---
import DarkModeToggle from '../islands/DarkModeToggle.astro';
import { REPO_HTTPS } from '../../data/canonical';
import { topNav } from '../../utils/navigation';

// Storyweave P4 M4.2 — the header renders the single-source topNav model (utils/navigation.ts)
// instead of a hand-maintained array that had drifted from the sidebar. Flat entries render in
// the row; the one "More" entry (with children) renders as a native <details> disclosure that
// surfaces the doc-only sections (Reference / Glossary / Guides / For you) without widening the
// 1024px row. The disclosure sits OUTSIDE .nav-desktop so gate-13's `.nav-desktop a` selector
// stays exactly the flat links (Community is last; Commons stays a flat <a>).
const flatEntries = topNav.filter((e) => e.href);
const moreEntry = topNav.find((e) => e.children);

const currentPath = Astro.url.pathname;
const moreActive = moreEntry?.children?.some((c) => currentPath.startsWith(c.href)) ?? false;
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="aDNA home">
      <span class="logo-mark">a</span><span class="logo-text">DNA</span>
    </a>

    <nav class="nav-desktop-wrap" aria-label="Main navigation">
      <div class="nav-desktop">
        {flatEntries.map(({ label, href }) => (
          <a
            href={href}
            class:list={['nav-link', { active: currentPath.startsWith(href!) }]}
            data-astro-prefetch
          >
            {label}
          </a>
        ))}
      </div>
      {moreEntry && (
        <details class="nav-more">
          <summary class:list={['nav-link', 'nav-more-summary', { active: moreActive }]}>
            {moreEntry.label}
          </summary>
          <div class="nav-more-panel">
            {moreEntry.children!.map(({ label, href }) => (
              <a
                href={href}
                class:list={['nav-link', { active: currentPath.startsWith(href) }]}
                data-astro-prefetch
              >
                {label}
              </a>
            ))}
          </div>
        </details>
      )}
    </nav>

    <div class="header-actions">
      <a href="/get-started" class="btn btn-primary header-cta" data-astro-prefetch>Get Started</a>
      <a
        href={REPO_HTTPS}
        class="github-link"
        aria-label="GitHub repository"
        target="_blank"
        rel="noopener"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
      </a>
      <DarkModeToggle />
      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" aria-label="Mobile navigation" hidden>
    {flatEntries.map(({ label, href }) => (
      <a
        href={href}
        class:list={['nav-link', { active: currentPath.startsWith(href!) }]}
        data-astro-prefetch
      >
        {label}
      </a>
    ))}
    {moreEntry && (
      <>
        <p class="nav-mobile-label">{moreEntry.label}</p>
        {moreEntry.children!.map(({ label, href }) => (
          <a
            href={href}
            class:list={['nav-link', { active: currentPath.startsWith(href) }]}
            data-astro-prefetch
          >
            {label}
          </a>
        ))}
      </>
    )}
  </nav>
</header>

<script>
  const btn = document.querySelector('.mobile-menu-btn');
  const nav = document.querySelector('.nav-mobile');

  function openMenu() {
    btn?.setAttribute('aria-expanded', 'true');
    nav?.removeAttribute('hidden');
    const firstLink = nav?.querySelector('a');
    firstLink?.focus();
  }

  function closeMenu() {
    btn?.setAttribute('aria-expanded', 'false');
    nav?.setAttribute('hidden', '');
    btn?.focus();
  }

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    expanded ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });

  nav?.addEventListener('focusout', (e) => {
    setTimeout(() => {
      if (nav && !nav.contains(document.activeElement) && btn !== document.activeElement) {
        closeMenu();
      }
    }, 0);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    /* space-6 → space-4 at c165: part of the ~100px the 8th nav item (Commons) needed
       to fit the inline row at the 1024px switch-on. */
    gap: var(--space-4);
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-6);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
  }

  .logo-mark {
    color: var(--color-primary);
  }

  .logo-text {
    color: var(--color-text-heading);
  }

  .nav-desktop-wrap {
    display: none;
  }

  .nav-desktop {
    display: flex;
    gap: 2px;
  }

  /* Inline nav appears at >=1024px (E5 c165 — the c158 overflow class, third instance).
     The 8th item ("Commons") pushed the measured row minimum to ~1112px at the old paddings;
     even compressed (nav-link 12→8px, nav gap 4→2px, header gap 24→16px) the row needs
     ~1010px, so the prior 900px switch-on overflowed. Sub-1024 viewports get the hamburger
     (which holds every entry with no overflow); 1024 = the responsive gate's desktop preset,
     and gate-13 asserts the fit at exactly this width. Storyweave P4 M4.2: the flat row is now
     7 links + a compact "More" disclosure (narrower than the prior 8 flat links), so the fit
     only improved and the switch-on is unchanged. */
  @media (min-width: 1024px) {
    .nav-desktop-wrap {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }
    /* Descendant selector on purpose: the .mobile-menu-btn base rule below this media
       query sets display:flex at equal specificity, and later source order wins — the
       burger rendered on EVERY desktop width (pre-existing at HEAD; caught at the c165
       eyeball). The extra class out-specifies it order-independently. */
    .header-actions .mobile-menu-btn {
      display: none;
    }
  }

  /* "More" disclosure (Storyweave P4 M4.2) — surfaces the doc-only sections (Reference,
     Glossary, Guides, For you) that were absent from the header. Native <details>, zero JS
     (the no-JS baseline holds). The panel is position:absolute so it overlays and never widens
     the row (gate-13 fit / gate-9 no-overflow); it sits ABOVE the sticky header (z-index > 40). */
  .nav-more {
    position: relative;
  }

  .nav-more-summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-more-summary::-webkit-details-marker {
    display: none;
  }

  .nav-more-summary::after {
    content: '';
    width: 0.4em;
    height: 0.4em;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-0.15em) rotate(45deg);
    transition: transform var(--transition-fast);
    opacity: 0.7;
  }

  .nav-more[open] .nav-more-summary::after {
    transform: translateY(0.1em) rotate(-135deg);
  }

  .nav-more-panel {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 12rem;
    margin-top: var(--space-1);
    padding: var(--space-2);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    z-index: 41;
  }

  /* Mobile hamburger: label separating the doc-only sections from the flat entries. */
  .nav-mobile-label {
    margin: var(--space-3) 0 0;
    padding: 0 var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .nav-link {
    padding: var(--space-2);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .nav-link.active {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }

  /* Persistent build CTA (network audit D4 — header had no path to building;
     only a footer text link existed). Compact reuse of the global .btn-primary. */
  .header-cta {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
  }

  .github-link {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    /* SP-7 / M-5 (D4 C3): 44px min touch target — the 20px glyph is centred in the box, matching
       the .mobile-menu-btn / dark-mode-toggle pattern. No visual-weight change. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
  }

  .github-link:hover {
    color: var(--color-text);
  }

  .mobile-menu-btn {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: var(--space-2);
    min-height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-mobile {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) var(--space-6) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-mobile .nav-link {
    min-height: 44px;
    display: flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
  }

  .nav-mobile[hidden] {
    display: none;
  }

  /* SP-7 (D4 C3): the two new 44px header targets (github + toggle) widened the actions row by ~42px;
     reclaim it at small-phone widths so the row clears 320px without horizontal overflow (gate-9) —
     tighter side padding + gaps only, no element dropped, desktop (≥1024px) untouched. */
  @media (max-width: 480px) {
    .header-inner {
      gap: var(--space-2);
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }
    .header-actions {
      gap: var(--space-2);
    }
    .header-cta {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }
  }
</style>
