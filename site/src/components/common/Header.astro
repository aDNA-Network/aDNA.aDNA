---
import DarkModeToggle from '../islands/DarkModeToggle.astro';
import { REPO_HTTPS } from '../../data/canonical';

const navLinks = [
  { label: 'Network', href: '/network' },
  { label: 'Vaults', href: '/vaults' },
  { label: 'Commons', href: '/commons' },
  { label: 'Learn', href: '/learn' },
  { label: 'Patterns', href: '/patterns' },
  { label: 'Use Cases', href: '/use-cases' },
  { label: 'Community', href: '/community' },
  { label: 'Reference', href: '/reference' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="aDNA home">
      <span class="logo-mark">a</span><span class="logo-text">DNA</span>
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={['nav-link', { active: currentPath.startsWith(href) }]}
          data-astro-prefetch
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="/get-started" class="btn btn-primary header-cta" data-astro-prefetch>Get Started</a>
      <a
        href={REPO_HTTPS}
        class="github-link"
        aria-label="GitHub repository"
        target="_blank"
        rel="noopener"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
      </a>
      <DarkModeToggle />
      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" aria-label="Mobile navigation" hidden>
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class:list={['nav-link', { active: currentPath.startsWith(href) }]}
        data-astro-prefetch
      >
        {label}
      </a>
    ))}
  </nav>
</header>

<script>
  const btn = document.querySelector('.mobile-menu-btn');
  const nav = document.querySelector('.nav-mobile');

  function openMenu() {
    btn?.setAttribute('aria-expanded', 'true');
    nav?.removeAttribute('hidden');
    const firstLink = nav?.querySelector('a');
    firstLink?.focus();
  }

  function closeMenu() {
    btn?.setAttribute('aria-expanded', 'false');
    nav?.setAttribute('hidden', '');
    btn?.focus();
  }

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    expanded ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });

  nav?.addEventListener('focusout', (e) => {
    setTimeout(() => {
      if (nav && !nav.contains(document.activeElement) && btn !== document.activeElement) {
        closeMenu();
      }
    }, 0);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    /* space-6 → space-4 at c165: part of the ~100px the 8th nav item (Commons) needed
       to fit the inline row at the 1024px switch-on. */
    gap: var(--space-4);
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-3) var(--space-6);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
  }

  .logo-mark {
    color: var(--color-primary);
  }

  .logo-text {
    color: var(--color-text-heading);
  }

  .nav-desktop {
    display: none;
    gap: 2px;
  }

  /* Inline nav appears at >=1024px (E5 c165 — the c158 overflow class, third instance).
     The 8th item ("Commons") pushed the measured row minimum to ~1112px at the old paddings;
     even compressed (nav-link 12→8px, nav gap 4→2px, header gap 24→16px) the row needs
     ~1010px, so the prior 900px switch-on overflowed. Sub-1024 viewports get the hamburger
     (which holds all 8 with no overflow); 1024 = the responsive gate's desktop preset, and
     gate-13 asserts the fit at exactly this width. */
  @media (min-width: 1024px) {
    .nav-desktop {
      display: flex;
    }
    /* Descendant selector on purpose: the .mobile-menu-btn base rule below this media
       query sets display:flex at equal specificity, and later source order wins — the
       burger rendered on EVERY desktop width (pre-existing at HEAD; caught at the c165
       eyeball). The extra class out-specifies it order-independently. */
    .header-actions .mobile-menu-btn {
      display: none;
    }
  }

  .nav-link {
    padding: var(--space-2);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-alt);
  }

  .nav-link.active {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }

  /* Persistent build CTA (network audit D4 — header had no path to building;
     only a footer text link existed). Compact reuse of the global .btn-primary. */
  .header-cta {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
  }

  .github-link {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    /* SP-7 / M-5 (D4 C3): 44px min touch target — the 20px glyph is centred in the box, matching
       the .mobile-menu-btn / dark-mode-toggle pattern. No visual-weight change. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
  }

  .github-link:hover {
    color: var(--color-text);
  }

  .mobile-menu-btn {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: var(--space-2);
    min-height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-mobile {
    display: flex;
    flex-direction: column;
    padding: var(--space-2) var(--space-6) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-mobile .nav-link {
    min-height: 44px;
    display: flex;
    align-items: center;
    padding: var(--space-3) var(--space-4);
  }

  .nav-mobile[hidden] {
    display: none;
  }

  /* SP-7 (D4 C3): the two new 44px header targets (github + toggle) widened the actions row by ~42px;
     reclaim it at small-phone widths so the row clears 320px without horizontal overflow (gate-9) —
     tighter side padding + gaps only, no element dropped, desktop (≥1024px) untouched. */
  @media (max-width: 480px) {
    .header-inner {
      gap: var(--space-2);
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }
    .header-actions {
      gap: var(--space-2);
    }
    .header-cta {
      padding-left: var(--space-3);
      padding-right: var(--space-3);
    }
  }
</style>
