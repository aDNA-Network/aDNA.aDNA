---
type JsonLDValue = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  jsonLD?: JsonLDValue;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalURL = Astro.url.href,
  jsonLD,
  noindex = false,
} = Astro.props;

// Select OG image based on page path if not explicitly provided
function selectOgImage(path: string): string {
  if (path.startsWith('/learn/') || path === '/learn') return '/images/og-learn.png';
  if (path.startsWith('/patterns/') || path === '/patterns') return '/images/og-patterns.png';
  if (path.startsWith('/reference/') || path === '/reference') return '/images/og-reference.png';
  if (path.startsWith('/glossary/') || path === '/glossary') return '/images/og-reference.png';
  if (path.startsWith('/community/') || path === '/community') return '/images/og-community.png';
  if (path.startsWith('/adopters/') || path === '/adopters') return '/images/og-community.png';
  if (path.startsWith('/how/') || path === '/how') return '/images/og-how.png';
  return '/images/og-default.png';
}

const resolvedOgImage = ogImage ?? selectOgImage(Astro.url.pathname);

const fullTitle = title.includes('aDNA') ? title : `${title} — aDNA`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';
const ogImageUrl = resolvedOgImage.startsWith('http') ? resolvedOgImage : `${siteUrl}${resolvedOgImage}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex" />}

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageUrl} />
{/* Storyweave P5 M5.3 O4 — dimensions + alt for the share card. Every OG image is a 1200×630
    card (the 6 `selectOgImage` defaults; no page passes a differently-sized custom `ogImage`),
    so the size is a safe invariant — scrapers lay the card out before fetching, and `og:image:alt`
    gives assistive tech a description of the shared card. If a non-1200×630 custom card is ever
    introduced, these become props. */}
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:site_name" content="aDNA" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={fullTitle} />

<!-- JSON-LD: single schema or @graph bundle for multiple schemas -->
{jsonLD && (Array.isArray(jsonLD)
  ? <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': jsonLD.map(({ '@context': _ctx, ...rest }) => rest),
    })} />
  : <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
)}
