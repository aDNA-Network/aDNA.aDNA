---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  jsonLD?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalURL = Astro.url.href,
  jsonLD,
  noindex = false,
} = Astro.props;

// Select OG image based on page path if not explicitly provided
function selectOgImage(path: string): string {
  if (path.startsWith('/learn/') || path === '/learn') return '/images/og-learn.png';
  if (path.startsWith('/patterns/') || path === '/patterns') return '/images/og-patterns.png';
  if (path.startsWith('/reference/') || path === '/reference') return '/images/og-reference.png';
  if (path.startsWith('/glossary/') || path === '/glossary') return '/images/og-reference.png';
  if (path.startsWith('/community/') || path === '/community') return '/images/og-community.png';
  if (path.startsWith('/adopters/') || path === '/adopters') return '/images/og-community.png';
  return '/images/og-default.png';
}

const resolvedOgImage = ogImage ?? selectOgImage(Astro.url.pathname);

const fullTitle = title.includes('aDNA') ? title : `${title} — aDNA`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';
const ogImageUrl = resolvedOgImage.startsWith('http') ? resolvedOgImage : `${siteUrl}${resolvedOgImage}`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex" />}

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content="aDNA" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- JSON-LD -->
{jsonLD && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
)}
