---
/**
 * TriadDiagram — WHAT / HOW / WHO triad visualization.
 *
 * Canonical aDNA ontology illustration: three legs arranged in a triangle with
 * connecting relationships. Defaults to the standard triad (WHAT / HOW / WHO);
 * labels and taglines are operator-overridable for adaptation (e.g., Knowledge /
 * Operations / People; or domain-specific triads in extension vaults).
 *
 * Pattern lineage:
 *   - Inline SVG directly in template (NOT ?raw import — labels are dynamic).
 *   - currentColor inheritance for theme/dark-mode parity (cycle 106 carry-forward).
 *   - Additive Props extension (cycle 104 carry-forward; all props optional).
 *   - Semantic aria-labelledby (decorative SVG inside; <title> + <desc> provide a11y).
 *   - Stroke 1.6 matches site icon set vocabulary (cycle 103+106 motif).
 */

import type { HTMLAttributes } from 'astro/types';

export interface TriadLeg {
  label: string;
  tagline?: string;
}

interface Props extends HTMLAttributes<'figure'> {
  legs?: [TriadLeg, TriadLeg, TriadLeg];
  caption?: string;
  ariaLabel?: string;
}

const {
  legs = [
    { label: 'WHAT', tagline: 'Knowledge objects' },
    { label: 'HOW',  tagline: 'Operations + sessions' },
    { label: 'WHO',  tagline: 'People + coordination' },
  ],
  caption,
  ariaLabel,
  class: className,
  ...rest
} = Astro.props;

const titleId = `triad-title-${Math.random().toString(36).slice(2, 9)}`;
const descId  = `triad-desc-${Math.random().toString(36).slice(2, 9)}`;

const computedLabel =
  ariaLabel ??
  `Triad diagram: ${legs.map((l) => l.label).join(', ')}.`;
---

<figure
  class:list={['triad-diagram', className]}
  {...rest}
>
  <svg
    viewBox="0 0 320 280"
    role="img"
    aria-labelledby={`${titleId} ${descId}`}
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id={titleId}>{computedLabel}</title>
    <desc id={descId}>
      Three legs arranged in a triangle. {legs[0].label} at the top apex;
      {legs[1].label} at the bottom left; {legs[2].label} at the bottom right.
      Connecting lines indicate that each leg relates to the other two.
    </desc>

    {/* Connecting edges (drawn first so nodes overlay them) */}
    <g class="triad-edges" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round">
      {/* Top apex (160, 56) — bottom-left (72, 200) */}
      <line x1="160" y1="56" x2="72" y2="200" />
      {/* Top apex (160, 56) — bottom-right (248, 200) */}
      <line x1="160" y1="56" x2="248" y2="200" />
      {/* Bottom-left (72, 200) — bottom-right (248, 200) */}
      <line x1="72" y1="200" x2="248" y2="200" />
    </g>

    {/* Nodes — circle backgrounds for label legibility on connectors */}
    <g class="triad-nodes" stroke="currentColor" stroke-width="1.6" fill="var(--color-bg)">
      <circle cx="160" cy="56" r="32" />
      <circle cx="72"  cy="200" r="32" />
      <circle cx="248" cy="200" r="32" />
    </g>

    {/* Labels — inside circles, centered */}
    <g class="triad-labels" fill="currentColor" text-anchor="middle" font-family="var(--font-display, system-ui)" font-weight="600">
      <text x="160" y="62" font-size="14">{legs[0].label}</text>
      <text x="72"  y="206" font-size="14">{legs[1].label}</text>
      <text x="248" y="206" font-size="14">{legs[2].label}</text>
    </g>

    {/* Taglines — under each circle */}
    {legs.some((l) => l.tagline) && (
      <g class="triad-taglines" fill="currentColor" text-anchor="middle" font-family="var(--font-body, system-ui)" font-size="11" opacity="0.75">
        {legs[0].tagline && <text x="160" y="108">{legs[0].tagline}</text>}
        {legs[1].tagline && <text x="72"  y="252">{legs[1].tagline}</text>}
        {legs[2].tagline && <text x="248" y="252">{legs[2].tagline}</text>}
      </g>
    )}
  </svg>

  {caption && <figcaption class="triad-caption">{caption}</figcaption>}
</figure>

<style>
  .triad-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-6) 0;
    color: var(--color-text-muted);
  }

  .triad-diagram svg {
    width: 100%;
    max-width: 320px;
    height: auto;
  }

  .triad-caption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    max-width: 36rem;
  }
</style>
