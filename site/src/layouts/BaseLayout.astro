---
import { ClientRouter } from 'astro:transitions';
import SEOHead from '../components/common/SEOHead.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import interLatinFont from '@fontsource/inter/files/inter-latin-400-normal.woff2';
import spaceGroteskLatinFont from '@fontsource/space-grotesk/files/space-grotesk-latin-400-normal.woff2';
import spaceGroteskLatin700Font from '@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2';

type JsonLDValue = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  jsonLD?: JsonLDValue;
  bodyClass?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  canonicalURL,
  jsonLD,
  bodyClass = '',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="no-js dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Subscribable feed (idea_site_rss_feed / Champollion M4.2) — a cheap
         "actively maintained" signal + the standard watch-mechanism for evaluators. -->
    <link rel="alternate" type="application/rss+xml" title="aDNA — Changelog" href="/rss.xml" />

    <!-- Preload critical above-fold fonts (latin subsets only) -->
    <link rel="preload" href={interLatinFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={spaceGroteskLatinFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={spaceGroteskLatin700Font} as="font" type="font/woff2" crossorigin />

    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      jsonLD={jsonLD}
      noindex={noindex}
    />

    <script is:inline>
      document.documentElement.classList.remove('no-js');
    </script>

    <script is:inline>
      (function () {
        const applyTheme = () => {
          // Dark-first (ADR-032): the Tokyo Night register is the default for every
          // visitor; light is opt-in via the toggle. Dark unless the user chose light.
          const theme = localStorage.getItem('theme');
          const dark = theme !== 'light';
          document.documentElement.classList.toggle('dark', dark);
        };
        applyTheme();
        document.addEventListener('astro:page-load', applyTheme);
        matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyTheme);
      })();
    </script>

    <ClientRouter />
  </head>
  <body class:list={['min-h-screen flex flex-col', bodyClass]}>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
