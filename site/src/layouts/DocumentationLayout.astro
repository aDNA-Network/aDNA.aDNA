---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import SidebarNav from '../components/sections/SidebarNav.astro';
import TOCPanel from '../components/sections/TOCPanel.astro';
import PrevNextNav from '../components/sections/PrevNextNav.astro';
import Breadcrumb from '../components/sections/Breadcrumb.astro';

type JsonLDValue = Record<string, unknown> | Record<string, unknown>[];

interface Props {
  title: string;
  description: string;
  headings?: { depth: number; slug: string; text: string }[];
  prev?: { label: string; href: string };
  next?: { label: string; href: string };
  jsonLD?: JsonLDValue;
  heroImage?: { src: ImageMetadata; alt: string };
}

const { title, description, headings = [], prev, next, jsonLD, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description} jsonLD={jsonLD}>
  <div class="doc-layout">
    <!-- Mobile section nav (audit C3: the sidebar was display:none below 768px, leaving
         doc pages with no section navigation on phones). Native disclosure, zero JS; the
         desktop <aside> below is display:none'd on mobile so only one copy is ever in
         the accessibility tree. -->
    <details class="doc-mobile-nav">
      <summary>In this section</summary>
      <div class="doc-mobile-nav-inner">
        <SidebarNav />
      </div>
    </details>

    <aside class="doc-sidebar" aria-label="Documentation navigation">
      <SidebarNav />
    </aside>

    <article class="doc-content prose">
      <Breadcrumb pageTitle={title} />
      {heroImage && (
        <Image
          src={heroImage.src}
          alt={heroImage.alt}
          class="doc-hero"
          widths={[640, 960, 1280, 1408]}
          sizes="(min-width: 1280px) 880px, (min-width: 768px) calc(100vw - 14rem), 100vw"
          loading="eager"
        />
      )}
      <h1>{title}</h1>
      <slot />
      {(prev || next) && <PrevNextNav prev={prev} next={next} />}
    </article>

    <aside class="doc-toc" aria-label="Table of contents">
      {headings.length > 0 && <TOCPanel headings={headings} />}
    </aside>
  </div>
</BaseLayout>

<script>
  // Wrap bare <pre> elements in .doc-content with a copy button.
  // Skips pre elements already inside .code-block (those are handled by CodeBlock.astro).
  function initCopyButtons() {
    const pres = document.querySelectorAll<HTMLPreElement>('.doc-content pre:not(.code-block pre)');
    pres.forEach((pre) => {
      if (pre.closest('.code-block')) return; // already wrapped

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';

      const inner = document.createElement('div');
      inner.className = 'code-content';

      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(inner);
      inner.appendChild(pre);

      // Scrollable code samples must be keyboard-reachable (axe scrollable-region-focusable —
      // audit P1-S3, /learn/what-is-adna).
      if (!pre.hasAttribute('tabindex')) pre.setAttribute('tabindex', '0');

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.type = 'button';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
      wrapper.appendChild(btn);

      btn.addEventListener('click', async () => {
        const text = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
        await navigator.clipboard.writeText(text);
        btn.setAttribute('aria-label', 'Copied!');
        setTimeout(() => btn.setAttribute('aria-label', 'Copy code'), 2000);
      });
    });
  }

  // Run on initial load and after each client-side navigation
  initCopyButtons();
  document.addEventListener('astro:page-load', initCopyButtons);
</script>

<style>
  .doc-layout {
    display: grid;
    grid-template-columns: 1fr;
    max-width: var(--content-width);
    margin: 0 auto;
    min-height: calc(100vh - 8rem);
  }

  .doc-sidebar {
    display: none;
    position: sticky;
    top: 3.5rem;
    height: calc(100vh - 3.5rem);
    overflow-y: auto;
    padding: var(--space-6) var(--space-4);
    border-right: 1px solid var(--color-border);
  }

  /* ——— Mobile section-nav disclosure (<768px only) ——— */
  .doc-mobile-nav {
    margin: var(--space-4) var(--space-6) 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    /* Page ground, NOT --color-surface: the switcher's purple .active link is AA on the
       page bg (matching the desktop sidebar) but only 3.9:1 on the elevated card surface
       (the E5 c160 purple-on-surface class — axe-caught here at the c165 probe). */
  }

  .doc-mobile-nav > summary {
    list-style: none;
    cursor: pointer;
    min-height: 44px;
    display: flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .doc-mobile-nav > summary::-webkit-details-marker {
    display: none;
  }

  .doc-mobile-nav > summary::before {
    content: '▸ ';
    display: inline-block;
    transition: transform var(--transition-fast);
    font-size: 0.7em;
    margin-right: var(--space-2);
  }

  .doc-mobile-nav[open] > summary::before {
    transform: rotate(90deg);
  }

  .doc-mobile-nav-inner {
    padding: var(--space-2) var(--space-4) var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .doc-content {
    padding: var(--space-8) var(--space-6);
    min-width: 0;
    overflow-x: hidden;
  }

  .doc-content :global(.doc-hero) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-6);
    background: var(--color-bg-alt);
  }

  .doc-toc {
    display: none;
    position: sticky;
    top: 3.5rem;
    height: calc(100vh - 3.5rem);
    overflow-y: auto;
    padding: var(--space-6) var(--space-4);
  }

  /* Tablet: show sidebar, hide the mobile disclosure */
  @media (min-width: 768px) {
    .doc-layout {
      grid-template-columns: var(--sidebar-width) 1fr;
    }

    .doc-sidebar {
      display: block;
    }

    .doc-mobile-nav {
      display: none;
    }
  }

  /* Desktop: show TOC */
  @media (min-width: 1280px) {
    .doc-layout {
      grid-template-columns: var(--sidebar-width) 1fr var(--toc-width);
    }

    .doc-toc {
      display: block;
    }
  }
</style>
