---
import DocumentationLayout from '../layouts/DocumentationLayout.astro';
import { getSortedChangelog } from '../utils/collections';
import { buildWebPageJsonLD } from '../utils/seo';
import { render } from 'astro:content';

const entries = await getSortedChangelog();
const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const jsonLD = buildWebPageJsonLD({
  title: 'Changelog',
  description: 'Version history for the aDNA documentation site — release notes, breaking changes, and improvements by version.',
  url: Astro.url.href,
});
---

<DocumentationLayout
  title="Changelog"
  description="Version history for the aDNA documentation site — release notes, breaking changes, and improvements by version."
  jsonLD={jsonLD}
>
  {rendered.length === 0 ? (
    <p>No changelog entries yet.</p>
  ) : (
    rendered.map(({ entry, Content }) => (
      <article class="changelog-entry">
        <div class="changelog-meta">
          <span class="changelog-version">{entry.data.version}</span>
          <time datetime={entry.data.date.toISOString()}>
            {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {entry.data.breaking && <span class="breaking-badge">Breaking</span>}
        </div>
        <div class="changelog-body prose">
          <Content />
        </div>
      </article>
    ))
  )}
</DocumentationLayout>

<style>
  .changelog-entry {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .changelog-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .changelog-version {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-primary);
  }

  time {
    color: var(--color-text-muted);
  }

  .breaking-badge {
    background: color-mix(in srgb, var(--color-error) 15%, transparent);
    color: var(--color-error);
    padding: 0.1em 0.5em;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
  }
</style>
