---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Picture } from 'astro:assets';
import vaultsData from '../../data/vaults.json';
// E5 c162 (context-graph experience): the deep graph surface gets the network glyph art —
// the same visual language as home/network — so the topology page reads as part of the
// world, not a bare diagram. Class `hero-stage-img` keeps it under gate-11's banner clauses.
import heroVaultsGraph from '../../assets/heroes/hero_vaults_graph.png';
// Vite `?raw` resolves the .mmd at build correctly. The prior fs.readFileSync(path.resolve(__dirname,…))
// missed the file (in the built bundle import.meta.url points at the chunk, not the source) → the graph
// silently fell back to "(no data)". (E4 cycle 154 fix.)
import graphChart from '../../data/vaults_graph.mmd?raw';
// A-06 (Operation Meridian M8): the topology is PRE-RENDERED to a committed static SVG at authoring
// time (scripts/build_graph_svg.mjs → `npm run sync:graph`) and inlined here via Vite `?raw` — zero
// runtime JS, visible with JavaScript disabled, theme-adaptive (edges inherit currentColor; node
// chips keep their self-grounding fills). Replaces the former client-side <MermaidDiagram> island
// render for THIS route only (the island still serves the docs pages). The .mmd is still imported
// above, but only to parse the legend swatch palette (classDefColors) — not to render at runtime.
import graphSvg from '../../assets/vaults_graph.svg?raw';
import { buildCollectionPageJsonLD } from '../../utils/seo';

const chart = (graphChart && graphChart.trim()) ? graphChart : 'flowchart LR\n  empty["(no data)"]';

const edgeCount = (vaultsData as any).edges?.length ?? 0;
const vaultCount = (vaultsData as any).vault_count ?? 0;

// Per-type edge census (E4 c155) — live counts beside each legend row keep the typed taxonomy
// self-honest: the reader sees federation/companion are load-bearing and umbrella/partner are rare,
// rather than inferring five evenly-populated kinds.
const edgeTypeCounts: Record<string, number> = ((vaultsData as any).edges ?? []).reduce(
  (m: Record<string, number>, e: any) => { m[e.type] = (m[e.type] ?? 0) + 1; return m; },
  {} as Record<string, number>,
);
// Vaults with no cited relationship yet — named on the page so the disconnected nodes read as
// honest-sparse-by-design, not as a broken render (E4 c155 — Diagram-Reviewer top finding).
const linkedSlugs = new Set<string>();
for (const e of ((vaultsData as any).edges ?? [])) { linkedSlugs.add(e.source); linkedSlugs.add(e.target); }
const unlinkedCount = ((vaultsData as any).vaults ?? []).filter(
  (v: any) => !linkedSlugs.has(v.vault_slug) && !linkedSlugs.has(v.vault),
).length;

// The 5-edge taxonomy — differentiated by LINE STYLE (Mermaid draws every edge in one colour),
// so the legend mirrors what is actually rendered, not an invented per-type palette.
const legend = [
  { key: 'umbrella', sample: 'thick', meaning: 'an org-vault contains its org-graph / pillar children' },
  { key: 'federation', sample: 'solid', meaning: 'a consumer wrapper depends on the forge / framework it consumes' },
  { key: 'partner', sample: 'circle', meaning: 'a platform ships with its default partner' },
  { key: 'companion', sample: 'dashed', meaning: 'a sibling persona-pair or thematic family' },
  { key: 'supersedes', sample: 'super', meaning: 'a successor replaced its predecessor (lifecycle)' },
];

// Node-colour legend (E4 c158 — Newcomer owned-item finding: the graph renders ~14 vault-class
// fill colours with no key, so the boxes read as an undecoded rainbow). Parse the rendered classDef
// palette straight from the .mmd so the swatches can never drift from what the graph actually draws,
// then census the classes present and label them. Box colour = vault class is the node-clarity bridge.
const classDefColors: Record<string, string> = {};
for (const m of chart.matchAll(/classDef\s+(\w+)\s+fill:(#[0-9a-fA-F]{3,6})/g)) {
  classDefColors[m[1]] = m[2];
}
const classLabels: Record<string, string> = {
  forge: 'Forge', framework: 'Framework', framework_candidate: 'Framework (candidate)',
  platform: 'Platform', org_vault: 'Org-Vault', org_graph: 'Org-Graph', standard_dev: 'Standard',
  network: 'Network', node_operational: 'Node (operational)', coordination: 'Coordination',
  document: 'Document', knowledge_graph: 'Knowledge-graph', tooling: 'Tooling', workspace: 'Workspace',
  tbd_at_p0: 'Genesis stub',
};
const classCensus: Record<string, number> = ((vaultsData as any).vaults ?? []).reduce(
  (m: Record<string, number>, v: any) => { m[v.class] = (m[v.class] ?? 0) + 1; return m; },
  {} as Record<string, number>,
);
const nodeLegend = Object.keys(classCensus)
  .sort((a, b) => classCensus[b] - classCensus[a] || a.localeCompare(b))
  .map((cls) => ({
    cls,
    label: classLabels[cls] ?? cls,
    count: classCensus[cls],
    color: classDefColors['class' + cls.replace(/_/g, '')] ?? '#888888',
  }));

// Node-colour KEY (SP-5/H-5 D4 C3 — Option A restraint, operator decision 2026-06-19): colour no longer
// encodes class — every vault shares one neutral chip — so the old 15-swatch per-class key read as a
// misleading rainbow. The key now explains the ≤2-accent treatment (neutral = a vault · cyan = the
// standard · muted = retired) and class is surfaced as a plain text census below. Swatch colours are
// still parsed from the .mmd classDefs (drift-free) — if the palette changes, this key follows it.
const keyNeutral = classDefColors['classplatform'] ?? '#d3d5db';
const keyStandard = classDefColors['classstandarddev'] ?? '#7dcfff';
const keyRetired = classDefColors['classsuperseded'] ?? '#9ea3ad';
const hasStandard = (classCensus['standard_dev'] ?? 0) > 0;
const hasRetired = (classCensus['superseded'] ?? 0) > 0;

// Client round-trip map (E4 cycle 154): `label` is the Mermaid node text (the vault name, as the .mmd
// renders it), `name` is the friendly display name for the back-link, `slug` routes to /vaults/<slug>/.
const vaultNameMap = ((vaultsData as any).vaults ?? []).map((v: any) => ({
  slug: v.vault_slug, name: v.display_name, label: v.vault,
}));

// H-9 (D4 C5): on phones the wide 40-node SVG scales to ~310px and is illegible, so the keyboard
// node-twin below is promoted to the PRIMARY mobile view. Group the vaults by class (nodeLegend order)
// with the unlinked set last — a structured, legible index of the same vaults + links. ONE DOM list
// serves both the keyboard-twin (desktop) and the mobile-primary roles (no duplicate list for SR users).
const isOrphan = (v: any) => !linkedSlugs.has(v.vault_slug) && !linkedSlugs.has(v.vault);
const toListItem = (v: any) => ({ slug: v.vault_slug, name: v.display_name });
const byName = (a: { name: string }, b: { name: string }) => a.name.localeCompare(b.name);
const allVaultsForList = ((vaultsData as any).vaults ?? []);
const nodeGroups = [
  ...nodeLegend.map((n) => ({
    label: n.label,
    items: allVaultsForList.filter((v: any) => v.class === n.cls && !isOrphan(v)).map(toListItem).sort(byName),
  })),
  { label: 'Not yet linked', items: allVaultsForList.filter(isOrphan).map(toListItem).sort(byName) },
].filter((g) => g.items.length > 0);

// M-3 (D3 agentic-readiness): the topology page emits structured data so agents/crawlers can
// read the network as a described collection, not just a decorative SVG. CollectionPage (reused
// seo.ts builder) — valid JSON-LD; counts derive from vaults.json (read-only; Honor pt19).
const jsonLD = buildCollectionPageJsonLD({
  title: 'The aDNA network — relationship graph',
  description: `The federation topology of the aDNA network: ${vaultCount} vaults, ${edgeCount} real directed relationships (umbrella, federation, partner, companion, supersedes).`,
  url: Astro.url.href,
});
---

<BaseLayout title="The aDNA network — relationship graph" description="The federation topology of the aDNA network: every edge is a real, directed relationship drawn from vault governance — umbrella, federation, partner, companion, supersedes." jsonLD={jsonLD}>
  <main class="vaults-graph">
    <section class="vaults-graph-hero">
      <p class="vault-breadcrumb">
        <a href="/vaults/">&larr; Vaults</a>
        <span class="crumb-sep" aria-hidden="true">·</span>
        <a class="crumb-network" href="/network/">Network</a>
        <a id="graph-back-link" class="graph-back-link" href="/vaults/" hidden>&larr; Back to <span id="graph-back-name"></span></a>
      </p>
      <h1>The network, drawn</h1>
      <p class="lede">
        {vaultCount} vaults, {edgeCount} relationships. Every edge is <strong>real and directed</strong>,
        drawn from each vault&rsquo;s governance — a consumer points at what it is built from, an
        org-vault at the children it contains, a successor at what it replaced. {unlinkedCount} vaults
        carry no cited relationship yet, so they sit unconnected here — that is honest topology, not missing data.
      </p>
      <p class="lede lede-node">
        Each box is a <strong>vault</strong>; an aDNA computer — a <em>node</em> — is a <code>Home.aDNA</code>
        plus the vaults that live on it, with each box naming its class.
        <a href="/network/">New here? Start with what the network is &rarr;</a>
      </p>
      <div class="graph-stage">
        <Picture
          src={heroVaultsGraph}
          alt="A wide pixel-art network scene in Tokyo-Night colours — clusters of small glowing vault-buildings joined by cyan and purple connection lines across a dark landscape"
          widths={[768, 1024, 1408]}
          formats={["avif", "webp"]}
          sizes="(max-width: 980px) calc(100vw - 2rem), 42rem"
          class="hero-stage-img"
          loading="eager"
        />
      </div>
      <p class="lede lede-node">
        This is a <strong>context democracy, drawn</strong>: each project grows its own
        <a href="/learn/concepts/knowledge-graph/">knowledge graph</a>, and the graphs federate into a
        shared commons — narrowing from the whole network to the one vault you need is the
        <a href="/learn/concepts/convergence/">convergence model</a> at work.
      </p>
    </section>

    <section class="graph-legend" aria-label="How to read the graph">
      <h2>How to read it</h2>
      <h3 class="legend-sub">Line style = the kind of relationship</h3>
      <ul class="legend-list">
        {legend.map((l) => (
          <li>
            <span class={`le le-${l.sample}`} aria-hidden="true"></span>
            <span class="le-text"><strong>{l.key}</strong> <span class="le-count">&middot; {edgeTypeCounts[l.key] ?? 0}</span> — {l.meaning}</span>
          </li>
        ))}
      </ul>
      <h3 class="legend-sub">Box colour</h3>
      <ul class="node-key">
        <li>
          <span class="ne-swatch" style={`background:${keyNeutral}`} aria-hidden="true"></span>
          <span class="ne-text">A <strong>vault</strong> — every box shares one fill; its class is named on the box and listed below. The <strong>lines</strong> carry the story.</span>
        </li>
        {hasStandard && (
          <li>
            <span class="ne-swatch" style={`background:${keyStandard}`} aria-hidden="true"></span>
            <span class="ne-text"><code>aDNA.aDNA</code> — <strong>the standard</strong> this network documents.</span>
          </li>
        )}
        {hasRetired && (
          <li>
            <span class="ne-swatch" style={`background:${keyRetired}`} aria-hidden="true"></span>
            <span class="ne-text"><strong>Superseded</strong> — a retired vault, kept for audit.</span>
          </li>
        )}
      </ul>
      <h3 class="legend-sub">Vault classes in view</h3>
      <ul class="class-census">
        {nodeLegend.map((n) => (
          <li class="ne-text">{n.label} <span class="le-count">&middot; {n.count}</span></li>
        ))}
      </ul>
    </section>

    <p class="graph-tip">Open any vault below — or browse them all on the <a href="/vaults/">vault index</a>. Each vault page links back to this graph.</p>

    {/* A-06 pre-rendered topology (M8): the committed SVG carries its own role="img" + <title>/<desc>,
        so the container is a plain styled box (no role/aria-label — the SVG is the labelled image).
        The keyboard/AT navigation twin is the node-list <nav> below; node click-to-open is a pointer
        enhancement wired by the round-trip <script>. No runtime mermaid — renders with JS disabled. */}
    <figure class="mermaid-figure">
      <div class="mermaid-container" set:html={graphSvg}></div>
      <figcaption class="mermaid-caption">The aDNA network — cross-vault federation topology</figcaption>
    </figure>

    {/* Keyboard node-twin (E4 c156): the SVG is decorative (aria-hidden) and its nodes are wired for
        pointer only, so this is the focusable/AT-navigable mirror of the graph — one real anchor per
        node, in the same order the .mmd defines them. Visually hidden; revealed on keyboard focus. */}
    <nav class="graph-node-list visually-hidden" aria-label="Open a vault from the network graph">
      <h2>Vaults in the graph</h2>
      <p class="nodelist-intro">Tap a vault to open it.</p>
      {nodeGroups.map((g) => (
        <div class="nodelist-group">
          <p class="nodelist-group-label">{g.label}</p>
          <ul>
            {g.items.map((v) => (
              <li><a href={`/vaults/${v.slug}/`} data-slug={v.slug}>{v.name}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </main>

  <script type="application/json" id="vault-name-map" set:html={JSON.stringify(vaultNameMap)} is:inline></script>
  <script>
    // Round-trip cross-links (E4 cycle 154 — Network-Legibility item 4, navigability).
    // The graph SVG is decorative (aria-hidden; the container carries the accessible name), so node
    // navigation is a pointer affordance via click handlers on the non-focusable <g> groups — NOT
    // focusable <a> anchors (which would trip axe aria-hidden-focus). The accessible/keyboard path is
    // the /vaults/ index. A `?focus=<slug>` arrival signs the round-trip ("← Back to {vault}" + highlight).
    function initGraphRoundTrip() {
      const container = document.querySelector('.mermaid-container');
      if (!container) return;
      let pairs: { slug: string; name: string; label: string }[] = [];
      try { pairs = JSON.parse(document.getElementById('vault-name-map')?.textContent || '[]'); } catch { /* noop */ }
      // Longest labels first so a short vault name cannot pre-empt a longer node's text.
      const byLabel = pairs.slice().sort((a, b) => b.label.length - a.label.length);

      const focus = new URLSearchParams(location.search).get('focus');
      const focusName = focus ? pairs.find((p) => p.slug === focus)?.name : null;
      if (focus && focusName) {
        const back = document.getElementById('graph-back-link');
        const nameSpan = document.getElementById('graph-back-name');
        if (back && nameSpan) {
          back.setAttribute('href', `/vaults/${focus}/`);
          nameSpan.textContent = focusName;
          back.hidden = false;
        }
      }

      // H-9 (D4 C5): on phones (≤640px) the SVG graph is hidden and the node-list is the primary view —
      // there are no svg <g.node> to wire, so highlight + scroll to the focused vault's LIST row instead
      // and skip the (otherwise 300-try) node poll.
      if (matchMedia('(max-width: 640px)').matches) {
        if (focus) {
          const row = document.querySelector(`.graph-node-list a[data-slug="${focus}"]`);
          if (row) {
            row.classList.add('nodelist-focus');
            row.setAttribute('aria-current', 'true');
            const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
            row.scrollIntoView({ block: 'center', behavior: reduce ? 'auto' : 'smooth' });
          }
        }
        return;
      }

      let tries = 0;
      function wire() {
        // Poll until the NODES exist (not merely the <svg> shell) — the 40-node graph renders the
        // svg element before its node groups are populated, so keying off the svg wired nothing.
        const nodes = container.querySelectorAll('svg g.node');
        if (nodes.length === 0) { if (tries++ < 300) requestAnimationFrame(wire); return; }
        nodes.forEach((node) => {
          const el = node as HTMLElement;
          if (el.dataset.rtWired) return; // idempotent across astro:page-load re-fires
          const text = (node.textContent || '').trim();
          if (!text) return;
          const match = byLabel.find((p) => text.indexOf(p.label) !== -1);
          if (!match) return;
          el.dataset.rtWired = '1';
          el.style.cursor = 'pointer';
          node.addEventListener('click', () => { location.href = `/vaults/${match.slug}/`; });
          if (focus && match.slug === focus) {
            node.classList.add('graph-focus');
            const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
            node.scrollIntoView({ block: 'center', inline: 'center', behavior: reduce ? 'auto' : 'smooth' });
          }
        });
      }
      requestAnimationFrame(wire);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGraphRoundTrip);
    } else {
      initGraphRoundTrip();
    }
    document.addEventListener('astro:page-load', initGraphRoundTrip);
  </script>
</BaseLayout>

<style>
  .vaults-graph { max-width: 100%; padding: var(--space-8, 2rem) 1rem; }
  .vaults-graph-hero { max-width: 72ch; margin: 0 auto var(--space-6, 1.5rem); }
  .vault-breadcrumb { color: var(--color-text-muted); }
  .graph-back-link { margin-left: 1rem; color: var(--color-link); }
  /* Two co-equal parents (registry · narrative), separated — not a two-arrow chain (E4 c158 cul-de-sac
     fix + c159 IA/Newcomer disambiguation). One "←" on the registry; Network is a parallel link. */
  .crumb-network { color: var(--color-link); }
  .crumb-sep { margin: 0 0.6rem; color: var(--color-text-muted); }
  /* Pointer affordance hint — the click target itself is wired client-side. */
  .graph-tip { max-width: 72ch; margin: 0 auto var(--space-4, 1rem); color: var(--color-text-muted); font-size: var(--text-sm, 0.9rem); }
  /* In-text link → underlined (not colour-only) for WCAG link-in-text-block, both modes. */
  .graph-tip a { color: var(--color-link); text-decoration: underline; }

  /* Pre-rendered-SVG figure (A-06 / M8) — these were the MermaidDiagram island's scoped styles;
     brought inline here now that this route inlines the committed SVG instead of the island.
     `color: var(--color-text)` seeds the SVG's edge/cluster `currentColor` (theme-adaptive). */
  .mermaid-figure { margin: var(--space-6) 0; }
  .mermaid-container {
    display: flex;
    justify-content: center;
    padding: var(--space-4);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    overflow-x: auto;
    color: var(--color-text);
  }
  .mermaid-container :global(svg) { max-width: 100%; height: auto; }
  .mermaid-caption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-2);
    font-style: italic;
  }

  /* Focus highlight when arriving via ?focus=<slug>. A single cyan stroke competed with the cyan
     focus EDGE and lost against Mermaid's per-node inline stroke (E4 c155 — IA: the focused node was
     not findable in the 40-node coloured field). The robust cue is a drop-shadow GLOW on the whole
     node group — it reads by shape, survives Mermaid's inline rect styling, and stays within the
     cyan/purple budget — backed by a thicker stroke. Global: the SVG is rendered by the island. */
  :global(.mermaid-container g.graph-focus) {
    filter: drop-shadow(0 0 7px var(--color-link)) drop-shadow(0 0 2px var(--color-link));
  }
  :global(.mermaid-container g.graph-focus rect),
  :global(.mermaid-container g.graph-focus polygon),
  :global(.mermaid-container g.graph-focus path) {
    stroke: var(--color-link) !important;
    stroke-width: 4px !important;
  }

  /* The "Not yet linked" orphan cluster reads as a deliberately PARKED holding area — a muted,
     dashed container border (pending, not active structure; the design-spec "subordinate the
     parked nodes" cue) so the honest-sparse set looks held-by-design, not broken. The vault
     nodes inside keep their full class styling; only the wrapping box is subordinated. The
     deeper layout (Mermaid lays the edgeless set in one wide row) + the graph-render Perf fix
     are paired for the c159 close. (E4 c157.) */
  :global(.mermaid-container .cluster rect) {
    stroke: var(--color-text-muted) !important;
    stroke-dasharray: 6 5;
  }
  .vaults-graph-hero h1 { margin: 0.25rem 0 0.75rem; }
  .lede { color: var(--color-text); line-height: 1.6; }

  /* The glyph band (E5 c162) — compact, text-column width, the hero-stage finish
     (radius + border + signal-glow shadow) so it reads as the same family as the
     home/network heroes without displacing the Mermaid graph as the centerpiece. */
  .graph-stage {
    margin: var(--space-5, 1.25rem) 0;
    border-radius: var(--radius-xl, 1rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--brand-primary, #7aa2f7) 14%, transparent);
  }
  .graph-stage :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }
  /* Node-clarity bridge line (E4 c158 — Newcomer): carries "a node = Home.aDNA + its vaults" onto
     the deep graph surface (where the concept was absent) and links back to the /network explainer. */
  .lede-node { margin-top: 0.85rem; color: var(--color-text-muted); font-size: var(--text-sm, 0.95rem); }
  .lede-node code { font-family: var(--font-mono); }
  .lede-node a { color: var(--color-link); text-decoration: underline; }

  /* ── Typed legend — line STYLE, not colour (mirrors Mermaid's single-colour rendering) ── */
  .graph-legend {
    max-width: 72ch;
    margin: 0 auto var(--space-6, 1.5rem);
    padding: var(--space-4, 1rem) var(--space-5, 1.25rem);
    background: var(--color-bg-alt, var(--color-surface));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 0.5rem);
  }
  .graph-legend h2 { font-size: var(--text-sm, 0.9rem); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 0 0 var(--space-3, 0.75rem); }
  /* Two keys in one legend (E4 c158): line style = relationship, box colour = vault class. */
  .legend-sub { font-size: var(--text-xs, 0.78rem); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; color: var(--color-text-muted); margin: var(--space-4, 1rem) 0 var(--space-2, 0.5rem); }
  .legend-sub:first-of-type { margin-top: 0; }
  .legend-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  /* Node-colour KEY (SP-5/H-5 D4 C3) — a short vertical key explaining the ≤2-accent treatment
     (neutral = a vault · cyan = the standard · muted = retired); swatch fills are parsed from the
     .mmd classDefs so the key can never drift from the rendered boxes. */
  .node-key { list-style: none; margin: 0 0 var(--space-3, 0.75rem); padding: 0; display: grid; gap: 0.5rem; }
  .node-key li { display: flex; align-items: flex-start; gap: 0.6rem; line-height: 1.45; }
  .node-key .ne-swatch { margin-top: 0.2rem; }
  .node-key code { font-family: var(--font-mono); color: var(--color-link); }
  /* Class census — class is read as TEXT now (not colour): a compact wrap of label · count. */
  .class-census { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.3rem 1rem; }
  .class-census li { line-height: 1.4; }
  .ne-swatch { flex: 0 0 auto; width: 0.85rem; height: 0.85rem; border-radius: 3px; border: 1px solid var(--color-border); }
  .ne-text { color: var(--color-text); font-size: var(--text-sm, 0.9rem); }
  .legend-list li { display: flex; align-items: center; gap: 0.75rem; line-height: 1.4; }
  .le-text { color: var(--color-text); }
  .le-text strong { font-family: var(--font-mono); color: var(--color-link); }
  /* Per-type census — muted so the count is a quiet honesty cue, not a competing emphasis. */
  .le-count { font-family: var(--font-mono); color: var(--color-text-muted); }

  /* Line samples drawn with the edge colour Mermaid uses (--color-link). */
  .le {
    flex: 0 0 auto;
    width: 3rem;
    height: 0;
    position: relative;
    border-top: 2px solid var(--color-link);
  }
