---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VaultRelationshipBlock from '../../components/sections/VaultRelationshipBlock.astro';
import vaultsData from '../../data/vaults.json';

export function getStaticPaths() {
  const data = vaultsData as { vaults: any[]; edges: any[] };
  return data.vaults.map(v => ({
    params: { slug: v.vault_slug },
    props: { vault: v, allVaults: data.vaults, allEdges: data.edges },
  }));
}

const { vault, allVaults, allEdges } = Astro.props as { vault: any; allVaults: any[]; allEdges: any[] };
---

<BaseLayout
  title={`${vault.display_name} — ${vault.persona || vault.class}`}
  description={vault.tagline || vault.note || `aDNA vault: ${vault.display_name}`}
>
  <main class="vault-detail">
    <section class="vault-hero">
      <p class="vault-breadcrumb">
        <a href="/vaults/">&larr; The Lattice</a>
        <span class="crumb-sep" aria-hidden="true">·</span>
        <a class="crumb-network" href="/network/">Network</a>
      </p>
      <h1>{vault.display_name}</h1>
      {vault.tagline && <p class="vault-tagline">{vault.tagline}</p>}
      <p class="vault-meta">
        <strong>Persona</strong> {vault.persona || '—'} ·
        <strong>Class</strong> {vault.class} ·
        <strong>Status</strong> {vault.status}
        {vault.current_phase && <> · <strong>Phase</strong> {vault.current_phase}</>}
      </p>
    </section>

    {vault.persona_archetype && (
      <section class="vault-persona">
        <h2>Persona</h2>
        <p>{vault.persona_archetype}</p>
      </section>
    )}

    {vault.headline_mission && (
      <section class="vault-focus">
        <h2>Current focus</h2>
        <p>{vault.headline_mission} <span class={`mission-state state-${vault.headline_mission_state}`}>{vault.headline_mission_state}</span></p>
      </section>
    )}

    <VaultRelationshipBlock vault={vault} allEdges={allEdges} allVaults={allVaults} />

    {vault.headline_adrs && vault.headline_adrs.length > 0 && (
      <section class="vault-adrs">
        <h2>Headline ADRs</h2>
        <ul>
          {vault.headline_adrs.map((adr: string) => <li><code>{adr}</code></li>)}
        </ul>
      </section>
    )}

    {vault.recent_closed && vault.recent_closed.length > 0 && (
      <section class="vault-missions">
        <h2>Recent missions</h2>
        <ul>
          {vault.recent_closed.map((m: string) => <li>{m}</li>)}
        </ul>
      </section>
    )}

    <section class="vault-links">
      <h2>Quick links</h2>
      <ul>
        {vault.github_url && <li><a href={vault.github_url}>GitHub &rarr;</a></li>}
        {vault.docs_site_url && <li><a href={vault.docs_site_url}>Docs site &rarr;</a></li>}
        {vault.canonical_governance && <li>Governance: <code>{vault.canonical_governance}</code></li>}
      </ul>
    </section>

    {vault.note && (
      <section class="vault-note">
        <h2>On the lattice</h2>
        <p>{vault.note}</p>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  /* Tokens, not hardcoded greys — the prior #444/#555/#666 failed AA on the dark-first
     Tokyo-Night background (E4 cycle 150; same bug class as the E1 c148 a11y fixes). */
  .vault-detail { max-width: 80ch; margin: 0 auto; padding: 2rem 1rem; }
  .vault-breadcrumb { color: var(--color-text-muted); }
  /* Two parents: the registry (The Lattice → /vaults) and the narrative (→ /network), so the
     deep vault page is not a one-way cul-de-sac back to the explainer (E4 c158 — IA + Newcomer). */
  .vault-breadcrumb a { color: var(--color-link); }
  /* Two co-equal parents (registry · narrative), separated — not a two-arrow chain that mis-reads as
     one hierarchy (E4 c159 — IA + Newcomer). One "←" on the registry; Network is a parallel link. */
  .vault-breadcrumb .crumb-sep { margin: 0 0.6rem; color: var(--color-text-muted); }
  .vault-tagline { font-size: 1.2rem; font-style: italic; color: var(--color-text-muted); }
  .vault-meta { padding: 0.5rem 0; color: var(--color-text-muted); }
  /* Badges carry light pastel backgrounds in both modes → pin dark text for AA contrast. */
  .mission-state { padding: 0.1rem 0.5rem; border-radius: 0.25rem; font-size: 0.85em; color: #1a1b26; }
  .state-in_progress { background: #fef1d1; }
  .state-completed { background: #b9e4d0; }
  .state-planned { background: #e7e7e7; }
</style>
