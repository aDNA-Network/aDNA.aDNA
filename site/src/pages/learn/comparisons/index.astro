---
import DocumentationLayout from '../../../layouts/DocumentationLayout.astro';
import CardGrid from '../../../components/sections/CardGrid.astro';
import { getDocsBySection } from '../../../utils/collections';

const comparisons = await getDocsBySection('comparisons');
const cards = comparisons.map((doc) => ({
  title: doc.data.doc_title,
  description: doc.data.description,
  href: `/learn/comparisons/${doc.id}`,
}));
---

<DocumentationLayout
  title="Comparisons"
  description="How aDNA compares to PARA, Zettelkasten, Notion, Johnny.Decimal, and plain Markdown."
>
  <p>Honest comparisons between aDNA and other knowledge architectures. Every system has strengths — these pages help you understand when aDNA is the right fit.</p>
  <CardGrid cards={cards} columns={2} />
</DocumentationLayout>
