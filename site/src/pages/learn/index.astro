---
import DocumentationLayout from '../../layouts/DocumentationLayout.astro';
import CardGrid from '../../components/sections/CardGrid.astro';
import { buildCollectionPageJsonLD } from '../../utils/seo';
import heroLearn from '../../assets/heroes/hero_learn.png';

const sections = [
  { title: 'What is aDNA?', description: 'Overview of the aDNA knowledge architecture.', href: '/learn/what-is-adna' },
  { title: 'Concepts', description: '13 core concepts — Triad to FAIR Metadata.', href: '/learn/concepts' },
  { title: 'Tutorials', description: '9 step-by-step guides, beginner to advanced.', href: '/learn/tutorials' },
  { title: 'Comparisons', description: 'aDNA vs. PARA, Zettelkasten, Notion, and more.', href: '/learn/comparisons' },
];

const jsonLD = buildCollectionPageJsonLD({
  title: 'Learn aDNA',
  description: 'Learn the aDNA knowledge architecture through concepts, tutorials, and comparisons.',
  url: Astro.url.href,
});
---

<DocumentationLayout
  title="Learn aDNA"
  description="Learn the aDNA knowledge architecture through concepts, tutorials, and comparisons."
  jsonLD={jsonLD}
  heroImage={{ src: heroLearn, alt: 'Cozy pixel-art study desk with books, a notebook, and a glowing DNA helix rising from the page — learning aDNA' }}
>
  <p>Start with the overview, dive into concepts, follow hands-on tutorials, or compare aDNA to systems you already know.</p>
  <CardGrid cards={sections} columns={2} />
</DocumentationLayout>
