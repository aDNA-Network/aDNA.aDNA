---
import { getCollection, render } from 'astro:content';
import DocumentationLayout from '../../../layouts/DocumentationLayout.astro';
import TryInClaudeCode from '../../../components/sections/TryInClaudeCode.astro';
import { buildHowToJsonLD, buildBreadcrumbListJsonLD } from '../../../utils/seo';
import '../../../styles/tutorial-meta.css';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

const timeMatch = guide.data.estimated_time?.match(/(\d+)\s*min/)?.[1];
const totalTime = timeMatch ? `PT${timeMatch}M` : undefined;

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';

const jsonLD = [
  buildHowToJsonLD({
    title: guide.data.guide_title,
    description: guide.data.description ?? '',
    url: Astro.url.href,
    totalTime,
  }),
  buildBreadcrumbListJsonLD([
    { name: 'Home', url: `${siteBase}/` },
    { name: 'Learn', url: `${siteBase}/learn/` },
    { name: 'Tutorials', url: `${siteBase}/learn/tutorials/` },
    { name: guide.data.guide_title },
  ]),
];
---

<DocumentationLayout
  title={guide.data.guide_title}
  description={guide.data.description ?? `Learn how to ${guide.data.guide_title.toLowerCase()}.`}
  headings={headings}
  jsonLD={jsonLD}
>
  <div class="guide-meta">
    <span class:list={['difficulty-badge', guide.data.difficulty]}>{guide.data.difficulty}</span>
    <span class="estimated-time">{guide.data.estimated_time}</span>
  </div>
  <Content />
  <TryInClaudeCode tutorialTitle={guide.data.guide_title} />
</DocumentationLayout>
