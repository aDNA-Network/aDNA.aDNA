---
import { getCollection, render } from 'astro:content';
import DocumentationLayout from '../../../layouts/DocumentationLayout.astro';
import TryInClaudeCode from '../../../components/sections/TryInClaudeCode.astro';
import { buildHowToJsonLD, buildBreadcrumbListJsonLD } from '../../../utils/seo';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

// Convert "15 min" → "PT15M" for schema.org totalTime
const totalTime = guide.data.estimated_time?.match(/(\d+)\s*min/)?.[1]
  ? `PT${guide.data.estimated_time.match(/(\d+)\s*min/)![1]}M`
  : undefined;

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';

const jsonLD = [
  buildHowToJsonLD({
    title: guide.data.guide_title,
    description: guide.data.description ?? '',
    url: Astro.url.href,
    totalTime,
  }),
  buildBreadcrumbListJsonLD([
    { name: 'Home', url: `${siteBase}/` },
    { name: 'Learn', url: `${siteBase}/learn/` },
    { name: 'Tutorials', url: `${siteBase}/learn/tutorials/` },
    { name: guide.data.guide_title },
  ]),
];
---

<DocumentationLayout
  title={guide.data.guide_title}
  description={guide.data.description ?? `Learn how to ${guide.data.guide_title.toLowerCase()}.`}
  headings={headings}
  jsonLD={jsonLD}
>
  <div class="guide-meta">
    <span class:list={['difficulty-badge', guide.data.difficulty]}>{guide.data.difficulty}</span>
    <span class="estimated-time">{guide.data.estimated_time}</span>
  </div>
  <Content />
  <TryInClaudeCode tutorialTitle={guide.data.guide_title} />
</DocumentationLayout>

<style>
  .guide-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .difficulty-badge {
    padding: 0.15em 0.6em;
    border-radius: var(--radius-full);
    font-weight: 500;
    text-transform: capitalize;
  }

  .difficulty-badge.beginner {
    background: color-mix(in srgb, var(--color-success) 15%, transparent);
    color: hsl(142 72% 28%); /* darker green for WCAG AA contrast (5.4:1) */
  }

  .difficulty-badge.intermediate {
    background: color-mix(in srgb, var(--color-info) 15%, transparent);
    color: hsl(217 91% 35%); /* darker blue for WCAG AA contrast */
  }

  .difficulty-badge.advanced {
    background: color-mix(in srgb, var(--color-warning) 15%, transparent);
    color: hsl(25 95% 35%); /* darker orange for WCAG AA contrast */
  }

  /* Dark mode: lighten badge text for contrast on dark color-mix backgrounds */
  :global(.dark) .difficulty-badge.beginner {
    color: #34C06E; /* 5.85:1 on dark green bg */
  }

  :global(.dark) .difficulty-badge.intermediate {
    color: #5CB8E8; /* 6.53:1 on dark blue bg */
  }

  :global(.dark) .difficulty-badge.advanced {
    color: #E89545; /* 5.83:1 on dark orange bg */
  }

  .estimated-time {
    color: var(--color-text-muted);
  }
</style>
