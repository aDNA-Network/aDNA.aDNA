---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWebSiteJsonLD } from '../utils/seo';
import bannerImage from '../assets/banner.jpg';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';
const jsonLD = buildWebSiteJsonLD(siteUrl);

const steps = [
  {
    number: '01',
    title: 'Structure',
    description: 'Every agent session starts from scratch — agents relearn your project by rummaging through files. aDNA ends that. Three directories (what you know, how you work, who\'s involved) give any agent instant orientation.',
    demo: `<div class="step-demo">
  <div class="step-demo-bar">
    <span class="demo-dots"><span></span><span></span><span></span></span>
    <span class="demo-filename">project/</span>
  </div>
  <pre class="step-demo-pre">my-project/
├── CLAUDE.md       ← agent master context
├── what/           ← what the project knows
│   └── context/      typed context files
├── how/            ← how it operates
│   └── missions/     decomposed work plans
└── who/            ← who&#39;s involved
    └── governance/   roles &amp; rules</pre>
</div>`,
  },
  {
    number: '02',
    title: 'Orient',
    description: 'Without a map, agents blast through irrelevant files or ask you to re-explain the project. Agents read your CLAUDE.md and AGENTS.md first, then pull typed context at exactly the depth they need — not your entire repo, not a blank slate.',
    demo: `<div class="step-demo">
  <div class="step-demo-bar">
    <span class="demo-dots"><span></span><span></span><span></span></span>
    <span class="demo-filename">CLAUDE.md</span>
  </div>
  <pre class="step-demo-pre"># CLAUDE.md — climate-pipeline

You are working on climate-pipeline.
A data pipeline for surface temperature
records (1990–present).

## Priority Rules
1. Never overwrite raw sensor data
2. All outputs need uncertainty ranges
3. Ingestion changes need peer review</pre>
</div>`,
  },
  {
    number: '03',
    title: 'Execute',
    description: 'Context windows close and wipe progress — the next agent starts over. aDNA decomposes work into sessions, missions, and campaigns — context-sized chunks that fit a single agent window. What one agent learns, the next inherits.',
    demo: `<div class="step-demo">
  <div class="step-demo-bar">
    <span class="demo-dots"><span></span><span></span><span></span></span>
    <span class="demo-filename">mission_schema_v2.md</span>
  </div>
  <pre class="step-demo-pre">plan_id: mission_schema_v2
status: active

## Objective 1 — Migrate schema
- Status: ✓ complete
- Files: data/schema.py

## Objective 2 — Backfill validation
- Status: in_progress
- Depends on: [1]</pre>
</div>`,
  },
];

const personas = [
  {
    title: 'Solo Developer',
    summary: 'Freelancers and indie hackers using aDNA as a personal knowledge backbone.',
    href: '/use-cases/solo-developer',
  },
  {
    title: 'Enterprise Team',
    summary: 'Cross-functional teams embedding aDNA into existing codebases and workflows.',
    href: '/use-cases/enterprise-team',
  },
  {
    title: 'Educator',
    summary: 'Teachers and professors structuring course materials for student-agent collaboration.',
    href: '/use-cases/educator',
  },
  {
    title: 'Startup',
    summary: 'Fast-moving teams using aDNA to preserve institutional knowledge as they scale.',
    href: '/use-cases/startup',
  },
  {
    title: 'Researcher',
    summary: 'Labs and research groups tracking protocols, datasets, and experiments.',
    href: '/use-cases/research-lab',
  },
];

const stats = [
  { value: '14', label: 'Entity Types' },
  { value: '3', label: 'Conformance Levels' },
  { value: 'v2.2', label: 'Current Version' },
  { value: 'MIT', label: 'Licensed' },
];
---

<BaseLayout
  title="aDNA — An Integrated Standard for Context and Knowledge"
  description="An open standard that structures your project's context and knowledge so both humans and AI agents can navigate it."
  jsonLD={jsonLD}
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-banner">
      <Picture
        src={bannerImage}
        alt="aDNA — three glowing DNA helices representing the who/what/how triad, rising from a workspace of monitors and instruments"
        widths={[480, 768, 964]}
        formats={["avif", "webp"]}
        sizes="(max-width: 768px) calc(100vw - 3rem), 56rem"
        class="hero-banner-img"
        loading="eager"
      />
    </div>
    <p class="hero-problem">AI agents re-read your whole project every session — wasting tokens, losing decisions, rebuilding context that already existed.</p>
    <p class="hero-lead">aDNA is the genome of your project (a structured, persistent context layer) — knowledge every AI agent can navigate without being re-briefed from scratch.</p>
    <p class="hero-subtitle">An open standard: a folder layout, metadata spec, and governance files so agents land oriented every session.</p>
    <div class="hero-actions">
      <a href="/get-started" class="btn btn-primary" data-astro-prefetch>Get Started</a>
      <a href="/learn/what-is-adna" class="btn btn-secondary" data-astro-prefetch>What is aDNA?</a>
    </div>
    <div class="hero-trust-links">
      <a href="https://github.com/LatticeProtocol/Agentic-DNA" target="_blank" rel="noopener" class="trust-link">View on GitHub</a>
      <span class="trust-sep" aria-hidden="true">·</span>
      <a href="/reference/specification" class="trust-link" data-astro-prefetch>Read the Specification</a>
    </div>
    <div class="trust-strip">
      {stats.map((stat) => (
        <div class="trust-stat">
          <span class="trust-value">{stat.value}</span>
          <span class="trust-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- How it Works -->
  <section class="how-it-works">
    <div class="section-inner">
      <h2 class="section-title">How it Works</h2>
      <p class="section-subtitle">Three steps from scattered files to a project your agents can navigate — and keep navigating.</p>
      <div class="feature-strip">
        <div class="feature-item">
          <strong>Agent-native</strong>
          <span>Governance files and typed context give agents orientation — no prompt re-engineering every session.</span>
        </div>
        <div class="feature-item">
          <strong>Human-readable</strong>
          <span>Every file is plain Markdown. Browse in Obsidian, VS Code, or GitHub. No proprietary formats, no lock-in.</span>
        </div>
        <div class="feature-item">
          <strong>Composable</strong>
          <span>Modules, datasets, and lattices compose into workflows. Start small, scale to multi-team campaigns with the same primitives.</span>
        </div>
      </div>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step">
            <div class="step-number">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
            <Fragment set:html={step.demo} />
          </div>
        ))}
      </div>
      <p class="how-footer">
        Dive deeper: <a href="/learn/concepts/convergence">Convergence Model</a> · <a href="/learn">Concepts &amp; Tutorials</a> · <a href="/reference">Reference Specification</a>
      </p>
    </div>
  </section>

  <!-- Who Uses aDNA -->
  <section class="who-uses">
    <div class="section-inner">
      <h2 class="section-title">Who Uses aDNA</h2>
      <p class="section-subtitle">From solo developers to enterprise teams — aDNA scales with your project.</p>
      <div class="persona-grid">
        {personas.map((persona) => (
          <a href={persona.href} class="persona-card">
            <h3 class="persona-title">{persona.title}</h3>
            <p class="persona-summary">{persona.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- The Standard -->
  <section class="the-standard">
    <div class="section-inner">
      <h2 class="section-title">The Standard</h2>
      <p class="section-subtitle">aDNA is an open specification — MIT licensed, community-driven, designed for extension.</p>
      <div class="standard-meta">
        <span class="meta-tag">v2.2</span>
        <span class="meta-tag">MIT License</span>
        <span class="meta-tag">Open Standard</span>
        <span class="meta-tag">14 Entity Types</span>
      </div>
      <div class="standard-cta">
        <a href="/reference/specification" class="btn btn-primary" data-astro-prefetch>Read the Specification</a>
        <a href="https://github.com/LatticeProtocol/Agentic-DNA" class="btn btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ——— Hero ——— */
  .hero {
    padding: var(--space-12) var(--space-6) var(--space-16);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-banner {
    max-width: 56rem;
    width: 100%;
    margin: 0 auto var(--space-8);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .hero-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-problem {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin: 0 auto var(--space-5);
    line-height: 1.5;
  }

  .hero-lead {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text-heading);
    max-width: 42rem;
    margin: 0 auto var(--space-4);
    line-height: 1.35;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    line-height: 1.4;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-trust-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
  }

  .trust-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .trust-link:hover {
    color: var(--color-primary);
  }

  .trust-sep {
    color: var(--color-border);
  }

  .trust-strip {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    width: 100%;
    max-width: 36rem;
  }

  .trust-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .trust-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .trust-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-lg);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  :global(.dark) .btn-primary {
    background: var(--brand-primary);
  }

  :global(.dark) .btn-primary:hover {
    background: var(--brand-primary-dark);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: var(--color-surface);
  }

  .btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* ——— Shared section styles ——— */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-title {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 36rem;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  /* ——— How it Works ——— */
  .how-it-works {
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
    overflow-x: hidden;
  }

  .feature-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-12);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-primary);
  }

  .feature-item strong {
    font-size: var(--text-base);
    color: var(--color-text-heading);
  }

  .feature-item span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }

  .step {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    min-width: 0;
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .step-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .step-description {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .step-demo {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #13131f;
    width: 100%;
    box-sizing: border-box;
  }

  .step-demo-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: #1c1c2e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .demo-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .demo-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .demo-dots span:nth-child(1) { background: #ff5f57; }
  .demo-dots span:nth-child(2) { background: #febc2e; }
  .demo-dots span:nth-child(3) { background: #28c840; }

  .demo-filename {
    color: #aaa;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.01em;
  }

  .step-demo-pre {
    margin: 0;
    padding: var(--space-4);
    color: #c9c9df;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.65;
    white-space: pre;
    overflow-x: auto;
    max-width: 100%;
    box-sizing: border-box;
  }

  .how-footer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-10);
    line-height: 1.6;
  }

  .how-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .how-footer a:hover {
    text-decoration: underline;
  }

  /* ——— Who Uses aDNA ——— */
  .who-uses {
    padding: var(--space-24) 0;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .persona-card {
    display: block;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .persona-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .persona-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
  }

  .persona-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ——— The Standard ——— */
  .the-standard {
    padding: var(--space-24) 0 var(--space-32);
    background: var(--color-bg-alt);
  }

  .standard-meta {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25em 0.75em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-surface);
    letter-spacing: 0.03em;
  }

  .standard-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— Touch device tap feedback (no-hover devices) ——— */
  @media (hover: none) and (pointer: coarse) {
    .persona-card:active {
      transform: scale(0.98);
      box-shadow: var(--shadow-sm);
      transition: transform 80ms ease, box-shadow 80ms ease;
    }

    .btn:active {
      opacity: 0.85;
      transition: opacity 80ms ease;
    }
  }

  /* ——— Responsive ——— */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-16) var(--space-4) var(--space-12);
    }

    .hero-banner {
      max-width: 100%;
    }

    .trust-strip {
      gap: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-8) var(--space-4) var(--space-8);
    }

    .hero-lead {
      font-size: var(--text-xl);
    }

    .hero-subtitle {
      font-size: var(--text-base);
    }

    .trust-strip {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }

    .section-title {
      font-size: var(--text-2xl);
    }

    .section-subtitle {
      font-size: var(--text-base);
      margin-bottom: var(--space-6);
    }

    .how-it-works {
      padding: var(--space-12) 0;
    }

    .who-uses {
      padding: var(--space-12) 0;
    }

    .the-standard {
      padding: var(--space-12) 0 var(--space-16);
    }

    .steps-grid {
      gap: var(--space-6);
    }

    .feature-strip {
      margin-bottom: var(--space-8);
    }

    .how-footer {
      margin-top: var(--space-6);
    }
  }
</style>
