---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/sections/HomeHero.astro';
import NetworkDiagram from '../components/sections/NetworkDiagram.astro';
import RegistryCard from '../components/sections/RegistryCard.astro';
import { buildWebSiteJsonLD } from '../utils/seo';
import { steps, stats, audiences } from '../data/home';
import { STANDARD_VERSION, ENTITY_TYPE_COUNT } from '../data/standard';
import vaultsData from '../data/vaults.json';
import subnetworksData from '../data/subnetworks.json';
import heroImage from '../assets/heroes/hero_adna_helix.png';
// Storyweave direction A — the "living network" hero graph: the compact connected-component radial
// pre-rendered by scripts/build_graph_svg.mjs (npm run sync:graph) → committed static SVG, imported
// raw and inlined by HomeHero as the graph-led hero. HOME-ONLY (the additive-optional `heroGraph`
// prop; /network + /commons don't pass it → they keep the image-led hero, zero-diff).
import heroGraph from '../assets/hero_graph.svg?raw';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.network';
const jsonLD = buildWebSiteJsonLD(siteUrl);

// Section 2 — a curated slice across the network's classes (real data/vaults.json
// records), including two public-good org vaults (WGA, Rare Archive) to thread the
// ethos by what is shown. "See all" routes to the full /vaults registry.
const REGISTRY_SLUGS = [
  'aDNA.aDNA', 'III.aDNA', 'canvas', 'Operations.aDNA',
  'LAVentureGraph.aDNA', 'Home.aDNA', 'wga.aDNA', 'RareArchive.aDNA',
];
const bySlug: Record<string, any> = Object.fromEntries(
  (vaultsData.vaults as any[]).map((v) => [v.vault_slug, v])
);
const registryVaults = REGISTRY_SLUGS.map((s) => bySlug[s]).filter(Boolean);
const vaultCount = vaultsData.vault_count;

// Section 5 — the featured public-good subnetworks, teased data-driven from the
// subnetworks.json fixture (names/taglines single-sourced, never hardcoded — the
// E1-deferred §5 tease now hands off to the live /commons surface; E5 c165).
const subnetworks = subnetworksData.subnetworks as Array<{
  id: string;
  display_name: string;
  tagline: string;
}>;

const CLASS_LABELS: Record<string, string> = {
  standard_dev: 'the standard',
  framework: 'framework',
  framework_candidate: 'framework',
  forge: 'forge',
  platform: 'platform',
  org_vault: 'org vault',
  org_graph: 'org graph',
  network: 'network',
  node_operational: 'node',
  coordination: 'coordination',
  document: 'document',
  knowledge_graph: 'knowledge graph',
  tooling: 'tooling',
  workspace: 'workspace',
};
const classLabel = (c: string) => CLASS_LABELS[c] ?? c.replace(/_/g, ' ');
---

<BaseLayout
  title="aDNA — the open standard & network for shared context"
  description="The open standard and network to build, share, and govern the context that powers AI — in the open, for the good of all. Built on the Lattice Protocol."
  jsonLD={jsonLD}
>
  <HomeHero
    heroImage={heroImage}
    heroAlt="A pixel-art hero in the Tokyo Night palette: a glowing cyan DNA double-helix rising from a row of small computers and branching at the top into a network of connected nodes — shared inheritance resolving into the aDNA network."
    reframe="Your context is just the notes, docs, and decisions you already keep — now shaped into a graph your agents can navigate, and shared in the open."
    primaryHref="/vaults"
    primaryLabel="Explore the network"
    secondaryHref="/get-started"
    secondaryLabel="Get Started"
    proofLead="Real public-good work already lives here —"
    proofNames={subnetworks.map((s) => s.display_name)}
    proofHref="/about"
    proofLinkLabel="Who's behind aDNA →"
    stats={stats}
    heroGraph={heroGraph}
    heroGraphCaption="15 connected vaults · 14 relationships"
  />

  <!-- 1 · What a context democracy is -->
  <section class="context-democracy">
    <div class="section-inner">
      <h2 class="section-title">What a context democracy is</h2>
      <p class="section-subtitle">
        A self-governed network where people and their agents build, share, and govern
        context graphs in the open — each project its own graph, all of them federating
        into a shared commons.
      </p>
      <NetworkDiagram />
      <p class="diagram-caption">
        Real aDNA vaults — forges, frameworks, platforms, and public-good archives —
        federating on the Lattice Protocol.
      </p>
    </div>
  </section>

  <!-- 2 · The living registry -->
  <section class="living-registry">
    <div class="section-inner">
      <h2 class="section-title">The living registry</h2>
      <p class="section-subtitle">
        Every vault is a real, governed context graph — its own persona, its own history,
        its own place in the network. Here's a slice across {vaultCount} of them.
      </p>
      <div class="registry-grid">
        {registryVaults.map((v) => (
          <RegistryCard vault={v} classLabel={classLabel(v.class)} />
        ))}
      </div>
      <p class="registry-actions">
        <a href="/vaults/">See all {vaultCount} vaults &rarr;</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href="/vaults/graph/">View the relationship graph &rarr;</a>
      </p>
    </div>
  </section>

  <!-- How it Works -->
  <section class="how-it-works">
    <div class="section-inner">
      <h2 class="section-title">How it Works</h2>
      <p class="section-subtitle">Three steps from scattered files to a project your agents can navigate — and keep navigating.</p>
      <div class="feature-strip">
        <div class="feature-item">
          <strong>Agent-native</strong>
          <span>Governance files and typed context give agents orientation — no prompt re-engineering every session.</span>
        </div>
        <div class="feature-item">
          <strong>Human-readable</strong>
          <span>Every file is plain Markdown. Browse in Obsidian, VS Code, or GitHub. No proprietary formats, no lock-in.</span>
        </div>
        <div class="feature-item">
          <strong>Composable</strong>
          <span>Modules, datasets, and lattices compose into workflows. Start small, scale to multi-team campaigns with the same primitives.</span>
        </div>
      </div>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step">
            <div class="step-number">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
            <Fragment set:html={step.demo} />
          </div>
        ))}
      </div>
      <!-- N-07 / F-CHM-210 (M4.2 rider): the public image ships no in-repo tutorials — it
           points newcomers here. So the landing page must carry a findable "start here"
           learning on-ramp, not just a "dive deeper" footnote for the already-convinced.
           The prior `.how-footer` line was demoted-in-place below the explicit on-ramp. -->
      <div class="learn-onramp">
        <h3 class="onramp-title">New to aDNA? Start here</h3>
        <p class="onramp-lead">
          Cloned the workspace image and want to understand it before you build? The standard
          embeds in <code>.adna/</code>; the guided path lives here — a five-minute tour, the
          core concepts, and hands-on tutorials.
        </p>
        <div class="onramp-actions">
          <a href="/learn" class="btn btn-primary" data-astro-prefetch>Learn aDNA</a>
          <a href="/learn/what-is-adna" class="btn btn-secondary" data-astro-prefetch>What is aDNA? &rarr;</a>
          <a href="/learn/tutorials" class="btn btn-secondary" data-astro-prefetch>Tutorials &rarr;</a>
        </div>
      </div>
      <p class="how-footer">
        Dive deeper: <a href="/learn/concepts/convergence">Convergence Model</a> · <a href="/learn">Concepts &amp; Tutorials</a> · <a href="/reference">Reference Specification</a>
      </p>
    </div>
  </section>

  <!-- The Standard -->
  <section class="the-standard">
    <div class="section-inner">
      <h2 class="section-title">The Standard</h2>
      <p class="section-subtitle">aDNA is an open specification — MIT licensed, community-driven, designed for extension.</p>
      <div class="standard-meta">
        <span class="meta-tag">{STANDARD_VERSION}</span>
        <span class="meta-tag">MIT License</span>
        <span class="meta-tag">Open Standard</span>
        <span class="meta-tag">{ENTITY_TYPE_COUNT} Entity Types</span>
      </div>
      <div class="standard-cta">
        <a href="/reference/specification" class="btn btn-primary" data-astro-prefetch>Read the Specification</a>
        <a href="https://github.com/aDNA-Network/aDNA" class="btn btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>

  <!-- 5 · Join the network -->
  <section class="join-network">
    <div class="section-inner">
      <h2 class="section-title">Join the network</h2>
      <p class="section-subtitle">
        The network is open — run a node, share a vault, and help
        <a href="/reference/governance-model/">govern the standard</a>.
        Mission-aligned subnetworks already steward real public-good work here, in the open.
      </p>
      <ul class="subnetwork-tease">
        {subnetworks.map((s) => (
          <li class="tease-item">
            <a href="/commons/#featured" class="tease-name">{s.display_name}</a>
            <span class="tease-tagline">{s.tagline}</span>
          </li>
        ))}
      </ul>
      <div class="join-cta">
        <a href="/commons/" class="btn btn-primary" data-astro-prefetch>See the commons</a>
        <a href="/community/" class="btn btn-secondary" data-astro-prefetch>Join the community</a>
      </div>
      <p class="audience-pathways">
        <span class="pathways-label">aDNA for</span>
        {audiences.map((a, i) => (
          <Fragment>
            <a href={a.href}>{a.label}</a>{i < audiences.length - 1 && <span class="sep" aria-hidden="true">·</span>}
          </Fragment>
        ))}
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ——— Shared section styles ——— */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-title {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 36rem;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  /* ——— 1 · What a context democracy is ——— */
  .context-democracy {
    padding: var(--space-24) 0;
  }

  .diagram-caption {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 34rem;
    margin: var(--space-8) auto 0;
    line-height: 1.6;
  }

  /* ——— 2 · The living registry ——— */
  .living-registry {
    padding: var(--space-24) 0;
  }

  .registry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }

  .registry-actions {
    text-align: center;
    margin-top: var(--space-10);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .registry-actions a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .registry-actions a:hover {
    text-decoration: underline;
  }

  .registry-actions .sep {
    color: var(--color-border);
  }

  /* ——— How it Works ——— */
  .how-it-works {
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
    overflow-x: hidden;
  }

  .feature-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-12);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-primary);
  }

  .feature-item strong {
    font-size: var(--text-base);
    color: var(--color-text-heading);
  }

  .feature-item span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }

  .step {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    min-width: 0;
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    /* Cyan accent — AA both modes (purple --color-primary fails for sm text). */
    color: var(--color-link);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .step-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .step-description {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .step-demo {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #13131f;
    width: 100%;
    box-sizing: border-box;
  }

  .step-demo-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: #1c1c2e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .demo-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .demo-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .demo-dots span:nth-child(1) { background: #ff5f57; }
  .demo-dots span:nth-child(2) { background: #febc2e; }
  .demo-dots span:nth-child(3) { background: #28c840; }

  .demo-filename {
    color: #aaa;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.01em;
  }

  .step-demo-pre {
    margin: 0;
    padding: var(--space-4);
    color: #c9c9df;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.65;
    white-space: pre;
    overflow-x: auto;
    max-width: 100%;
    box-sizing: border-box;
  }

  .how-footer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-10);
    line-height: 1.6;
  }

  .how-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .how-footer a:hover {
    text-decoration: underline;
  }

  /* ——— Learning on-ramp (N-07 / F-CHM-210): a findable "start here" for the
     image-holding newcomer — the site is the learning home the image points at. ——— */
  .learn-onramp {
    max-width: 44rem;
    margin: var(--space-12) auto 0;
    padding: var(--space-8) var(--space-6);
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .onramp-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .onramp-lead {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: 1.6;
    max-width: 36rem;
    margin: 0 auto var(--space-6);
  }

  .onramp-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— The Standard ——— */
  .the-standard {
    /* §5 (.join-network) closes the page now — the --space-32 tail moved there (c165). */
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
  }

  .standard-meta {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25em 0.75em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-surface);
    letter-spacing: 0.03em;
  }

  .standard-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— 5 · Join the network ——— */
  .join-network {
    padding: var(--space-24) 0 var(--space-32);
  }

  /* In-text link inside the subtitle — underlined (link-in-text-block, c155 lesson). */
  .join-network .section-subtitle a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .subnetwork-tease {
    list-style: none;
    margin: 0 auto var(--space-10);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
    max-width: 60rem;
  }

  .tease-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .tease-name {
    font-family: var(--font-display);
    font-weight: 600;
    /* Cyan — AA both modes for small/medium brand-colored text. */
    color: var(--color-link);
    text-decoration: none;
  }

  .tease-name:hover {
    text-decoration: underline;
  }

  .tease-tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .join-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .audience-pathways {
    margin-top: var(--space-10);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Underlined — the row mixes muted label text with links (link-in-text-block guard). */
  .audience-pathways a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .audience-pathways .sep {
    color: var(--color-border);
  }

  /* ——— Responsive ——— */
  @media (max-width: 480px) {
    .section-title {
      font-size: var(--text-2xl);
    }

    .section-subtitle {
      font-size: var(--text-base);
      margin-bottom: var(--space-6);
    }

    .how-it-works {
      padding: var(--space-12) 0;
    }

    .context-democracy {
      padding: var(--space-12) 0;
    }

    .living-registry {
      padding: var(--space-12) 0;
    }

    .the-standard {
      padding: var(--space-12) 0;
    }

    .join-network {
      padding: var(--space-12) 0 var(--space-16);
    }

    .steps-grid {
      gap: var(--space-6);
    }

    .feature-strip {
      margin-bottom: var(--space-8);
    }

    .how-footer {
      margin-top: var(--space-6);
    }
  }
</style>
