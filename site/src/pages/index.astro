---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/sections/HomeHero.astro';
import { buildWebSiteJsonLD } from '../utils/seo';
import { steps, personas, stats } from '../data/home';
import bannerImage from '../assets/aDNABanner.png';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.network';
const jsonLD = buildWebSiteJsonLD(siteUrl);
---

<BaseLayout
  title="aDNA — the open standard & network for shared context"
  description="The open standard and network to build, share, and govern the context that powers AI — in the open, for the good of all. Built on the Lattice Protocol."
  jsonLD={jsonLD}
>
  <HomeHero bannerImage={bannerImage} stats={stats} />

  <!-- How it Works -->
  <section class="how-it-works">
    <div class="section-inner">
      <h2 class="section-title">How it Works</h2>
      <p class="section-subtitle">Three steps from scattered files to a project your agents can navigate — and keep navigating.</p>
      <div class="feature-strip">
        <div class="feature-item">
          <strong>Agent-native</strong>
          <span>Governance files and typed context give agents orientation — no prompt re-engineering every session.</span>
        </div>
        <div class="feature-item">
          <strong>Human-readable</strong>
          <span>Every file is plain Markdown. Browse in Obsidian, VS Code, or GitHub. No proprietary formats, no lock-in.</span>
        </div>
        <div class="feature-item">
          <strong>Composable</strong>
          <span>Modules, datasets, and lattices compose into workflows. Start small, scale to multi-team campaigns with the same primitives.</span>
        </div>
      </div>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step">
            <div class="step-number">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
            <Fragment set:html={step.demo} />
          </div>
        ))}
      </div>
      <p class="how-footer">
        Dive deeper: <a href="/learn/concepts/convergence">Convergence Model</a> · <a href="/learn">Concepts &amp; Tutorials</a> · <a href="/reference">Reference Specification</a>
      </p>
    </div>
  </section>

  <!-- Who Uses aDNA -->
  <section class="who-uses">
    <div class="section-inner">
      <h2 class="section-title">Who Uses aDNA</h2>
      <p class="section-subtitle">From solo developers to enterprise teams — aDNA scales with your project.</p>
      <div class="persona-grid">
        {personas.map((persona) => (
          <a href={persona.href} class="persona-card">
            <h3 class="persona-title">{persona.title}</h3>
            <p class="persona-summary">{persona.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- The Standard -->
  <section class="the-standard">
    <div class="section-inner">
      <h2 class="section-title">The Standard</h2>
      <p class="section-subtitle">aDNA is an open specification — MIT licensed, community-driven, designed for extension.</p>
      <div class="standard-meta">
        <span class="meta-tag">v2.2</span>
        <span class="meta-tag">MIT License</span>
        <span class="meta-tag">Open Standard</span>
        <span class="meta-tag">14 Entity Types</span>
      </div>
      <div class="standard-cta">
        <a href="/reference/specification" class="btn btn-primary" data-astro-prefetch>Read the Specification</a>
        <a href="https://github.com/LatticeProtocol/Agentic-DNA" class="btn btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ——— Shared section styles ——— */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-title {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 36rem;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  /* ——— How it Works ——— */
  .how-it-works {
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
    overflow-x: hidden;
  }

  .feature-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-12);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-primary);
  }

  .feature-item strong {
    font-size: var(--text-base);
    color: var(--color-text-heading);
  }

  .feature-item span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }

  .step {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    min-width: 0;
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .step-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .step-description {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .step-demo {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #13131f;
    width: 100%;
    box-sizing: border-box;
  }

  .step-demo-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: #1c1c2e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .demo-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .demo-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .demo-dots span:nth-child(1) { background: #ff5f57; }
  .demo-dots span:nth-child(2) { background: #febc2e; }
  .demo-dots span:nth-child(3) { background: #28c840; }

  .demo-filename {
    color: #aaa;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.01em;
  }

  .step-demo-pre {
    margin: 0;
    padding: var(--space-4);
    color: #c9c9df;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.65;
    white-space: pre;
    overflow-x: auto;
    max-width: 100%;
    box-sizing: border-box;
  }

  .how-footer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-10);
    line-height: 1.6;
  }

  .how-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .how-footer a:hover {
    text-decoration: underline;
  }

  /* ——— Who Uses aDNA ——— */
  .who-uses {
    padding: var(--space-24) 0;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .persona-card {
    display: block;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-primary);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .persona-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .persona-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    color: var(--color-primary);
  }

  .persona-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ——— The Standard ——— */
  .the-standard {
    padding: var(--space-24) 0 var(--space-32);
    background: var(--color-bg-alt);
  }

  .standard-meta {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25em 0.75em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-surface);
    letter-spacing: 0.03em;
  }

  .standard-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— Touch device tap feedback (no-hover devices) ——— */
  @media (hover: none) and (pointer: coarse) {
    .persona-card:active {
      transform: scale(0.98);
      box-shadow: var(--shadow-sm);
      transition: transform 80ms ease, box-shadow 80ms ease;
    }
  }

  /* ——— Responsive ——— */
  @media (max-width: 480px) {
    .section-title {
      font-size: var(--text-2xl);
    }

    .section-subtitle {
      font-size: var(--text-base);
      margin-bottom: var(--space-6);
    }

    .how-it-works {
      padding: var(--space-12) 0;
    }

    .who-uses {
      padding: var(--space-12) 0;
    }

    .the-standard {
      padding: var(--space-12) 0 var(--space-16);
    }

    .steps-grid {
      gap: var(--space-6);
    }

    .feature-strip {
      margin-bottom: var(--space-8);
    }

    .how-footer {
      margin-top: var(--space-6);
    }
  }
</style>
