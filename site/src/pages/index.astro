---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWebSiteJsonLD } from '../utils/seo';
import bannerImage from '../assets/banner.jpg';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';
const jsonLD = buildWebSiteJsonLD(siteUrl);

const steps = [
  {
    number: '01',
    title: 'Structure',
    description: 'Organize your project into what you know, how you work, and who is involved. Three directories — one architecture.',
    icon: '🗂',
  },
  {
    number: '02',
    title: 'Orient',
    description: 'Agents read CLAUDE.md and AGENTS.md to understand your project. Typed context files give them the depth they need.',
    icon: '🧭',
  },
  {
    number: '03',
    title: 'Execute',
    description: 'Sessions, missions, and campaigns decompose work into context-sized chunks. Progress compounds across sessions.',
    icon: '🚀',
  },
];

const personas = [
  {
    title: 'Solo Developer',
    summary: 'Freelancers and indie hackers using aDNA as a personal knowledge backbone.',
    href: '/use-cases/solo-developer',
    icon: '👩‍💻',
  },
  {
    title: 'Enterprise Team',
    summary: 'Cross-functional teams embedding aDNA into existing codebases and workflows.',
    href: '/use-cases/enterprise-team',
    icon: '🏢',
  },
  {
    title: 'Educator',
    summary: 'Teachers and professors structuring course materials for student-agent collaboration.',
    href: '/use-cases/educator',
    icon: '🎓',
  },
  {
    title: 'Startup',
    summary: 'Fast-moving teams using aDNA to preserve institutional knowledge as they scale.',
    href: '/use-cases/startup',
    icon: '⚡',
  },
  {
    title: 'Researcher',
    summary: 'Labs and research groups tracking protocols, datasets, and experiments.',
    href: '/use-cases/research-lab',
    icon: '🔬',
  },
];

const stats = [
  { value: '14', label: 'Entity Types' },
  { value: '3', label: 'Conformance Levels' },
  { value: 'v2.2', label: 'Current Version' },
  { value: 'MIT', label: 'Licensed' },
];
---

<BaseLayout
  title="aDNA — An Integrated Standard for Context and Knowledge"
  description="An open standard that structures your project's context and knowledge so both humans and AI agents can navigate it."
  jsonLD={jsonLD}
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-banner">
      <Image
        src={bannerImage}
        alt="aDNA — three glowing DNA helices representing the who/what/how triad, rising from a workspace of monitors and instruments"
        widths={[480, 768, 964]}
        sizes="(max-width: 768px) calc(100vw - 3rem), 56rem"
        class="hero-banner-img"
        loading="eager"
      />
    </div>
    <p class="hero-subtitle">An integrated standard for context and knowledge.</p>
    <div class="hero-actions">
      <a href="/get-started" class="btn btn-primary">Get Started</a>
      <a href="/learn/what-is-adna" class="btn btn-secondary">What is aDNA?</a>
    </div>
  </section>

  <!-- Core features -->
  <section class="features">
    <div class="features-inner">
      <div class="feature">
        <h2>Agent-native</h2>
        <p>Built for AI agents from the ground up. Governance files and typed context give agents the orientation they need — no prompt re-engineering every session.</p>
      </div>
      <div class="feature">
        <h2>Human-readable</h2>
        <p>Every file is plain Markdown. Browse in Obsidian, VS Code, or GitHub. No proprietary formats, no lock-in.</p>
      </div>
      <div class="feature">
        <h2>Composable</h2>
        <p>Modules, datasets, and lattices compose into workflows. Start small, scale to multi-team campaigns with the same primitives.</p>
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section class="how-it-works">
    <div class="section-inner">
      <h2 class="section-title">How it Works</h2>
      <p class="section-subtitle">Three steps to a project that agents can understand.</p>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step">
            <div class="step-number">{step.number}</div>
            <div class="step-icon">{step.icon}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
            <div class="media-placeholder" data-media="gif" data-content={`step-${step.number}`}>
              <div class="media-placeholder-inner">
                <span class="media-placeholder-icon">▶</span>
                <span class="media-placeholder-label">Demo coming soon</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Operational Ontology -->
  <section class="ontology">
    <div class="section-inner">
      <h2 class="section-title">An Operational Ontology</h2>
      <p class="section-subtitle">14 entity types across three triad legs give your project a typed vocabulary — from planning to execution to knowledge capture.</p>
      <div class="ontology-grid">
        <div class="ontology-leg">
          <h3 class="ontology-leg-title"><span class="ontology-badge badge-who">WHO</span> People &amp; Governance</h3>
          <ul class="ontology-list">
            <li><strong>Governance</strong> — who decides, what the rules are</li>
            <li><strong>Team</strong> — who does the work</li>
            <li><strong>Coordination</strong> — how agents and people sync</li>
          </ul>
        </div>
        <div class="ontology-leg">
          <h3 class="ontology-leg-title"><span class="ontology-badge badge-what">WHAT</span> Knowledge &amp; Artifacts</h3>
          <ul class="ontology-list">
            <li><strong>Context</strong> — curated knowledge agents load before working</li>
            <li><strong>Decisions</strong> — architecture decision records</li>
            <li><strong>Modules</strong> — atomic capability units with typed I/O</li>
            <li><strong>Lattices</strong> — directed graphs that compose modules into workflows</li>
          </ul>
        </div>
        <div class="ontology-leg">
          <h3 class="ontology-leg-title"><span class="ontology-badge badge-how">HOW</span> Operations &amp; Execution</h3>
          <ul class="ontology-list">
            <li><strong>Campaigns</strong> — multi-mission strategic initiatives</li>
            <li><strong>Missions</strong> — tasks decomposed into session-sized objectives</li>
            <li><strong>Sessions</strong> — bounded units of agent work with audit trails</li>
            <li><strong>Templates, Skills, Pipelines, Backlog</strong></li>
          </ul>
        </div>
      </div>
      <p class="ontology-footer">
        The hierarchy narrows context at each level: <strong>Campaign → Mission → Objective</strong>. An agent working on a single objective loads only the files it needs — not the entire vault. <a href="/learn/concepts/convergence">Learn about convergence →</a>
      </p>
    </div>
  </section>

  <!-- Context Engineering -->
  <section class="context-eng">
    <div class="section-inner">
      <h2 class="section-title">Context Engineering, Built In</h2>
      <p class="section-subtitle">aDNA treats agent context as a first-class engineering problem — not an afterthought bolted onto your docs.</p>
      <div class="context-grid">
        <div class="context-card">
          <span class="context-icon">🎯</span>
          <h3>Context Optimization</h3>
          <p>Every context file is scored on signal density, actionability, and coverage. A 6-axis quality rubric keeps your agent knowledge sharp — not bloated.</p>
          <a href="/learn/concepts/context-optimization" class="card-link">How it works →</a>
        </div>
        <div class="context-card">
          <span class="context-icon">📐</span>
          <h3>Convergence Model</h3>
          <p>Each level of the execution hierarchy narrows scope. A vault might hold 75K tokens of context — but a single session loads only the 5K it actually needs.</p>
          <a href="/learn/concepts/convergence" class="card-link">See the model →</a>
        </div>
        <div class="context-card">
          <span class="context-icon">🧩</span>
          <h3>Context Recipes</h3>
          <p>Pre-built assemblies for common tasks. Need to design a lattice? There's a recipe that pulls exactly the right context subtopics — minimal, standard, or full.</p>
          <a href="/patterns/context-recipe" class="card-link">Browse recipes →</a>
        </div>
        <div class="context-card">
          <span class="context-icon">🏛️</span>
          <h3>Context Commons</h3>
          <p>A community-maintained library of reusable context files. Contribute what you learn, pull what others have validated. Knowledge compounds across projects.</p>
          <a href="/learn/concepts/context-commons" class="card-link">Join the commons →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Uses aDNA -->
  <section class="who-uses">
    <div class="section-inner">
      <h2 class="section-title">Who Uses aDNA</h2>
      <p class="section-subtitle">From solo developers to enterprise teams — aDNA scales with your project.</p>
      <div class="persona-grid">
        {personas.map((persona) => (
          <a href={persona.href} class="persona-card">
            <span class="persona-icon">{persona.icon}</span>
            <h3 class="persona-title">{persona.title}</h3>
            <p class="persona-summary">{persona.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- The Standard -->
  <section class="the-standard">
    <div class="section-inner">
      <h2 class="section-title">The Standard</h2>
      <p class="section-subtitle">aDNA is an open specification — MIT licensed, community-driven, designed for extension.</p>
      <div class="stats-row">
        {stats.map((stat) => (
          <div class="stat">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="standard-cta">
        <a href="/reference/specification" class="btn btn-primary">Read the Specification</a>
        <a href="https://github.com/LatticeProtocol/Agentic-DNA" class="btn btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ——— Hero ——— */
  .hero {
    padding: var(--space-12) var(--space-6) var(--space-16);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-banner {
    max-width: 56rem;
    width: 100%;
    margin: 0 auto var(--space-8);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .hero-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    line-height: 1.4;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-lg);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  /* Dark mode: use darker bg so white text passes WCAG AA (5.6:1) */
  :global(.dark) .btn-primary {
    background: var(--brand-primary);
  }

  :global(.dark) .btn-primary:hover {
    background: var(--brand-primary-dark);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: var(--color-surface);
  }

  .btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* ——— Features ——— */
  .features {
    padding: var(--space-16) var(--space-6);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .features-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-8);
  }

  .feature h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .feature p {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* ——— Shared section styles ——— */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-title {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 36rem;
    margin: 0 auto var(--space-12);
    line-height: 1.6;
  }

  /* ——— How it Works ——— */
  .how-it-works {
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
  }

  .step {
    text-align: center;
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }

  .step-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
    line-height: 1;
  }

  .step-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .step-description {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  /* ——— Media Placeholder ——— */
  .media-placeholder {
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 3%, transparent),
      color-mix(in srgb, var(--color-accent) 3%, transparent)
    );
  }

  .media-placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
  }

  .media-placeholder-icon {
    font-size: var(--text-2xl);
    opacity: 0.4;
  }

  .media-placeholder-label {
    font-size: var(--text-sm);
    font-style: italic;
  }

  /* ——— Operational Ontology ——— */
  .ontology {
    padding: var(--space-24) 0;
  }

  .ontology-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .ontology-leg {
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .ontology-leg-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .ontology-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15em 0.5em;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .badge-who {
    background: hsl(280 60% 92%);
    color: hsl(280 60% 35%);
  }

  :global(.dark) .badge-who {
    background: hsl(280 40% 20%);
    color: hsl(280 60% 75%);
  }

  .badge-what {
    background: hsl(180 60% 90%);
    color: hsl(180 60% 25%);
  }

  :global(.dark) .badge-what {
    background: hsl(180 40% 18%);
    color: hsl(180 60% 70%);
  }

  .badge-how {
    background: hsl(38 80% 90%);
    color: hsl(38 70% 30%);
  }

  :global(.dark) .badge-how {
    background: hsl(38 50% 18%);
    color: hsl(38 70% 70%);
  }

  .ontology-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .ontology-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .ontology-list li strong {
    color: var(--color-text);
  }

  .ontology-footer {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: 1.6;
    max-width: 48rem;
    margin: 0 auto;
  }

  .ontology-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .ontology-footer a:hover {
    text-decoration: underline;
  }

  /* ——— Context Engineering ——— */
  .context-eng {
    padding: var(--space-24) 0;
    background: var(--color-bg-alt);
  }

  .context-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .context-card {
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: all var(--transition-fast);
  }

  .context-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .context-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .context-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .context-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  /* ——— Who Uses aDNA ——— */
  .who-uses {
    padding: var(--space-24) 0;
  }

  .persona-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-6);
  }

  .persona-card {
    display: block;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .persona-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .persona-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .persona-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
    color: var(--color-text-heading);
  }

  .persona-summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ——— The Standard ——— */
  .the-standard {
    padding: var(--space-24) 0 var(--space-32);
    background: var(--color-bg-alt);
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: var(--space-12);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .standard-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— Responsive ——— */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-16) var(--space-4) var(--space-12);
    }

    .hero-banner {
      max-width: 100%;
    }

    .stats-row {
      gap: var(--space-8);
    }

    .stat-value {
      font-size: var(--text-2xl);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: var(--space-8) var(--space-4) var(--space-8);
    }

    .hero-subtitle {
      font-size: var(--text-xl);
    }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
</style>
