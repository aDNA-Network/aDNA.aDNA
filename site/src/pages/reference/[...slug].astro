---
import { getCollection, render } from 'astro:content';
import DocumentationLayout from '../../layouts/DocumentationLayout.astro';
import { buildTechArticleJsonLD, buildBreadcrumbListJsonLD } from '../../utils/seo';

export async function getStaticPaths() {
  const refs = await getCollection('reference', ({ data }) => !data.draft);
  return refs.map((ref) => ({
    params: { slug: ref.id },
    props: { ref },
  }));
}

const { ref } = Astro.props;
const { Content, headings } = await render(ref);

const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? 'https://adna.dev';

const jsonLD = [
  buildTechArticleJsonLD({
    title: ref.data.ref_title,
    description: ref.data.description ?? '',
    url: Astro.url.href,
    dateModified: ref.data.updated?.toISOString(),
  }),
  buildBreadcrumbListJsonLD([
    { name: 'Home', url: `${siteBase}/` },
    { name: 'Reference', url: `${siteBase}/reference/` },
    { name: ref.data.ref_title },
  ]),
];
---

<DocumentationLayout
  title={ref.data.ref_title}
  description={ref.data.description ?? `${ref.data.ref_title} — aDNA reference.`}
  headings={headings}
  jsonLD={jsonLD}
>
  {ref.id === 'specification' && (
    <aside class="spec-orientation" aria-label="Orientation">
      <p><strong>For implementers and evaluators.</strong> New to aDNA? Start with <a href="/learn/what-is-adna">What is aDNA &rarr;</a></p>
      <p class="spec-orientation-build">Ready to build one? <a href="/get-started">Get started &rarr;</a></p>
    </aside>
  )}
  {ref.data.version && (
    <div class="ref-meta">
      <span class="ref-version">v{ref.data.version}</span>
      <span class:list={['ref-stability', ref.data.stability]}>{ref.data.stability}</span>
    </div>
  )}
  <Content />
</DocumentationLayout>

<style>
  /* Spec reader-orientation banner (network-audit H5): /reference/specification is an
     entry point for implementers/evaluators but also the deepest doc — orient newcomers
     out to "What is aDNA" and forward to "Get started" so it isn't a dead-end wall of spec. */
  .spec-orientation {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
    background: var(--color-bg-alt);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }
  .spec-orientation p { margin: 0; }
  .spec-orientation p + p { margin-top: var(--space-1); }
  .spec-orientation a { color: var(--color-link); font-weight: 500; }

  .ref-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .ref-version {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .ref-stability {
    padding: 0.15em 0.6em;
    border-radius: var(--radius-full);
    font-weight: 500;
    text-transform: capitalize;
  }

  .ref-stability.stable {
    background: color-mix(in srgb, var(--color-success) 15%, transparent);
    color: hsl(142 72% 28%); /* darker green for WCAG AA (5.4:1 on white) */
  }

  .ref-stability.beta {
    background: color-mix(in srgb, var(--color-info) 15%, transparent);
    color: hsl(199 89% 32%); /* darker blue for WCAG AA */
  }

  .ref-stability.experimental {
    background: color-mix(in srgb, var(--color-warning) 15%, transparent);
    color: hsl(38 92% 32%); /* darker amber for WCAG AA */
  }

  .ref-stability.deprecated {
    background: color-mix(in srgb, var(--color-error) 15%, transparent);
    color: hsl(0 72% 35%); /* darker red for WCAG AA */
  }

  /* Dark mode: lighten badge text for dark backgrounds */
  :global(.dark) .ref-stability.stable { color: #34C06E; }
  :global(.dark) .ref-stability.beta { color: #5CB8E8; }
  :global(.dark) .ref-stability.experimental { color: #E89545; }
  :global(.dark) .ref-stability.deprecated { color: #E87070; }
</style>
