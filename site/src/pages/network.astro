---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/sections/HomeHero.astro';
import NetworkDiagram from '../components/sections/NetworkDiagram.astro';
import { buildWebPageJsonLD } from '../utils/seo';
import vaultsData from '../data/vaults.json';
import heroNetwork from '../assets/heroes/hero_network.png';

// E4 cycles 151–153 — the `/network` narrative surface (design spec Stage 2/3, bands 1–5).
// Hero (sparse) → "A network of real relationships" diagram-as-proof → "What is an aDNA
// computer?" (the local-by-default / opt-in-federation boundary, Standing Rule 4) →
// "The topology at a glance" (typed taxonomy + counts → /vaults/graph) → "Run a node"
// onboarding + participation CTA (cycle 152) → "Governed in the open" trust-anchor + the
// public-good ethos close (cycle 153; RLP Gap #4). Sparse→Medium→Medium→Dense→Sparse.

const description =
  'An aDNA computer is one machine carrying many context vaults. See how nodes connect through real, directed relationships — and what stays local versus what you federate.';

const jsonLD = buildWebPageJsonLD({
  title: 'The network of aDNA computers',
  description,
  url: Astro.url.href,
});

const vaultCount = (vaultsData as any).vault_count ?? 0;
const edgeCount = (vaultsData as any).edges?.length ?? 0;

// Per-type edge census (E4 c155 — Diagram-Reviewer: the typed legend over-sold an even
// taxonomy; the real census is two dominant kinds + three rare ones, so the legend shows
// live counts to stay self-honest about which kinds are load-bearing).
const edgeTypeCounts: Record<string, number> = ((vaultsData as any).edges ?? []).reduce(
  (m: Record<string, number>, e: any) => { m[e.type] = (m[e.type] ?? 0) + 1; return m; },
  {} as Record<string, number>,
);

// The 5-edge taxonomy — same source as /vaults/graph. Mermaid draws every edge in one
// colour, so the legend differentiates by LINE STYLE, not an invented per-type palette.
const edgeTypes = [
  { key: 'umbrella', sample: 'thick', meaning: 'an org-vault contains its pillar children' },
  { key: 'federation', sample: 'solid', meaning: 'a consumer depends on the forge or framework it is built from' },
  { key: 'partner', sample: 'circle', meaning: 'a platform ships with its default partner' },
  { key: 'companion', sample: 'dashed', meaning: 'a sibling persona-pair or thematic family' },
  { key: 'supersedes', sample: 'super', meaning: 'a successor replaced its predecessor' },
];
---

<BaseLayout
  title="The network of aDNA computers"
  description={description}
  jsonLD={jsonLD}
>
  <HomeHero
    heroImage={heroNetwork}
    heroAlt="A wide bird's-eye pixel-art map of many small, independently lit settlements scattered across a dark Tokyo-Night ground, a few linked by glowing cyan and purple conduits — aDNA computers, each its own place, sparsely federated."
    title="The network of aDNA computers"
    lead="An aDNA computer is one machine — laptop, server, or cloud box — carrying many context vaults (self-governing folders of project knowledge) under a single Home.aDNA. Nodes connect through real, directed relationships, and each one decides what stays local and what joins the shared commons."
    primaryHref="/vaults/graph/"
    primaryLabel="See the relationship graph"
    secondaryHref="/vaults/"
    secondaryLabel="Browse the vaults"
  />

  <!-- Band 1 · A network of real relationships (the diagram-as-proof) -->
  <section class="net-proof">
    <div class="section-inner">
      <h2 class="section-title">A network of real relationships</h2>
      <p class="section-subtitle">
        The connections are not decorative. Each line is a relationship a vault actually declares —
        drawn here as a simple hub around the shared core, not an invented peer-to-peer mesh.
      </p>
      <NetworkDiagram />
      <p class="diagram-caption">
        Six representative aDNA vaults — forges, frameworks, platforms, and public-good archives —
        federating around the shared aDNA core. (See all {vaultCount} in the full graph below.)
      </p>
    </div>
  </section>

  <!-- Band 2 · What is an aDNA computer? (the local / shared boundary) -->
  <section class="net-node">
    <div class="section-inner">
      <h2 class="section-title">What is an aDNA computer?</h2>
      <p class="section-subtitle">
        A node on the network is one machine, governed by a single <code>Home.aDNA</code> vault that
        knows every other vault living on it. What that machine shares is always your choice.
      </p>
      <div class="boundary">
        <div class="boundary-col boundary-local">
          <h3>Stays on your machine</h3>
          <p>
            By default, everything. A node is local-first — its vaults, their full history, the
            machine&rsquo;s inventory, and its credentials never leave the computer unless you send
            them (Standing Rule&nbsp;4).
          </p>
          <ul>
            <li>Your project vaults and their history</li>
            <li>The node&rsquo;s inventory and machine state</li>
            <li>Identity and credentials</li>
          </ul>
        </div>
        <div class="boundary-col boundary-shared">
          <h3>You opt to federate</h3>
          <p>
            Only what you choose. Publishing a vault, declaring a relationship to another vault, or
            joining a shared lattice is an explicit, reviewable act — never a silent default.
          </p>
          <ul>
            <li>A vault published to the shared registry</li>
            <li>A relationship declared to another vault</li>
            <li>Membership in a federated lattice</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Band 3 · The topology at a glance (typed taxonomy + counts → full graph) -->
  <section class="net-topology">
    <div class="section-inner">
      <h2 class="section-title">The topology at a glance</h2>
      <p class="section-subtitle">
        {vaultCount} vaults, {edgeCount} relationships. Every edge is <strong>real and directed</strong>,
        drawn from each vault&rsquo;s governance, across five kinds of relationship.
      </p>
      <ul class="edge-legend" aria-label="The five kinds of relationship">
        {edgeTypes.map((e) => (
          <li>
            <span class={`le le-${e.sample}`} aria-hidden="true"></span>
            <span class="le-text"><strong>{e.key}</strong> <span class="le-count">&middot; {edgeTypeCounts[e.key] ?? 0}</span> — {e.meaning}</span>
          </li>
        ))}
      </ul>
      <p class="topology-actions">
        <a href="/vaults/graph/">See the full relationship graph &rarr;</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href="/vaults/">Browse all {vaultCount} vaults &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Band 4 · Run a node (the onboarding steps + the participation CTA, RLP Gap #1) -->
  <section class="net-run">
    <div class="section-inner">
      <h2 class="section-title">Run a node</h2>
      <p class="section-subtitle">
        A node is a workspace on your own machine. Three steps take you from nothing to a governed
        node that decides what it shares — the same local-by-default boundary, made concrete.
      </p>
      <ul class="run-meta" aria-label="What running a node takes">
        <li>About five minutes</li>
        <li>Needs <code>git</code> + the Claude Code CLI</li>
        <li>Local-first — nothing leaves until you choose</li>
      </ul>

      <ol class="run-steps">
        <li class="run-step">
          <span class="run-step-no" aria-hidden="true">1</span>
          <div class="run-step-body">
            <h3>Bootstrap your node</h3>
            <p>
              Clone the template and start the agent. It detects a fresh workspace and walks you through
              the <code>Home.aDNA</code> node interview — the vault that governs your machine.
            </p>
            <pre class="run-code"><code>git clone https://github.com/LatticeProtocol/Agentic-DNA.git my-node
cd my-node
claude</code></pre>
            <p class="run-note">
              See <a href="/get-started/" data-astro-prefetch>Get started</a> for the one-time setup —
              installing <code>git</code> and the Claude Code CLI.
            </p>
          </div>
        </li>
        <li class="run-step">
          <span class="run-step-no" aria-hidden="true">2</span>
          <div class="run-step-body">
            <h3>Everything stays local by default</h3>
            <p>
              Your node is local-first. Its vaults, their full history, the machine&rsquo;s inventory, and
              your credentials stay on the computer until you choose to send them (Standing Rule&nbsp;4).
            </p>
          </div>
        </li>
        <li class="run-step">
          <span class="run-step-no" aria-hidden="true">3</span>
          <div class="run-step-body">
            <h3>Opt into federation</h3>
            <p>
              Joining the commons is always explicit and reviewable — a change you author and inspect
              before you push it. What actually crosses the boundary is a curated slice of your
              <code>Home.aDNA</code> registry — which vaults exist and the relationships they declare —
              never their contents.
            </p>
            <p class="run-note">
              <a href="/reference/" data-astro-prefetch>See how federation works &rarr;</a>
            </p>
          </div>
        </li>
      </ol>

      <div class="run-cta">
        <a href="/get-started/" class="btn btn-primary" data-astro-prefetch>Run your first node &rarr;</a>
        <a href="/reference/" class="btn btn-secondary" data-astro-prefetch>Read the standard &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Band 5 · Govern & trust (the sparse trust-anchor close; RLP Gap #4 partial — full org surface is E3) -->
  <section class="net-govern">
    <div class="section-inner">
      <h2 class="section-title">Governed in the open</h2>
      <p class="section-subtitle">
        The network is a commons, not a silo. The standard that holds it is openly specified and openly
        governed &mdash; a named steward, a public process for proposing change, and every decision on the record.
      </p>
      <ul class="gov-signals" aria-label="How the aDNA standard is governed">
        <li class="gov-tag">Founding-Architect stewardship</li>
        <li class="gov-tag">Open spec &middot; MIT</li>
        <li class="gov-tag">Public change process</li>
        <li class="gov-tag">Quarterly standard cadence</li>
      </ul>
      <div class="gov-cta">
        <a href="/reference/governance-model/" class="btn btn-primary" data-astro-prefetch>Read the governance model &rarr;</a>
        <a href="/community/" class="btn btn-secondary" data-astro-prefetch>Join the community &rarr;</a>
      </div>
      <p class="gov-ethos">
        Language and DNA are our shared heritage. So is context &mdash; the accumulated understanding of a
        civilization, held in common and stewarded for the generations that inherit it.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ——— Shared section scaffold (mirrors index.astro) ——— */
  .section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-title {
    font-size: var(--text-3xl);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    max-width: 40rem;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
  }

  .net-proof,
  .net-node,
  .net-topology,
  .net-run,
  .net-govern {
    padding: var(--space-24) 0;
    overflow-x: hidden;
  }

  /* Alternating band ground — band 4 sits on bg-alt so it reads distinct from
     the default-ground topology band above it (same device as .net-node). */
  .net-node,
  .net-run {
    background: var(--color-bg-alt);
  }

  .diagram-caption {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    max-width: 34rem;
    margin: var(--space-8) auto 0;
    line-height: 1.6;
  }

  /* ——— Band 2 · the local / shared boundary ——— */
  .boundary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .boundary-col {
    padding: var(--space-8) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  /* Cyan = local/data signal · purple = federation/brand signal (≤2 fighting colors). */
  .boundary-local {
    border-top: 3px solid var(--color-link);
  }

  .boundary-shared {
    border-top: 3px solid var(--color-primary);
  }

  .boundary-col h3 {
    font-size: var(--text-xl);
    color: var(--color-text-heading);
    margin: 0 0 var(--space-3);
  }

  .boundary-col p {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 var(--space-4);
  }

  .boundary-col ul {
    margin: 0;
    padding-left: var(--space-5);
    color: var(--color-text);
    line-height: 1.7;
  }

  .boundary-col li {
    margin-bottom: var(--space-1);
  }

  /* ——— Band 3 · typed legend (line STYLE, not colour — mirrors /vaults/graph) ——— */
  .edge-legend {
    list-style: none;
    margin: 0 auto;
    padding: var(--space-5) var(--space-6);
    max-width: 52rem;
    display: grid;
    gap: 0.7rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .edge-legend li {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    line-height: 1.4;
  }

  .le-text {
    color: var(--color-text);
  }

  .le-text strong {
    font-family: var(--font-mono);
    color: var(--color-link);
  }

  /* Per-type census — muted so the type name stays the emphasis, the count is a quiet honesty cue. */
  .le-count {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  /* Line samples drawn with the edge colour Mermaid uses (--color-link). */
  .le {
    flex: 0 0 auto;
    width: 3rem;
    height: 0;
    position: relative;
    border-top: 2px solid var(--color-link);
  }
  .le-thick { border-top-width: 4px; }
  .le-solid { border-top-width: 2px; }
  .le-dashed { border-top-style: dashed; }
  /* supersedes: thicker dash (+ the 's' label) so it reads apart from companion's thin dash —
     mirrors /vaults/graph and the .mmd long-dash linkStyle, so the legend stops implying five
     unique line styles when companion + supersedes share the dashed family (E4 c158 — Diagram-Reviewer). */
  .le-super { border-top-style: dashed; border-top-width: 3px; }
  .le::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border-left: 6px solid var(--color-link);
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
  }
  .le-circle::after {
    border: 2px solid var(--color-link);
    border-radius: 50%;
    width: 7px;
    height: 7px;
    background: var(--color-bg);
    right: -3px;
  }
  .le-super::before {
    content: 's';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -60%);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-link);
    background: var(--color-surface);
    padding: 0 0.2rem;
    line-height: 1;
  }

  .topology-actions {
    text-align: center;
    margin-top: var(--space-10);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .topology-actions a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .topology-actions a:hover {
    text-decoration: underline;
  }

  .topology-actions .sep {
    color: var(--color-border);
  }

  /* ——— Band 4 · run-a-node (numbered steps, one organizing principle) ——— */
  /* Pull the subtitle tighter to the cue row below it (they are one thought: the pitch + the
     commitment), so the cue row does not float in a space-10 gap. */
  .net-run .section-subtitle {
    margin-bottom: var(--space-5);
  }

  /* Commitment + safety cue row — front-loads the join-scent (what it takes, what stays
     safe) so the barrier-to-entry is answerable before the steps, not buried in step 1. */
  .run-meta {
    list-style: none;
    margin: 0 auto var(--space-12);
    padding: 0;
    max-width: 46rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .run-meta li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Cyan tick before each cue (the local/data signal; decorative). */
  .run-meta li::before {
    content: '';
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-link);
  }

  .run-steps {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 46rem;
    display: grid;
    gap: var(--space-8);
  }

  .run-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  /* Numbered marker — cyan signal (local/data), the same pair band 2 uses. */
  .run-step-no {
    flex: 0 0 auto;
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    border: 2px solid var(--color-link);
    color: var(--color-link);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
    line-height: 1;
  }

  .run-step-body h3 {
    font-size: var(--text-xl);
    color: var(--color-text-heading);
    margin: 0.3rem 0 var(--space-3);
  }

  .run-step-body p {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .run-code {
    margin: var(--space-4) 0 0;
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-text);
  }

  /* Prereq / pointer note under a run-step — quiet, muted, the concrete HOW the lenses asked for. */
  .run-note {
    margin: var(--space-3) 0 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  /* Underlined, not colour-only: the step-1 "Get started" link sits inside a sentence of muted text,
     so it needs a non-colour distinction to satisfy WCAG link-in-text-block (axe both modes). */
  .run-note a {
    color: var(--color-link);
    text-decoration: underline;
  }

  .run-cta {
    margin-top: var(--space-12);
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ——— Band 5 · govern & trust (trust-anchor close; mirrors homepage .the-standard) ——— */
  /* Non-link trust facts (the on-page governance scent); the CTAs below carry the navigation. */
  .gov-signals {
    list-style: none;
    margin: 0 auto var(--space-10);
    padding: 0;
    max-width: 48rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .gov-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25em 0.75em;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-surface);
    letter-spacing: 0.03em;
  }

  .gov-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* The ethos close — one muted manifesto line that lands the page (shown, not preached). */
  .gov-ethos {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-base);
    max-width: 38rem;
    margin: var(--space-12) auto 0;
    line-height: 1.7;
  }

  /* ——— Responsive ——— */
  @media (max-width: 700px) {
    .boundary {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: var(--text-2xl);
    }

    .section-subtitle {
      font-size: var(--text-base);
      margin-bottom: var(--space-6);
    }

    .net-proof,
    .net-node,
    .net-topology,
    .net-run,
    .net-govern {
      padding: var(--space-12) 0;
    }
  }
</style>
