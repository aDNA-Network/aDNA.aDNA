---
import DocumentationLayout from '../../layouts/DocumentationLayout.astro';
import CardGrid from '../../components/sections/CardGrid.astro';
import { getDocsBySection } from '../../utils/collections';

const useCases = await getDocsBySection('use-cases');
const cards = useCases.map((doc) => ({
  title: doc.data.doc_title,
  description: doc.data.description,
  href: `/use-cases/${doc.id}`,
}));
---

<DocumentationLayout
  title="Use Cases"
  description="Real-world aDNA adoption stories across solo developers, startups, research labs, and enterprises."
>
  <p>See how different teams and individuals use aDNA to organize their projects. Each use case follows a named persona through a concrete deployment.</p>
  <CardGrid cards={cards} columns={2} />
</DocumentationLayout>
