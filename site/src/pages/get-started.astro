---
import DocumentationLayout from '../layouts/DocumentationLayout.astro';
import Callout from '../components/sections/Callout.astro';
import { buildWebPageJsonLD } from '../utils/seo';

const jsonLD = buildWebPageJsonLD({
  title: 'Get Started with aDNA',
  description: 'Set up your first aDNA project in three steps: clone the template, open in your editor, and run your first agent session with Claude Code.',
  url: Astro.url.href,
});
---

<DocumentationLayout
  title="Get Started"
  description="Set up your first aDNA project in three steps: clone the template, open in your editor, and run your first agent session with Claude Code."
  jsonLD={jsonLD}
>
  <p>Get your first aDNA project running in about 5 minutes.</p>

  <Callout variant="info" title="Prerequisites">
    <p>You need <a href="https://docs.anthropic.com/en/docs/claude-code" target="_blank" rel="noopener">Claude Code installed</a> before step 3. Install it with:</p>
    <pre><code>npm install -g @anthropic-ai/claude-code</code></pre>
    <p>Git is also required for step 1.</p>
  </Callout>

  <Callout variant="tip" title="What you'll have when you're done">
    <p>A working aDNA project with <code>CLAUDE.md</code>, <code>what/</code>, <code>how/</code>, and <code>who/</code> directories. Run <code>claude</code> inside the project folder and your agent reads the governance files automatically — no re-briefing needed.</p>
  </Callout>

  <h2 id="step-1">1. Clone the template</h2>
  <pre><code>git clone https://github.com/LatticeProtocol/Agentic-DNA.git my-project
cd my-project</code></pre>
  <p>This gives you the base <code>.adna/</code> template with governance files, skills, and context structure.</p>

  <h2 id="step-2">2. Open in your editor</h2>
  <p>Open the project in Obsidian, VS Code, or any Markdown editor. The <code>CLAUDE.md</code> file at the root is your starting point — it tells AI agents how to navigate the project.</p>

  <h2 id="step-3">3. Run your first session</h2>
  <p>Start a session with Claude Code (or your preferred AI agent). The agent will read <code>CLAUDE.md</code>, detect a fresh project, and walk you through onboarding.</p>

  <h2 id="see-it-live">See it live</h2>
  <p>The <code>aDNA.aDNA/</code> repository is a working aDNA project — open it alongside this tutorial to see every concept in action:</p>
  <ul>
    <li><code>aDNA.aDNA/CLAUDE.md</code> — the root governance file your agent reads first</li>
    <li><code>aDNA.aDNA/STATE.md</code> — live operational snapshot: current phase, blockers, next steps</li>
    <li><code>aDNA.aDNA/how/sessions/active/</code> — active session files, one per working session</li>
  </ul>

  <h2 id="next-steps">Next steps</h2>
  <ul>
    <li><a href="/learn/tutorials/first-claude-md">Tutorial: Create Your First CLAUDE.md</a></li>
    <li><a href="/learn/what-is-adna">What is aDNA?</a></li>
    <li><a href="/learn/concepts/triad">Learn about the Triad</a></li>
  </ul>
</DocumentationLayout>
