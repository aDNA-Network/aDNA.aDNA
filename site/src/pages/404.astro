---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <div class="not-found">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <div class="not-found-actions">
      <a href="/" class="btn">Go home</a>
      <a href="/learn" class="btn btn-outline">Browse docs</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-32) var(--space-6);
    min-height: 50vh;
  }

  .not-found h1 {
    font-size: var(--text-4xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .not-found p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  .not-found-actions {
    display: flex;
    gap: var(--space-4);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-lg);
    font-family: var(--font-display);
    font-weight: 600;
    text-decoration: none;
    background: var(--color-primary);
    color: white;
    transition: background var(--transition-fast);
  }

  .btn:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  /* Dark mode: --color-primary flips to the lighter #9d7cd8 (3.3:1 vs white = fails AA).
     Mirror the global .btn-primary fix — deep purple --brand-primary-dark #6d4bb8 → 5.8:1.
     Scoped with :not(.btn-outline) so the transparent outline button is unaffected. */
  :global(.dark) .btn:not(.btn-outline) {
    background: var(--brand-primary-dark);
  }

  :global(.dark) .btn:not(.btn-outline):hover {
    background: #7c5cc4;
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-outline:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: transparent;
  }
</style>
