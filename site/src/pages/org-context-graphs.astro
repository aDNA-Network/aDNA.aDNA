---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildWebPageJsonLD } from '../utils/seo';

const title = 'Organizational Context Graphs — the aDNA method';
const description = 'A reproducible method for building, operating, and accessing organizational context graphs — living, machine-readable models of how a company actually works.';
const jsonLD = buildWebPageJsonLD({ title, description, url: Astro.url.href });
---

<BaseLayout title={title} description={description} jsonLD={jsonLD} bodyClass="ocg-route">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..700,0..100,0..1;1,9..144,300..600,0..100,0..1&display=swap" rel="stylesheet" />
  <div class="ocg">
    <div class="atmos aurora"></div>
    <div class="atmos grid"></div>
    <div class="atmos grain"></div>

    <!-- ============ SUB-NAV (slim sticky; replaces the page's own top bar) ============ -->
    <div class="subnav">
      <div class="subnav-inner">
        <nav class="sections" id="navlinks">
          <a href="#problem"><span class="n">01</span>Problem</a>
          <a href="#graph"><span class="n">02</span>The graph</a>
          <a href="#method"><span class="n">03</span>Method</a>
          <a href="#proof"><span class="n">04</span>Proof</a>
          <a href="#pattern"><span class="n">05</span>Pattern</a>
          <a href="#base"><span class="n">06</span>Base graph</a>
          <a href="#boa"><span class="n">07</span>Build·Operate·Access</a>
        </nav>
      </div>
    </div>

    <a id="top"></a>
<!-- ============ HERO ============ -->
<div class="wrap">
  <section class="hero">
    <div class="hero-eyebrow rv"><span class="tick"></span>Org context graphs · a reproducible method</div>
    <h1 class="rv d1">Make an organization <em>legible</em> — to its people, and to AI.</h1>
    <p class="sub rv d2">We build a living, machine-readable model of how a company actually works — its people, processes, systems, friction, and opportunity — then turn it into intelligence the business can use. <b>This is the method, the proof, and the front end waiting to be built.</b></p>
    <div class="hero-cta rv d3">
      <a class="ocg-btn primary" href="#method">See how it's built →</a>
      <a class="ocg-btn ghost" href="#boa">The front-end opportunity</a>
    </div>
    <div class="hero-figure rv d4">
      <!-- D1: dual-surface constellation -->
      <svg class="constellation" viewBox="0 0 1160 360" fill="none" aria-label="A dual-surface constellation: the modeled organization on the left, the engagement work on the right, separated by a projection membrane.">
        <defs>
          <radialGradient id="glowO" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#a98fe0" stop-opacity="0.9"/><stop offset="100%" stop-color="#a98fe0" stop-opacity="0"/></radialGradient>
          <radialGradient id="glowW" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#e6b25a" stop-opacity="0.9"/><stop offset="100%" stop-color="#e6b25a" stop-opacity="0"/></radialGradient>
          <linearGradient id="membrane" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#7dcfff" stop-opacity="0"/><stop offset="50%" stop-color="#7dcfff" stop-opacity="0.5"/><stop offset="100%" stop-color="#7dcfff" stop-opacity="0"/></linearGradient>
        </defs>
        <!-- membrane -->
        <rect x="578" y="20" width="4" height="320" fill="url(#membrane)"/>
        <text x="580" y="352" text-anchor="middle" fill="#7dcfff" opacity="0.55" font-family="'JetBrains Mono Variable', monospace" font-size="10" letter-spacing="2">ONE GRAPH · TWO SURFACES</text>
        <!-- ORG edges (left, purple) -->
        <g stroke="#a98fe0" stroke-width="1" opacity="0.42">
          <path class="c-edge" d="M150 90 L 280 70"/><path class="c-edge" d="M280 70 L 230 175"/><path class="c-edge" d="M230 175 L 120 200"/>
          <path class="c-edge" d="M120 200 L 150 90"/><path class="c-edge" d="M230 175 L 340 150"/><path class="c-edge" d="M340 150 L 420 240"/>
          <path class="c-edge" d="M230 175 L 300 280"/><path class="c-edge" d="M300 280 L 420 240"/><path class="c-edge" d="M280 70 L 430 110"/>
          <path class="c-edge" d="M430 110 L 340 150"/><path class="c-edge" d="M120 200 L 200 300"/><path class="c-edge" d="M200 300 L 300 280"/>
        </g>
        <!-- WORK edges (right, gold) -->
        <g stroke="#e6b25a" stroke-width="1" opacity="0.42">
          <path class="c-edge" d="M730 90 L 860 70"/><path class="c-edge" d="M860 70 L 950 150"/><path class="c-edge" d="M950 150 L 1020 100"/>
          <path class="c-edge" d="M730 90 L 800 180"/><path class="c-edge" d="M800 180 L 860 70"/><path class="c-edge" d="M800 180 L 920 250"/>
          <path class="c-edge" d="M920 250 L 950 150"/><path class="c-edge" d="M800 180 L 700 270"/><path class="c-edge" d="M700 270 L 920 250"/>
          <path class="c-edge" d="M1020 100 L 1040 220"/><path class="c-edge" d="M1040 220 L 920 250"/>
        </g>
        <!-- projection edges crossing membrane -->
        <g stroke="#7dcfff" stroke-width="1.1" opacity="0.5" stroke-dasharray="2 4">
          <path class="c-edge" d="M430 110 L 730 90"/><path class="c-edge" d="M420 240 L 700 270"/><path class="c-edge" d="M340 150 L 800 180"/>
        </g>
        <!-- ORG nodes -->
        <g>
          <circle cx="150" cy="90" r="22" fill="url(#glowO)"/><circle class="c-node" cx="150" cy="90" r="6" fill="#bb9af7"/>
          <circle cx="280" cy="70" r="20" fill="url(#glowO)"/><circle class="c-node" cx="280" cy="70" r="5" fill="#a98fe0"/>
          <circle cx="230" cy="175" r="26" fill="url(#glowO)"/><circle class="c-node" cx="230" cy="175" r="7" fill="#bb9af7"/>
          <circle cx="120" cy="200" r="18" fill="url(#glowO)"/><circle class="c-node" cx="120" cy="200" r="5" fill="#a98fe0"/>
          <circle cx="340" cy="150" r="18" fill="url(#glowO)"/><circle class="c-node" cx="340" cy="150" r="5" fill="#a98fe0"/>
          <circle cx="430" cy="110" r="18" fill="url(#glowO)"/><circle class="c-node" cx="430" cy="110" r="5" fill="#bb9af7"/>
          <circle cx="420" cy="240" r="18" fill="url(#glowO)"/><circle class="c-node" cx="420" cy="240" r="5" fill="#a98fe0"/>
          <circle cx="300" cy="280" r="18" fill="url(#glowO)"/><circle class="c-node" cx="300" cy="280" r="5" fill="#a98fe0"/>
          <circle cx="200" cy="300" r="16" fill="url(#glowO)"/><circle class="c-node" cx="200" cy="300" r="4.5" fill="#bb9af7"/>
        </g>
        <!-- WORK nodes -->
        <g>
          <circle cx="730" cy="90" r="20" fill="url(#glowW)"/><circle class="c-node" cx="730" cy="90" r="5.5" fill="#f2cd83"/>
          <circle cx="860" cy="70" r="18" fill="url(#glowW)"/><circle class="c-node" cx="860" cy="70" r="5" fill="#e6b25a"/>
          <circle cx="950" cy="150" r="22" fill="url(#glowW)"/><circle class="c-node" cx="950" cy="150" r="6" fill="#f2cd83"/>
          <circle cx="1020" cy="100" r="18" fill="url(#glowW)"/><circle class="c-node" cx="1020" cy="100" r="5" fill="#e6b25a"/>
          <circle cx="800" cy="180" r="24" fill="url(#glowW)"/><circle class="c-node" cx="800" cy="180" r="6.5" fill="#f2cd83"/>
          <circle cx="920" cy="250" r="18" fill="url(#glowW)"/><circle class="c-node" cx="920" cy="250" r="5" fill="#e6b25a"/>
          <circle cx="700" cy="270" r="16" fill="url(#glowW)"/><circle class="c-node" cx="700" cy="270" r="4.5" fill="#e6b25a"/>
          <circle cx="1040" cy="220" r="16" fill="url(#glowW)"/><circle class="c-node" cx="1040" cy="220" r="4.5" fill="#f2cd83"/>
        </g>
        <text x="120" y="40" fill="#a98fe0" opacity="0.7" font-family="'JetBrains Mono Variable', monospace" font-size="11" letter-spacing="1.5">THE ORGANIZATION</text>
        <text x="1040" y="40" text-anchor="end" fill="#e6b25a" opacity="0.7" font-family="'JetBrains Mono Variable', monospace" font-size="11" letter-spacing="1.5">THE WORK</text>
      </svg>
      <p style="font-family:var(--mono);font-size:12px;letter-spacing:.04em;color:var(--ink-faint);margin:20px 0 0;max-width:none">aDNA · <span style="color:var(--ink-dim)">agentic DNA</span> — the machine-readable structure of how an organization works, written down once.</p>
    </div>
  </section>
</div>

<hr class="hairline">

<!-- ============ 01 PROBLEM ============ -->
<div class="wrap">
  <section id="problem">
    <div class="seg rv"><span class="num">01</span><span class="kicker">The problem</span></div>
    <h2 class="rv">Organizations are <em>illegible</em>.</h2>
    <p class="lede rv d1">Most of what an organization knows lives nowhere you can point to — in people's heads, in threads, in spreadsheets no one else can read.</p>
    <p class="rv d1">Leaders can't see how the work actually flows. New hires rebuild context from scratch. And AI — the thing that's supposed to help — is blind to an organization it was never given a map of. <strong>You can't automate, advise, or improve what you can't see.</strong></p>
    <div class="grid g3" style="margin-top:32px">
      <div class="card rv d1">
        <div class="tagn">Signal 01</div>
        <h3>High interest, low adoption</h3>
        <p>Teams want AI. They don't adopt it — not because it's hard, but because no one ever set it up for the work they actually do.</p>
      </div>
      <div class="card rv d2">
        <div class="tagn">Signal 02</div>
        <h3>Knowledge in silos</h3>
        <p>The answer is "easy — if you know the right person." The same report gets demanded, independently, by four different teams.</p>
      </div>
      <div class="card rv d3">
        <div class="tagn">Signal 03</div>
        <h3>Friction hides at the seams</h3>
        <p>The most expensive problems aren't inside a team. They're in the handoffs between teams, where work gets rebuilt by hand every cycle.</p>
      </div>
    </div>
  </section>
</div>

<!-- ============ 02 THE GRAPH ============ -->
<div class="wrap">
  <section id="graph">
    <div class="seg rv"><span class="num">02</span><span class="kicker">What it is</span></div>
    <h2 class="rv">A context graph is a map of the organization that <em>machines can read</em>.</h2>
    <p class="lede rv d1">Every person, team, system, process, metric, friction point, risk, and opportunity becomes a <span class="hl-org">node</span>. The relationships between them become <span class="hl-work">edges</span>. The result is one navigable structure that holds how the organization actually works — not the org chart, the real thing.</p>

    <!-- D2: dual-surface anatomy -->
    <div class="rv d2" style="margin:34px 0 10px">
      <svg viewBox="0 0 1160 430" width="100%" fill="none" aria-label="Dual-surface anatomy: the modeled organization, a projection membrane, and the engagement work, with a four-tag node detail.">
        <defs>
          <linearGradient id="memb2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#7dcfff" stop-opacity="0"/><stop offset="50%" stop-color="#7dcfff" stop-opacity="0.55"/><stop offset="100%" stop-color="#7dcfff" stop-opacity="0"/></linearGradient>
        </defs>
        <!-- left panel: organization -->
        <rect x="20" y="36" width="470" height="300" rx="16" fill="rgba(169,143,224,0.05)" stroke="rgba(169,143,224,0.28)"/>
        <text x="44" y="72" fill="#bb9af7" font-family="'JetBrains Mono Variable', monospace" font-size="12" letter-spacing="2">THE MODELED ORGANIZATION</text>
        <text x="44" y="92" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="10.5" letter-spacing="1">client surface · the subject</text>
        <g font-family="Inter, sans-serif" font-size="13" fill="#ece8e1">
          <g transform="translate(44,120)"><rect width="120" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="60" y="22" text-anchor="middle">People</text></g>
          <g transform="translate(178,120)"><rect width="130" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="65" y="22" text-anchor="middle">Departments</text></g>
          <g transform="translate(322,120)"><rect width="110" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="55" y="22" text-anchor="middle">Systems</text></g>
          <g transform="translate(44,168)"><rect width="120" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="60" y="22" text-anchor="middle">Processes</text></g>
          <g transform="translate(178,168)"><rect width="90" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="45" y="22" text-anchor="middle">KPIs</text></g>
          <g transform="translate(282,168)"><rect width="100" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="50" y="22" text-anchor="middle">Friction</text></g>
          <g transform="translate(44,216)"><rect width="90" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="45" y="22" text-anchor="middle">Risks</text></g>
          <g transform="translate(148,216)"><rect width="135" height="34" rx="8" fill="rgba(169,143,224,0.12)" stroke="rgba(169,143,224,0.4)"/><text x="67" y="22" text-anchor="middle">Opportunities</text></g>
        </g>
        <text x="44" y="296" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="10.5">~12 node types · hypothesis → validated</text>

        <!-- seam: one graph, two surfaces -->
        <rect x="578" y="40" width="4" height="290" fill="url(#memb2)"/>
        <text x="580" y="30" text-anchor="middle" fill="#7dcfff" opacity="0.9" font-family="'JetBrains Mono Variable', monospace" font-size="10" letter-spacing="2">ONE GRAPH</text>

        <!-- right panel: the work -->
        <rect x="670" y="36" width="470" height="300" rx="16" fill="rgba(230,178,90,0.05)" stroke="rgba(230,178,90,0.28)"/>
        <text x="694" y="72" fill="#f2cd83" font-family="'JetBrains Mono Variable', monospace" font-size="12" letter-spacing="2">THE ENGAGEMENT</text>
        <text x="694" y="92" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="10.5" letter-spacing="1">engagement surface · our work</text>
        <g font-family="Inter, sans-serif" font-size="13" fill="#ece8e1">
          <g transform="translate(694,120)"><rect width="180" height="34" rx="8" fill="rgba(230,178,90,0.12)" stroke="rgba(230,178,90,0.4)"/><text x="90" y="22" text-anchor="middle">Discovery instruments</text></g>
          <g transform="translate(888,120)"><rect width="100" height="34" rx="8" fill="rgba(230,178,90,0.12)" stroke="rgba(230,178,90,0.4)"/><text x="50" y="22" text-anchor="middle">Missions</text></g>
          <g transform="translate(694,168)"><rect width="110" height="34" rx="8" fill="rgba(230,178,90,0.12)" stroke="rgba(230,178,90,0.4)"/><text x="55" y="22" text-anchor="middle">Decisions</text></g>
          <g transform="translate(818,168)"><rect width="90" height="34" rx="8" fill="rgba(230,178,90,0.12)" stroke="rgba(230,178,90,0.4)"/><text x="45" y="22" text-anchor="middle">Pilots</text></g>
          <g transform="translate(922,168)"><rect width="100" height="34" rx="8" fill="rgba(230,178,90,0.12)" stroke="rgba(230,178,90,0.4)"/><text x="50" y="22" text-anchor="middle">Handoff</text></g>
        </g>
        <text x="694" y="252" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="11" width="300">The method, kept in the same graph as</text>
        <text x="694" y="270" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="11">the subject — so the model stays honest</text>
        <text x="694" y="288" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="11">about what it knows, and how it knows it.</text>
      </svg>
    </div>

    <div class="grid g2" style="margin-top:14px">
      <div class="rv d1">
        <h3 style="font-family:var(--display);font-weight:500;font-size:22px;color:var(--ink);margin:0 0 10px;font-variation-settings:'opsz' 40,'SOFT' 18">Two surfaces, one graph</h3>
        <p>We model two things at once: the <span class="hl-org">organization itself</span> (the subject) and the <span class="hl-work">work of understanding it</span> (the engagement). Every claim about the company is kept next to the evidence for it — so the model can always show its sources, and confidential material is fenced off cleanly.</p>
      </div>
      <div class="rv d2">
        <h3 style="font-family:var(--display);font-weight:500;font-size:22px;color:var(--ink);margin:0 0 10px;font-variation-settings:'opsz' 40,'SOFT' 18">Four tags before a node exists</h3>
        <p>Every node carries four tags before it's allowed in: where it belongs, where it came from, how sensitive it is, and whether it's confirmed or still a guess. Nothing is asserted without a source.</p>
        <div class="chips" style="margin-top:14px">
          <span class="chip"><i class="dot" style="background:var(--org)"></i>surface</span>
          <span class="chip"><i class="dot" style="background:var(--work)"></i>provenance</span>
          <span class="chip"><i class="dot" style="background:#e06a6a"></i>sensitivity</span>
          <span class="chip"><i class="dot" style="background:var(--valid)"></i>status</span>
        </div>
      </div>
    </div>
    <div class="callout rv d2">
      <div class="lbl">The fence</div>
      <p>Confidential material is structurally fenced. The client only ever sees a <strong>deterministic projection</strong> of the graph — a filtered, redacted view built by a repeatable engine — <strong>never the raw model</strong>. For a public company, that fence is the difference between an asset and a liability.</p>
    </div>
  </section>
</div>

<!-- ============ 03 METHOD ============ -->
<div class="wrap">
  <section id="method">
    <div class="seg rv"><span class="num">03</span><span class="kicker">The method</span></div>
    <h2 class="rv">How we build one — a repeatable, <em>ten-step</em> method.</h2>
    <p class="lede rv d1">The same sequence runs every time. The operator makes the handful of judgment calls only a human should make — who the client is, what's in scope, what's confidential, what gets delivered. Everything downstream is structured, deterministic, and auditable.</p>

    <!-- D3: method flow -->
    <div class="movements" style="margin-top:30px">
      <div class="move rv d1">
        <div class="mh"><i></i>Discover</div>
        <div class="step"><span class="sn">01</span><span class="st"><b style="color:var(--ink);font-weight:600">Genesis</b> — agree the ground rules and the finish line before any modeling</span></div>
        <div class="step"><span class="sn">02</span><span class="st"><b style="color:var(--ink);font-weight:600">Ingest</b> — turn sources into a hypothesis graph; every node sourced</span></div>
      </div>
      <div class="move rv d2">
        <div class="mh"><i></i>Harden</div>
        <div class="step"><span class="sn">03</span><span class="st"><b style="color:var(--ink);font-weight:600">Adversarial check</b> — break load-bearing claims; kill what fails</span></div>
        <div class="step"><span class="sn">04</span><span class="st"><b style="color:var(--ink);font-weight:600">Ontology</b> — tag and score every node, by rule not by hand</span></div>
        <div class="step"><span class="sn">05</span><span class="st"><b style="color:var(--ink);font-weight:600">Value model</b> — connect each friction point to the value of fixing it</span></div>
      </div>
      <div class="move rv d3">
        <div class="mh"><i></i>Freeze</div>
        <div class="step"><span class="sn">06</span><span class="st"><b style="color:var(--ink);font-weight:600">Review</b> — a human gate, taken by choice, before the lock</span></div>
        <div class="step"><span class="sn">07</span><span class="st"><b style="color:var(--ink);font-weight:600">Freeze & stamp</b> — certify the baseline so derivatives inherit trust</span></div>
      </div>
      <div class="move rv d4">
        <div class="mh"><i></i>Enable</div>
        <div class="step"><span class="sn">08</span><span class="st"><b style="color:var(--ink);font-weight:600">Project</b> — build the only thing the partner ever sees</span></div>
        <div class="step"><span class="sn">09</span><span class="st"><b style="color:var(--ink);font-weight:600">Enablement plan</b> — graph → a defensible, sequenced game plan</span></div>
        <div class="step"><span class="sn">10</span><span class="st"><b style="color:var(--ink);font-weight:600">Extract</b> — make the whole thing repeatable for the next org</span></div>
      </div>
    </div>

    <p class="rv d1" style="margin-top:8px">Each step has a gate a human signs, and each gate names exactly what it's waiting on. Two rules ride <em style="font-style:italic;color:var(--ink)">every</em> gate — enforced mechanically, not by good intentions:</p>
    <div class="invariants rv d2">
      <div class="inv"><span class="lk">✓</span><span>No unconfirmed claim is <b style="color:var(--ink)">ever</b> allowed to feed a number — a projection, a deliverable figure, a partner-facing surface.</span></div>
      <div class="inv"><span class="lk">✓</span><span>Every count is recomputed from source, under a <b style="color:var(--ink)">named</b> convention. The graph's trustworthiness <b style="color:var(--ink)">is</b> its audit trail.</span></div>
    </div>

    <div class="callout rv d2">
      <div class="lbl">Honesty is built in, not bolted on</div>
      <p>Every figure is rendered with its evidence tier — straight from the source token, never hand-typed. A projected number is made to <em style="font-style:italic;color:var(--ink)">look</em> provisional. The strongest version of a deliverable is the one that says plainly what it doesn't yet know.</p>
      <div class="chips" style="margin-top:14px">
        <span class="badge valid">validated</span>
        <span class="badge proj">projected</span>
        <span class="badge hyp">hypothesis</span>
      </div>
    </div>

    <!-- D4: graph growth -->
    <div class="rv d3" style="margin-top:30px">
      <svg viewBox="0 0 1160 150" width="100%" fill="none" aria-label="The graph grows from a sparse skeleton of hypotheses to a hardened, validated model, then is frozen and stamped.">
        <!-- skeleton -->
        <g opacity="0.85">
          <text x="60" y="24" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="11" letter-spacing="1">SKELETON</text>
          <g stroke="rgba(169,143,224,0.3)" stroke-width="1">
            <path d="M70 70 L 130 55"/><path d="M130 55 L 110 110"/><path d="M110 110 L 70 70"/><path d="M130 55 L 180 90"/>
          </g>
          <circle cx="70" cy="70" r="4" fill="#a98fe0" opacity="0.6"/><circle cx="130" cy="55" r="4" fill="#a98fe0" opacity="0.6"/>
          <circle cx="110" cy="110" r="4" fill="#a98fe0" opacity="0.6"/><circle cx="180" cy="90" r="4" fill="#a98fe0" opacity="0.6"/>
          <text x="60" y="138" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="10">all hypotheses</text>
        </g>
