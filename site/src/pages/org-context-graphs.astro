<script>
  function initOCG(){
    const root = document.querySelector('.ocg') as HTMLElement | null;
    if(!root || root.dataset.ocgInit) return;
    root.dataset.ocgInit = '1';
    const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- reveal on scroll ----
    const rvs = root.querySelectorAll('.rv');
    if(reduce || !('IntersectionObserver' in window)){
      rvs.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      rvs.forEach((el) => io.observe(el));
    }

    // ---- count-up ----
    const fmt = (n: number) => n.toLocaleString('en-US');
    function countUp(el: Element){
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      if(reduce){ el.textContent = fmt(target); return; }
      const dur = 1300;
      let t0 = 0, started = false;
      function tick(ts: number){
        if(!started){ t0 = ts; started = true; }
        const p = Math.min((ts - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(Math.round(target * eased));
        if(p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    const counters = root.querySelectorAll('[data-count]');
    if('IntersectionObserver' in window){
      const cio = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if(e.isIntersecting){ countUp(e.target); cio.unobserve(e.target); } });
      }, { threshold: 0.6 });
      counters.forEach((el) => cio.observe(el));
    } else {
      counters.forEach((el) => countUp(el));
    }

    // ---- scrollspy nav (sub-nav links → section ids) ----
    const links = Array.from(root.querySelectorAll('.subnav a')) as HTMLAnchorElement[];
    const map: Record<string, HTMLAnchorElement> = {};
    links.forEach((a) => { const id = (a.getAttribute('href') || '').slice(1); if(id) map[id] = a; });
    const secs = links
      .map((a) => document.getElementById((a.getAttribute('href') || '').slice(1)))
      .filter((s): s is HTMLElement => Boolean(s));
    if('IntersectionObserver' in window){
      const sio = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if(e.isIntersecting){
            links.forEach((l) => l.classList.remove('active'));
            const a = map[e.target.id];
            if(a) a.classList.add('active');
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px' });
      secs.forEach((s) => sio.observe(s));
    }

    // ---- hero edge draw-in ----
    if(!reduce){
      const edges = root.querySelectorAll<SVGElement>('.constellation .c-edge');
      edges.forEach((p, i) => {
        p.style.transition = 'stroke-dashoffset 1.1s ' + (0.3 + i * 0.045) + 's var(--ease)';
        requestAnimationFrame(() => requestAnimationFrame(() => { p.style.strokeDashoffset = '0'; }));
      });
      const nodes = root.querySelectorAll<SVGElement>('.constellation .c-node');
      nodes.forEach((n, i) => {
        n.style.opacity = '0';
        n.style.transition = 'opacity 0.6s ' + (0.2 + i * 0.04) + 's ease';
        requestAnimationFrame(() => requestAnimationFrame(() => { n.style.opacity = '1'; }));
      });
    }
  }
  document.addEventListener('DOMContentLoaded', initOCG);
  document.addEventListener('astro:page-load', initOCG);
</script>
