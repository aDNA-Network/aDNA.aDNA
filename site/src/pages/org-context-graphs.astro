          <text x="110" y="48" text-anchor="middle" fill="#a8a39b" font-family="'JetBrains Mono Variable', monospace" font-size="10">the base graph · the universal skeleton</text>
        </g>
        <!-- skeleton chips under base -->
        <g font-family="'JetBrains Mono Variable', monospace" font-size="10" fill="#6d6962">
          <text x="580" y="104" text-anchor="middle">people · departments · processes · systems · metrics · friction · risk · opportunity</text>
        </g>
