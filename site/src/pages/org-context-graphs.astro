          <path d="M500 118 C 380 118, 320 170, 230 170"/>
        </g>
        <!-- instances -->
        <g font-family="Inter, sans-serif">
          <g transform="translate(40,50)"><rect width="190" height="40" rx="10" fill="rgba(169,143,224,0.08)" stroke="rgba(169,143,224,0.4)"/><circle cx="22" cy="20" r="5" fill="#a98fe0"/><text x="40" y="25" fill="#ece8e1" font-size="13.5">Digital media</text></g>
          <g transform="translate(40,98)"><rect width="190" height="40" rx="10" fill="rgba(169,143,224,0.08)" stroke="rgba(169,143,224,0.4)"/><circle cx="22" cy="20" r="5" fill="#a98fe0"/><text x="40" y="25" fill="#ece8e1" font-size="13.5">Clinical practice</text></g>
          <g transform="translate(40,146)"><rect width="190" height="40" rx="10" fill="rgba(169,143,224,0.08)" stroke="rgba(169,143,224,0.4)"/><circle cx="22" cy="20" r="5" fill="#a98fe0"/><text x="40" y="25" fill="#ece8e1" font-size="13.5">Hardware startup</text></g>
        </g>
        <text x="950" y="115" fill="#6d6962" font-family="'JetBrains Mono Variable', monospace" font-size="11">one delivered —</text>
