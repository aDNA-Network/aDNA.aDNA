{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adna.dev/schemas/frontmatter/v2.2",
  "title": "aDNA Frontmatter Schema",
  "description": "JSON Schema for validating aDNA content file frontmatter per §7 of the aDNA Universal Standard v2.2",
  "type": "object",
  "required": ["type", "created", "updated", "status", "last_edited_by", "tags"],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Entity classification (e.g., session, mission, customer, context_research)"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of file creation (YYYY-MM-DD)"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of last modification (YYYY-MM-DD)"
    },
    "last_edited_by": {
      "type": "string",
      "minLength": 1,
      "description": "Attribution — who or what last modified this file"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "minItems": 1,
      "description": "Categorization array — at least one tag required"
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the content"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title"
    },
    "banner": {
      "type": "string",
      "description": "Path to banner image (Tier 3 — Obsidian-specific)"
    },
    "icon": {
      "type": "string",
      "description": "Icon identifier (Tier 3 — Obsidian-specific)"
    }
  },
  "additionalProperties": true
}
